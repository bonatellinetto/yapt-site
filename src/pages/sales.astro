---
import SiteLayout from '../layouts/SiteLayout.astro';
import PageHero from '../components/PageHero.astro';
import ModuleDeepDive from '../components/ModuleDeepDive.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTASection from '../components/CTASection.astro';
import MockupYaDeals from '../components/mockups/MockupYaDeals.astro';
import MockupScoring from '../components/mockups/MockupScoring.astro';
import MockupPlaybook from '../components/mockups/MockupPlaybook.astro';
import MockupYaTeam from '../components/mockups/MockupYaTeam.astro';
import MockupProposals from '../components/mockups/MockupProposals.astro';
import MockupYaContact from '../components/mockups/MockupYaContact.astro';
import MockupCalendar from '../components/mockups/MockupCalendar.astro';
import MockupAutoDeal from '../components/mockups/MockupAutoDeal.astro';
import { t, type Locale } from '../lib/i18n';
import { wolfSvg, genericIcons } from '../lib/fauna';

const locale = 'pt-BR' as const;
const m = (key: string) => t(`sales.${key}`, locale);
const meta = m('meta') as { title: string; description: string };
const hero = m('hero') as { badge: string; title: string; subtitle: string };

const gridData = m('grid') as Record<string, any>;
const gridKeys = Object.keys(gridData).filter(k => k !== 'title' && k !== 'subtitle');
const gridFeatures = gridKeys.map(k => ({
  icon: genericIcons[k as keyof typeof genericIcons] || genericIcons.target,
  title: gridData[k].title,
  description: gridData[k].description,
}));

const modules = ['deals','qualification','playbooks','mentor','proposals','contacts','calendar','autoDeal'] as const;

// Pain points
const painPoints = m('painPoints') as any;
const painPointKeys = painPoints ? Object.keys(painPoints).filter(k => k !== 'title' && k !== 'subtitle') : [];

// Timeline
const timeline = m('timeline') as any;
const timelineSteps = timeline?.steps || [];
---

<SiteLayout title={meta.title} description={meta.description} path="/sales" locale={locale}>
  <PageHero
    gradient="linear-gradient(135deg, #312E81, #4F46E5, #6366F1)"
    title={hero.title}
    subtitle={hero.subtitle}
    badge={hero.badge}
    fauna={wolfSvg}
  />

  {/* Pain Points */}
  {painPointKeys.length > 0 && (
    <section data-observe class="py-16 lg:py-24 bg-[#FAFBFC]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-12">
          {painPoints.title && <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-[#1a1a2e]">{painPoints.title}</h2>}
          {painPoints.subtitle && <p class="text-base text-[#656D78] mt-4 max-w-2xl mx-auto">{painPoints.subtitle}</p>}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {(Array.isArray(painPoints.items) ? painPoints.items : painPoints.items ? Object.values(painPoints.items) : painPointKeys.map(k => painPoints[k])).map((pp: any) => (
              <div
                data-fade
                style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;"
                class="bg-white rounded-2xl p-6 border border-red-100"
              >
                <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4 bg-red-50">
                  <span class="text-red-400 text-lg">!</span>
                </div>
                <h3 class="font-poppins text-base font-semibold text-[#1a1a2e] mb-2">{pp.title}</h3>
                <p class="text-sm text-[#656D78] leading-relaxed">{pp.description}</p>
              </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <div class="[&>section]:py-12 [&>section]:lg:py-16">
    {modules.map((key, i) => {
      const mod = m(key) as { subtitle: string; title: string; description: string; features: string[] };
      if (!mod || !mod.title) return null;
      return (
        <>
          <ModuleDeepDive
            title={mod.title}
            subtitle={mod.subtitle}
            description={mod.description}
            features={mod.features || []}
            reversed={i % 2 === 1}
            accentColor="#4F46E5"
          >
            {key === 'deals' && <MockupYaDeals />}
            {key === 'qualification' && <MockupScoring />}
            {key === 'playbooks' && <MockupPlaybook />}
            {key === 'mentor' && <MockupYaTeam />}
            {key === 'proposals' && <MockupProposals />}
            {key === 'contacts' && <MockupYaContact />}
            {key === 'calendar' && <MockupCalendar />}
            {key === 'autoDeal' && <MockupAutoDeal />}
          </ModuleDeepDive>
          {i < modules.length - 1 && <SectionDivider variant="light" />}
        </>
      );
    })}
  </div>

  {/* Timeline */}
  {timelineSteps.length > 0 && (
    <section data-observe class="py-16 lg:py-24" style="background: linear-gradient(135deg, #1a1a2e, #312E81);">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-12">
          {timeline.title && <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-white">{timeline.title}</h2>}
          {timeline.subtitle && <p class="text-base text-white/60 mt-4">{timeline.subtitle}</p>}
        </div>
        <div class="relative">
          <div class="absolute left-6 top-0 bottom-0 w-px bg-indigo-400/20"></div>
          {timelineSteps.map((step: any, i: number) => {
            const isString = typeof step === 'string';
            return (
              <div
                data-fade
                style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;"
                class="relative pl-16 pb-10 last:pb-0"
              >
                <div class="absolute left-4 w-5 h-5 rounded-full border-2 border-indigo-400 bg-[#1a1a2e] flex items-center justify-center">
                  <span class="text-[10px] text-indigo-300 font-bold">{i + 1}</span>
                </div>
                <h3 class="font-poppins text-base font-semibold text-white">{isString ? step : step.title}</h3>
                {!isString && step.description && <p class="text-sm text-white/50 mt-1 leading-relaxed">{step.description}</p>}
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <FeatureGrid
    title={gridData.title}
    features={gridFeatures}
    columns={3}
    accentColor="#4F46E5"
  />

  <CTASection locale={locale} />
</SiteLayout>
