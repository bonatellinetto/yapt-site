---
import SiteLayout from '../layouts/SiteLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTASection from '../components/CTASection.astro';
import { t, type Locale } from '../lib/i18n';

const locale = 'pt-BR' as const;
const m = (key: string) => t(`trustCenter.${key}`, locale);
const meta = m('meta') as { title: string; description: string };
const hero = m('hero') as { badge: string; title: string; subtitle: string };

const sectionKeys = ['compliance','security','infrastructure','aiGovernance'] as const;
const sectionColors: Record<string, string> = {
  compliance: '#F59E0B',
  security: '#10B981',
  infrastructure: '#064E3B',
  aiGovernance: '#8B5CF6',
};

type TrustSection = { title: string; subtitle: string; description: string; features: { title: string; description: string }[] };
const sectionData = sectionKeys.map(key => ({
  key,
  color: sectionColors[key],
  data: m(key) as TrustSection,
})).filter(s => s.data?.title);

// Status items
const status = m('status') as any;
const statusItems = status?.items || [];
---

<SiteLayout title={meta.title} description={meta.description} path="/trust" locale={locale}>
  <PageHero
    gradient="linear-gradient(135deg, #064E3B, #0D9488, #20B2AA)"
    title={hero.title}
    subtitle={hero.subtitle}
    badge={hero.badge}
  />

  {sectionData.map((s, i) => (
    <Fragment>
      <section data-observe class="py-16 lg:py-24">
        <div class={`max-w-7xl mx-auto px-6 flex flex-col ${i % 2 === 1 ? 'lg:flex-row-reverse' : 'lg:flex-row'} items-start gap-12 lg:gap-16`}>
          <div class="flex-1 max-w-xl">
            <div data-fade style="opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;">
              <span class="inline-block text-xs font-semibold uppercase tracking-wider mb-3" style={`color: ${s.color};`}>
                {s.data.subtitle}
              </span>
              <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-[#1a1a2e] leading-tight">
                {s.data.title}
              </h2>
              <p class="text-base text-[#656D78] mt-4 leading-relaxed">{s.data.description}</p>
            </div>
            {s.data.features && (
              <ul class="mt-6 space-y-3">
                {s.data.features.map((feat) => (
                  <li
                    data-fade
                    style="opacity:0;transform:translateY(16px);transition:opacity 0.5s ease,transform 0.5s ease;"
                    class="flex items-start gap-3"
                  >
                    <span class="mt-1.5 w-2 h-2 rounded-full flex-shrink-0" style={`background-color: ${s.color};`} />
                    <div>
                      <span class="text-sm font-medium text-[#1a1a2e]">{feat.title}</span>
                      <span class="text-sm text-[#656D78]"> — {feat.description}</span>
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </div>
          <div class="flex-1 max-w-md w-full hidden lg:block">
            <div
              data-fade
              class="rounded-2xl p-8"
              style={`opacity:0;transform:translateY(24px);transition:opacity 0.8s ease,transform 0.8s ease;background: ${s.color}08;`}
            >
              <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-4" style={`background: ${s.color}15;`}>
                <div class="w-8 h-8 rounded-full" style={`background: ${s.color}30;`}></div>
              </div>
              <div class="space-y-3">
                <div class="h-3 rounded-full w-3/4" style={`background: ${s.color}12;`}></div>
                <div class="h-3 rounded-full w-1/2" style={`background: ${s.color}08;`}></div>
                <div class="h-3 rounded-full w-2/3" style={`background: ${s.color}10;`}></div>
              </div>
            </div>
          </div>
        </div>
      </section>
      {i < sectionData.length - 1 && <SectionDivider variant="light" />}
    </Fragment>
  ))}

  {/* Status Grid */}
  {statusItems.length > 0 && (
    <section data-observe class="py-16 lg:py-24 bg-[#FAFBFC]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-12">
          {status.title && <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-[#1a1a2e]">{status.title}</h2>}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {statusItems.map((item: any) => {
            const statusColor = item.status === 'active' ? '#10B981' : item.status === 'progress' ? '#F59E0B' : '#94A3B8';
            return (
              <div
                data-fade
                style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;"
                class="bg-white rounded-xl p-4 border border-gray-100"
              >
                <div class="flex items-center gap-2 mb-2">
                  <div class="w-2 h-2 rounded-full" style={`background: ${statusColor};`}></div>
                  <span class="text-xs uppercase tracking-wider" style={`color: ${statusColor};`}>{item.statusLabel}</span>
                </div>
                <h3 class="text-sm font-medium text-[#1a1a2e]">{item.title}</h3>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <CTASection locale={locale} />
</SiteLayout>
