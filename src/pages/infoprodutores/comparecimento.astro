  .bsp-item svg { width:22px;height:22px; }
  .bsp-item strong { color:var(--white); }

  /* ─── CTA FINAL ─── */
  #cta-final { padding:120px 0;background:linear-gradient(135deg,#050f08 0%,#0a0a0a 40%,#030f08 100%);position:relative;overflow:hidden; }
  #cta-final::before { content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:700px;background:radial-gradient(circle,rgba(37,211,102,0.1) 0%,transparent 65%);pointer-events:none; }
  .cta-final-inner { text-align:center;position:relative;z-index:2; }
  .cta-final-headline { font-size:clamp(28px,5vw,56px);font-weight:800;color:var(--white);line-height:1.2;margin:16px 0; }
  .cta-final-headline .orange { color:var(--orange); }
  .cta-final-sub { font-size:17px;color:var(--gray-mid);margin-bottom:48px;line-height:1.6; }
  .cta-buttons { display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:24px; }
  .btn-wa-lg { display:inline-flex;align-items:center;gap:12px;background:var(--wa-green);color:#000;font-size:17px;font-weight:700;padding:20px 40px;border-radius:14px;text-decoration:none;transition:all .2s;box-shadow:0 8px 40px rgba(37,211,102,0.35); }
  .btn-wa-lg:hover { background:#1fbb59;transform:translateY(-3px);box-shadow:0 16px 60px rgba(37,211,102,0.45); }
  .btn-outline-lg { display:inline-flex;align-items:center;gap:10px;background:transparent;color:var(--white);font-size:17px;font-weight:600;padding:20px 40px;border-radius:14px;text-decoration:none;border:1px solid rgba(255,255,255,0.2);transition:all .2s; }
  .btn-outline-lg:hover { background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.3); }
  .cta-microcopy { font-size:13px;color:var(--text-dim); }

  /* ─── MID CTA ─── */
  .mid-cta { text-align:center;padding:48px 0 8px; }
  .mid-cta a { display:inline-flex;align-items:center;gap:10px;background:var(--wa-green);color:#000;font-size:15px;font-weight:700;padding:16px 32px;border-radius:12px;text-decoration:none;box-shadow:0 8px 32px rgba(37,211,102,0.3);transition:all .2s; }
  .mid-cta a:hover { transform:translateY(-2px);box-shadow:0 14px 40px rgba(37,211,102,0.45); }
  .mid-cta p { font-size:12px;color:var(--text-dim);margin-top:10px; }

  /* ─── FOOTER ─── */
  footer { padding:40px 0;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px; }
  .footer-logo { font-size:18px;font-weight:700;color:var(--white); }
  .footer-logo span { color:var(--teal-light); }
  .footer-links { display:flex;gap:24px; }
  .footer-links a { font-size:13px;color:var(--text-dim);text-decoration:none; }
  .footer-links a:hover { color:var(--white); }
  .footer-copy { font-size:12px;color:var(--text-dim); }
  .format-pill { background:var(--bg-card);border:1px solid var(--border);border-radius:100px;padding:4px 12px;font-size:11px;color:var(--text-dim);font-weight:500; }

  /* ─── REVEAL ─── */
  .reveal { opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease; }
  .reveal.visible { opacity:1;transform:translateY(0); }

  /* ─── WA SVG shorthand ─── */
  .svg-wa { display:inline-block;vertical-align:middle; }

  /* ─── RESPONSIVE ─── */
  @media(max-width:900px){
    .hero-inner,.problema-inner,.pra-quem-inner{grid-template-columns:1fr;}
    .virada-steps{grid-template-columns:repeat(2,1fr);}
    .lt-track,.lt-cards{grid-template-columns:1fr 1fr;}
    .lt-track::before{display:none;}
    .features-grid{grid-template-columns:1fr 1fr;}
    .formatos-grid{grid-template-columns:1fr;}
    .phone-wrap{margin-top:40px;}
  }
  @media(max-width:600px){
    .features-grid,.formatos-grid{grid-template-columns:1fr;}
    .virada-steps{grid-template-columns:1fr;}
    .lt-track,.lt-cards{grid-template-columns:1fr;}
    .phone-frame{width:260px;height:520px;}
    .hero-stats{gap:20px;}
    .split-visual{grid-template-columns:1fr;}
  }
</style>
