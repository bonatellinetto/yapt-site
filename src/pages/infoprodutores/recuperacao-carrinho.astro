  /* ─── FORTALEZAS ─── */
  #fortalezas { padding:100px 0; }
  .features-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:60px;background:var(--border);border-radius:20px;overflow:hidden; }
  .feat-card { background:var(--bg-card);padding:36px 32px;transition:all .3s;position:relative;overflow:hidden; }
  .feat-card::before { content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--wa-green),var(--teal));opacity:0;transition:opacity .3s; }
  .feat-card:hover { background:var(--bg-card2); }
  .feat-card:hover::before { opacity:1; }
  .feat-num { font-size:11px;font-weight:700;letter-spacing:.1em;color:var(--text-dim);text-transform:uppercase;margin-bottom:20px; }
  .feat-icon { width:48px;height:48px;border-radius:12px;background:rgba(37,211,102,0.1);border:1px solid rgba(37,211,102,0.2);display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:20px; }
  .feat-icon.teal { background:rgba(32,178,170,0.1);border-color:rgba(32,178,170,0.2); }
  .feat-title { font-size:16px;font-weight:700;color:var(--white);margin-bottom:10px; }
  .feat-desc { font-size:13px;color:var(--text-dim);line-height:1.7; }
  .feat-badge { display:inline-flex;margin-top:16px;background:rgba(37,211,102,0.1);color:var(--wa-green);font-size:11px;font-weight:600;padding:4px 10px;border-radius:100px;border:1px solid rgba(37,211,102,0.2); }

  /* ─── CALCULADORA ─── */
  #calculadora { padding:100px 0; background:linear-gradient(180deg,#0a0a0a 0%,#08100a 50%,#0a0a0a 100%); }
  .calc-inner { display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center; }
  .calc-sliders { display:flex;flex-direction:column;gap:28px; }
  .calc-row label { display:block;font-size:13px;color:var(--text-dim);margin-bottom:8px;font-weight:500; }
  .calc-row label span { color:var(--white);font-weight:700; }
  input[type=range] {
    -webkit-appearance:none;width:100%;height:4px;border-radius:2px;
    background:linear-gradient(90deg,var(--wa-green) var(--pct,50%),rgba(255,255,255,0.1) var(--pct,50%));
    outline:none;cursor:pointer;
  }
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance:none;width:18px;height:18px;border-radius:50%;
    background:var(--wa-green);box-shadow:0 0 0 3px rgba(37,211,102,0.2);
    cursor:pointer;transition:box-shadow .2s;
  }
  input[type=range]::-webkit-slider-thumb:hover { box-shadow:0 0 0 6px rgba(37,211,102,0.25); }
  .calc-result { background:var(--bg-card);border:1px solid var(--border);border-radius:20px;padding:36px; }
  .calc-result-title { font-size:13px;font-weight:600;color:var(--text-dim);text-transform:uppercase;letter-spacing:.08em;margin-bottom:24px; }
  .calc-metric { display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid var(--border); }
  .calc-metric:last-child { border-bottom:none; }
  .calc-metric-label { font-size:13px;color:var(--text-dim); }
  .calc-metric-val { font-size:15px;font-weight:700;color:var(--white); }
  .calc-metric-val.green { color:var(--wa-green);font-size:20px; }
  .calc-metric-val.red { color:var(--red); }
  .calc-gain { margin-top:24px;padding:20px;background:rgba(37,211,102,0.08);border:1px solid rgba(37,211,102,0.2);border-radius:12px;text-align:center; }
  .calc-gain-label { font-size:12px;color:var(--text-dim);margin-bottom:8px; }
  .calc-gain-val { font-size:36px;font-weight:800;color:var(--wa-green); }
  .calc-gain-sub { font-size:12px;color:var(--text-dim);margin-top:4px; }

  /* ─── ALÉM DO CARRINHO ─── */
  #alem { padding:100px 0; }
  .alem-inner { display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center; }
  .alem-list { display:flex;flex-direction:column;gap:16px;margin-top:32px; }
  .alem-item { display:flex;gap:16px;align-items:flex-start;padding:20px 24px;background:var(--bg-card);border:1px solid var(--border);border-radius:14px;transition:all .3s; }
  .alem-item:hover { border-color:rgba(37,211,102,0.25);transform:translateX(4px); }
  .alem-icon { width:40px;height:40px;border-radius:10px;background:rgba(37,211,102,0.1);border:1px solid rgba(37,211,102,0.2);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0; }
  .alem-text strong { display:block;font-size:14px;font-weight:600;color:var(--white);margin-bottom:4px; }
  .alem-text p { font-size:13px;color:var(--text-dim);line-height:1.5; }

  /* ─── PRA QUEM ─── */
  #pra-quem { padding:100px 0; background:linear-gradient(180deg,#0a0a0a 0%,#0a100a 50%,#0a0a0a 100%); }
  .pra-quem-inner { display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center; }
  .checklist { display:flex;flex-direction:column;gap:12px;margin-top:32px; }
  .check-item { display:flex;gap:12px;align-items:flex-start;padding:14px 18px;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;transition:all .3s; }
  .check-item:hover { border-color:rgba(37,211,102,0.3); }
  .check-icon { width:22px;height:22px;border-radius:50%;background:var(--wa-green);display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;color:#000;font-weight:700; }
  .check-text { font-size:13px;color:var(--text);line-height:1.5; }
  .contraindication { margin-top:20px;padding:18px 22px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:12px; }
  .contra-label { font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-dim);margin-bottom:6px; }
  .contra-text { font-size:13px;color:var(--text-dim);line-height:1.6; }

  /* ─── OBJEÇÕES ─── */
  #objections { padding:100px 0; }
  .obj-grid { display:flex;flex-direction:column;gap:16px;margin-top:60px; }
  .obj-item { background:var(--bg-card);border:1px solid var(--border);border-radius:16px;overflow:hidden; }
  .obj-q { padding:22px 28px;display:flex;justify-content:space-between;align-items:center;font-size:15px;font-weight:600;color:var(--white); }
  .obj-q::after { content:'+';font-size:22px;color:var(--wa-green);font-weight:300;flex-shrink:0; }
  .obj-a { padding:0 28px 22px;font-size:14px;color:var(--text-dim);line-height:1.7;border-top:1px solid var(--border);padding-top:18px; }

  /* ─── BSP STRIP ─── */
  .bsp-strip { padding:20px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);margin:60px 0; }
  .bsp-inner { display:flex;align-items:center;justify-content:center;gap:40px;flex-wrap:wrap; }
  .bsp-item { display:flex;align-items:center;gap:10px;font-size:13px;color:var(--text-dim);font-weight:500; }
  .bsp-item svg { width:22px;height:22px; }
  .bsp-item strong { color:var(--white); }
  .platform-logos { display:flex;gap:8px;flex-wrap:wrap;margin-top:12px; }
  .platform-pill { background:var(--bg-card);border:1px solid var(--border);border-radius:100px;padding:4px 12px;font-size:11px;color:var(--text-dim);font-weight:500; }

  /* ─── CTA FINAL ─── */
  #cta-final {
    padding:120px 0; background:linear-gradient(135deg,#050f08 0%,#0a0a0a 40%,#030f08 100%);
    position:relative;overflow:hidden;
  }
  #cta-final::before {
    content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
    width:700px;height:700px;background:radial-gradient(circle,rgba(37,211,102,0.1) 0%,transparent 65%);
    pointer-events:none;
  }
  .cta-final-inner { text-align:center;position:relative;z-index:2; }
  .cta-final-headline { font-size:clamp(28px,5vw,56px);font-weight:800;color:var(--white);line-height:1.2;margin:16px 0; }
  .cta-final-headline .red { color:var(--red); }
  .cta-final-sub { font-size:17px;color:var(--gray-mid);margin-bottom:48px;line-height:1.6; }
  .cta-buttons { display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:24px; }
  .btn-wa-lg {
    display:inline-flex;align-items:center;gap:12px;background:var(--wa-green);color:#000;
    font-size:17px;font-weight:700;padding:20px 40px;border-radius:14px;text-decoration:none;
    transition:all .2s;box-shadow:0 8px 40px rgba(37,211,102,0.35);
  }
  .btn-wa-lg:hover { background:#1fbb59;transform:translateY(-3px);box-shadow:0 16px 60px rgba(37,211,102,0.45); }
  .btn-outline-lg {
    display:inline-flex;align-items:center;gap:10px;background:transparent;color:var(--white);
    font-size:17px;font-weight:600;padding:20px 40px;border-radius:14px;text-decoration:none;
    border:1px solid rgba(255,255,255,0.2);transition:all .2s;
  }
  .btn-outline-lg:hover { background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.3); }
  .cta-microcopy { font-size:13px;color:var(--text-dim); }

  /* ─── MID CTA ─── */
  .mid-cta { text-align:center;padding:48px 0 8px; }
  .mid-cta a {
    display:inline-flex;align-items:center;gap:10px;background:var(--wa-green);color:#000;
    font-size:15px;font-weight:700;padding:16px 32px;border-radius:12px;text-decoration:none;
    box-shadow:0 8px 32px rgba(37,211,102,0.3);transition:all .2s;
  }
  .mid-cta a:hover { transform:translateY(-2px);box-shadow:0 14px 40px rgba(37,211,102,0.45); }
  .mid-cta p { font-size:12px;color:var(--text-dim);margin-top:10px; }

  /* ─── FOOTER ─── */
  footer { padding:40px 0;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px; }
  .footer-logo { font-size:18px;font-weight:700;color:var(--white); }
  .footer-logo span { color:var(--teal-light); }
  .footer-links { display:flex;gap:24px; }
  .footer-links a { font-size:13px;color:var(--text-dim);text-decoration:none; }
  .footer-links a:hover { color:var(--white); }
  .footer-copy { font-size:12px;color:var(--text-dim); }

  /* ─── SCROLL REVEAL ─── */
  .reveal { opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease; }
  .reveal.visible { opacity:1;transform:translateY(0); }

  /* ─── RESPONSIVE ─── */
  @media(max-width:900px){
    .hero-inner,.problema-inner,.calc-inner,.alem-inner,.pra-quem-inner{grid-template-columns:1fr;}
    .virada-features,.features-grid{grid-template-columns:1fr 1fr;}
    .phone-wrap{margin-top:40px;}
    .steps-v::before{display:none;}
  }
  @media(max-width:600px){
    .virada-features,.features-grid{grid-template-columns:1fr;}
    .phone-frame{width:260px;height:520px;}
    .hero-stats{gap:20px;}
  }
</style>
</head>
