  .stat-num span { color: var(--wa-green); }
  .stat-num span.red { color: var(--red); }
  .stat-label { font-size: 12px; color: var(--text-dim); margin-top: 4px; }

  /* ─── PHONE SYSTEM ─── */
  .phone-wrap { display: flex; justify-content: center; align-items: center; position: relative; }
  .phone-wrap::before {
    content: ''; position: absolute; top: 55%; left: 50%; transform: translate(-50%,-50%);
