<script>
  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Staggered grid reveals
  document.querySelectorAll('.features-grid .feat-card, .ponto, .check-item, .obj-item, .alem-item, .vfeat').forEach((el, i) => {
    el.style.transitionDelay = `${i * 55}ms`;
    el.classList.add('reveal');
    observer.observe(el);
  });

  // ── CALCULADORA ──
  const slAb = document.getElementById('sl-ab');
  const slTk = document.getElementById('sl-tk');

  function fmt(n) { return 'R$ ' + Math.round(n).toLocaleString('pt-BR'); }
  function updateSlider(sl) {
    const pct = ((sl.value - sl.min) / (sl.max - sl.min)) * 100;
    sl.style.setProperty('--pct', pct + '%');
  }
  function calcUpdate() {
    const ab = +slAb.value, tk = +slTk.value;
    document.getElementById('lbl-ab').textContent = ab.toLocaleString('pt-BR');
    document.getElementById('lbl-tk').textContent = 'R$ ' + tk.toLocaleString('pt-BR');
    const total = ab * tk;
    const email = total * 0.04;
    const yapt  = total * 0.20;
    const gain  = yapt - email;
    document.getElementById('r-total').textContent = fmt(total);
    document.getElementById('r-email').textContent = fmt(email);
    document.getElementById('r-yapt').textContent  = fmt(yapt);
    document.getElementById('r-gain').textContent  = fmt(gain);
    updateSlider(slAb); updateSlider(slTk);
  }
  slAb.addEventListener('input', calcUpdate);
  slTk.addEventListener('input', calcUpdate);
  calcUpdate();

  // ── WHATSAPP CONVERSATION ENGINE ──
  function runConversation(bodyEl) {
    const typingEl    = bodyEl.querySelector('.wa-typing');
    const msgs        = Array.from(bodyEl.querySelectorAll('.wa-msg'));
    const dateDivider = bodyEl.querySelector('.wa-date-divider');
    const TYPING_SPEED = 36, TYPING_MIN = 650, TYPING_MAX = 1900;
    const GAP_OUT = 280, GAP_AFTER = 240, END_PAUSE = 3500;

    function delay(ms) { return new Promise(r => setTimeout(r, ms)); }
    function typingDur(text) { return Math.min(TYPING_MAX, Math.max(TYPING_MIN, text.length * TYPING_SPEED)); }
    function scrollBot() { bodyEl.scrollTo({ top: bodyEl.scrollHeight, behavior: 'smooth' }); }

    // hide = display:none so element takes NO space → scroll stays at top
    function hideEl(el) {
      el.style.transition = 'none';
      el.classList.remove('visible');
      el.style.display = 'none';
    }

    // show = make visible in DOM first (flex/block), then fade+slide in
    function showEl(el) {
      const isMsg = el.classList.contains('wa-msg');
      el.style.display = isMsg ? (el.classList.contains('in') ? 'block' : 'block') : 'flex';
      // force reflow so transition fires
      void el.offsetHeight;
      requestAnimationFrame(() => {
        el.style.transition = '';
        el.classList.add('visible');
      });
    }

    function reset() {
      const all = [...msgs, typingEl, dateDivider].filter(Boolean);
      all.forEach(el => hideEl(el));
      if (typingEl) bodyEl.appendChild(typingEl);
      bodyEl.scrollTop = 0;
    }

    async function showTyping(forEl) {
      if (!typingEl) return;
      bodyEl.appendChild(typingEl);
      showEl(typingEl); scrollBot();
      await delay(typingDur(forEl.textContent.trim()));
      hideEl(typingEl);
      await delay(50);
    }

    async function playOnce() {
      reset();
      await delay(300);
      if (dateDivider) { showEl(dateDivider); scrollBot(); await delay(450); }
      for (let i = 0; i < msgs.length; i++) {
        const msg = msgs[i];
        if (msg.classList.contains('in')) { await showTyping(msg); }
        else { await delay(GAP_OUT); }
        showEl(msg); scrollBot();
        await delay(GAP_AFTER + Math.min(750, msg.textContent.trim().length * 11));
      }
      if (typingEl) { bodyEl.appendChild(typingEl); showEl(typingEl); scrollBot(); }
      await delay(END_PAUSE);
    }

    async function loop() { while(true) { await playOnce(); } }
    loop();
  }

  document.querySelectorAll('.wa-body').forEach((body, i) => {
    setTimeout(() => runConversation(body), i * 2000);
  });
</script>
