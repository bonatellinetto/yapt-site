---
/**
 * yapt. — System Status Page (PT-BR)
 * Uses SiteLayout (SiteNavbar + SiteFooter) for brand consistency.
 * Data is hardcoded for now; will connect to real monitoring later.
 */

import SiteLayout from '../layouts/SiteLayout.astro';
import { t, type Locale } from '../lib/i18n';

const locale = 'pt-BR' as const;
const s = (key: string) => t(`status.${key}`, locale);
const meta = s('meta') as { title: string; description: string };

// ─── DATA (hardcoded — replace with API later) ───
const overallStatus = 'operational'; // operational | degraded | outage
const uptimePct = '99.97';
const avgLatency = '1.2s';
const mttr = '14min';
const lastCheck = '2 minutos';

const services = [
  {
    id: 'inbox',
    icon: '💬',
    iconBg: 'rgba(32,178,170,0.12)',
    name: 'Inbox & Mensagens',
    desc: 'Envio, recebimento e roteamento de mensagens',
    status: 'operational',
    uptime: '99.9',
    degradedDays: [8],
    maintenanceDays: [] as number[],
    components: [
      { name: 'send-message-sync', latency: '142ms', pct: 98, status: 'operational' },
      { name: 'webhook-bsp-platform', latency: '89ms', pct: 99, status: 'operational' },
      { name: 'webhook-waha', latency: '61ms', pct: 100, status: 'operational' },
    ],
  },
  {
    id: 'ai',
    icon: '✦',
    iconBg: 'rgba(139,92,246,0.12)',
    name: 'Inteligência Artificial',
    desc: 'Agentes, copilot e processamento NLP',
    status: 'operational',
    uptime: '99.8',
    degradedDays: [4, 18],
    maintenanceDays: [] as number[],
    components: [
      { name: 'ai-orchestrator', latency: '380ms', pct: 96, status: 'operational' },
      { name: 'mat-executor', latency: '210ms', pct: 99, status: 'operational' },
    ],
  },
  {
    id: 'flows',
    icon: '⚡',
    iconBg: 'rgba(245,158,11,0.1)',
    name: 'Automações (Flows)',
    desc: 'Motor de execução de fluxos automatizados',
    status: 'operational',
    uptime: '99.9',
    degradedDays: [] as number[],
    maintenanceDays: [] as number[],
    components: [
      { name: 'flow-runner', latency: '195ms', pct: 99, status: 'operational' },
      { name: 'flow-effects', latency: '88ms', pct: 100, status: 'operational' },
      { name: 'automation-processor', latency: '167ms', pct: 98, status: 'operational' },
    ],
  },
  {
    id: 'wa',
    icon: 'wa',
    iconBg: 'rgba(37,211,102,0.1)',
    name: 'WhatsApp Business API',
    desc: 'Canal oficial via BSP New Way',
    status: 'operational',
    uptime: '100',
    degradedDays: [] as number[],
    maintenanceDays: [] as number[],
    components: [
      { name: 'webhook-waent', latency: '73ms', pct: 100, status: 'operational' },
      { name: 'send-active-message', latency: '98ms', pct: 100, status: 'operational' },
    ],
  },
  {
    id: 'ig',
    icon: '📷',
    iconBg: 'rgba(225,48,108,0.1)',
    name: 'Instagram & Facebook',
    desc: 'Canais Meta Graph API',
    status: 'operational',
    uptime: '99.6',
    degradedDays: [3, 11, 22],
    maintenanceDays: [] as number[],
    components: [
      { name: 'webhook-instagram', latency: '201ms', pct: 97, status: 'operational' },
      { name: 'webhook-meta-router', latency: '134ms', pct: 99, status: 'operational' },
    ],
  },
  {
    id: 'ads',
    icon: '📊',
    iconBg: 'rgba(59,130,246,0.1)',
    name: 'Campanhas & Ads',
    desc: 'Sincronização e tracking de campanhas',
    status: 'operational',
    uptime: '99.9',
    degradedDays: [] as number[],
    maintenanceDays: [] as number[],
    components: [
      { name: 'ad-sync-campaigns', latency: '420ms', pct: 99, status: 'operational' },
      { name: 'ad-lead-webhook', latency: '58ms', pct: 100, status: 'operational' },
    ],
  },
  {
    id: 'plat',
    icon: '🛡',
    iconBg: 'rgba(32,178,170,0.08)',
    name: 'Plataforma (Login / API)',
    desc: 'Autenticação, dashboard e APIs',
    status: 'operational',
    uptime: '100',
    degradedDays: [] as number[],
    maintenanceDays: [2],
    components: [
      { name: 'health-check', latency: '12ms', pct: 100, status: 'operational' },
      { name: 'supabase-auth', latency: '45ms', pct: 100, status: 'operational' },
    ],
  },
];

const slaMetrics = [
  { value: '99.97%', label: 'Disponibilidade global', teal: true },
  { value: '14 min', label: 'MTTR (resolução média)', teal: false },
  { value: '3', label: 'Incidentes resolvidos', teal: false },
  { value: '0', label: 'Incidentes em aberto', teal: false },
];

const maintenance = [
  {
    title: 'Atualização de infra — Flows Engine v2.4',
    meta: 'Domingo, 15 Mar 2026 · 02:00–04:00 BRT · Impacto esperado: nenhum (rolling deploy)',
    badge: 'Agendado',
  },
];

const incidents = [
  {
    title: 'Latência elevada em Instagram webhooks',
    meta: '03 Mar 2026 · Duração: 18 minutos · Afetou: Instagram & Facebook',
    resolved: true,
    timeline: [
      { time: '14:07 BRT', status: 'investigating', label: 'Investigando', text: 'Alertas de latência P99 acima de 4s no webhook-instagram. Time notificado automaticamente.' },
      { time: '14:14 BRT', status: 'identified', label: 'Identificado', text: 'Causa identificada: spike de volume proveniente de campanha de leads no Meta Ads. Queue backpressure acumulado.' },
      { time: '14:25 BRT', status: 'resolved', label: 'Resolvido', text: 'Scaling horizontal aplicado. Latência normalizada em <800ms. Sem perda de mensagens — todas processadas via retry automático.' },
    ],
  },
  {
    title: 'Falha pontual no ai-orchestrator',
    meta: '19 Fev 2026 · Duração: 9 minutos · Afetou: Inteligência Artificial',
    resolved: true,
    timeline: [
      { time: '09:42 BRT', status: 'investigating', label: 'Investigando', text: 'Timeout excessivo detectado em chamadas ao modelo LLM externo. Taxa de erro subiu para 12%.' },
      { time: '09:51 BRT', status: 'resolved', label: 'Resolvido', text: 'Circuit-breaker ativado, fallback para modelo secundário. Serviço normalizado. Postmortem: adicionar timeout adaptativo por modelo.' },
    ],
  },
  {
    title: 'Manutenção de banco de dados — Supabase Auth',
    meta: '02 Fev 2026 · Duração: 4 minutos · Manutenção programada',
    resolved: true,
    timeline: [
      { time: '03:00 BRT', status: 'identified', label: 'Manutenção iniciada', text: 'Upgrade de versão do Supabase conforme agendado. Janela: 03:00–03:30 BRT.' },
      { time: '03:04 BRT', status: 'resolved', label: 'Concluído', text: 'Upgrade concluído em 4 minutos, dentro da janela. Zero impacto para usuários ativos (horário de baixo tráfego).' },
    ],
  },
];

// Global uptime bars (90 days)
const globalDegradedDays = [8, 22, 41, 65, 79];
const globalMaintenanceDays = [14, 55];

function statusBadgeClass(status: string) {
  const map: Record<string, string> = {
    operational: 'badge-operational',
    degraded: 'badge-degraded',
    outage: 'badge-outage',
    maintenance: 'badge-maintenance',
  };
  return map[status] || 'badge-operational';
}

function statusLabel(status: string) {
  const map: Record<string, string> = {
    operational: 'Operacional',
    degraded: 'Degradado',
    outage: 'Indisponível',
    maintenance: 'Manutenção',
  };
  return map[status] || status;
}

function overallLabel(status: string) {
  const map: Record<string, string> = {
    operational: 'All Systems Operational',
    degraded: 'Partial System Degradation',
    outage: 'Major System Outage',
  };
  return map[status] || status;
}

function pulseDotClass(status: string) {
  if (status === 'degraded') return 'pulse-dot yellow';
  if (status === 'outage') return 'pulse-dot red';
  return 'pulse-dot';
}
---

<SiteLayout title={meta.title} description={meta.description} path="/status" locale={locale}>

<!-- Dark status page wrapper -->
<div class="status-page">

  <!-- HERO -->
  <div class="status-hero">
    <div class="status-hero-inner">
      <div class="hero-eyebrow">System Status</div>

      <div class={`hero-status-banner ${overallStatus !== 'operational' ? overallStatus : ''}`}>
        <div class="banner-left">
          <div class="banner-indicator">
            <div class={pulseDotClass(overallStatus)}></div>
            <div class="banner-title">{overallLabel(overallStatus)}</div>
          </div>
          <div class="banner-subtitle">Última verificação há {lastCheck} &middot; Monitora 7 serviços e 14 componentes</div>
        </div>
        <div class="banner-right">
          <div class="banner-stat">
            <div class="banner-stat-value green">{uptimePct}%</div>
            <div class="banner-stat-label">Uptime 90 dias</div>
          </div>
          <div class="banner-divider"></div>
          <div class="banner-stat">
            <div class="banner-stat-value">{avgLatency}</div>
            <div class="banner-stat-label">Latência média</div>
          </div>
          <div class="banner-divider"></div>
          <div class="banner-stat">
            <div class="banner-stat-value">{mttr}</div>
            <div class="banner-stat-label">MTTR médio</div>
          </div>
        </div>
      </div>

      <!-- Global uptime bar (90 days) -->
      <div class="uptime-strip">
        <div class="uptime-label">90 dias</div>
        <div class="uptime-bars">
          {Array.from({ length: 90 }, (_, i) => {
            let cls = 'uptime-bar';
            if (globalMaintenanceDays.includes(i)) cls += ' maintenance';
            else if (globalDegradedDays.includes(i)) cls += ' degraded';
            return <div class={cls} />;
          })}
        </div>
        <div class="uptime-period">Hoje</div>
        <div class="uptime-pct">{uptimePct}%</div>
      </div>
    </div>
  </div>

  <!-- SERVICES -->
  <div class="status-section">
    <div class="section-header">
      <div class="section-title">Serviços</div>
      <div class="legend">
        <div class="legend-item"><div class="legend-dot" style="background:rgba(34,197,94,0.7)"></div>Operacional</div>
        <div class="legend-item"><div class="legend-dot" style="background:rgba(245,158,11,0.6)"></div>Degradado</div>
        <div class="legend-item"><div class="legend-dot" style="background:rgba(59,130,246,0.5)"></div>Manutenção</div>
      </div>
    </div>

    <div class="services-grid">
      {services.map((svc) => (
        <div class="service-card" data-toggle>
          <div class="service-row">
            <div class="service-icon" style={`background:${svc.iconBg}`}>
              {svc.icon === 'wa' ? (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.025.507 3.934 1.395 5.61L0 24l6.59-1.374C8.202 23.51 10.063 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.895 0-3.665-.513-5.18-1.405l-.371-.22-3.852.804.823-3.76-.241-.389C2.516 15.593 2 13.86 2 12 2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
              ) : (
                <Fragment set:text={svc.icon} />
              )}
            </div>
            <div class="service-info">
              <div class="service-name">{svc.name}</div>
              <div class="service-desc">{svc.desc}</div>
            </div>
            <div class="service-uptime-bars">
              {Array.from({ length: 30 }, (_, i) => {
                let cls = 'mini-bar';
                if (svc.maintenanceDays.includes(i)) cls += ' maintenance';
                else if (svc.degradedDays.includes(i)) cls += ' degraded';
                return <div class={cls} />;
              })}
            </div>
            <div class="service-uptime-pct">{svc.uptime}%</div>
            <div class={`service-badge ${statusBadgeClass(svc.status)}`}>
              <div class="badge-dot"></div>{statusLabel(svc.status)}
            </div>
            <div class="service-expand-icon">&#9662;</div>
          </div>
          <div class="service-detail">
            <div class="component-list">
              {svc.components.map((comp) => (
                <div class="component-item">
                  <div class="component-name">{comp.name}</div>
                  <div class="component-bar-wrap">
                    <div class="component-bar-fill" style={`width:${comp.pct}%`}></div>
                  </div>
                  <div class="component-latency">{comp.latency}</div>
                  <div class={`component-status ${comp.status === 'degraded' ? 'yellow' : ''}`}>
                    {statusLabel(comp.status)}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- SLA METRICS -->
  <div class="status-section" style="margin-top:40px">
    <div class="section-header">
      <div class="section-title">SLA &amp; Métricas</div>
      <div class="section-meta">Últimos 90 dias</div>
    </div>
    <div class="sla-grid">
      {slaMetrics.map((m) => (
        <div class="sla-card">
          <div class={`sla-value ${m.teal ? 'teal' : ''}`}>{m.value}</div>
          <div class="sla-label">{m.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- MAINTENANCE -->
  {maintenance.length > 0 && (
    <div class="status-section" style="margin-top:40px">
      <div class="section-header">
        <div class="section-title">Manutenção Programada</div>
      </div>
      {maintenance.map((m) => (
        <div class="maintenance-card">
          <div class="maintenance-icon">&#128295;</div>
          <div class="maintenance-info">
            <div class="maintenance-title">{m.title}</div>
            <div class="maintenance-meta">{m.meta}</div>
          </div>
          <div class="maintenance-badge">{m.badge}</div>
        </div>
      ))}
    </div>
  )}

  <!-- INCIDENT HISTORY -->
  <div class="status-section" style="margin-top:40px; padding-bottom: 80px;">
    <div class="section-header">
      <div class="section-title">Histórico de Incidentes</div>
      <div class="section-meta">Últimos 30 dias — apenas resolvidos</div>
    </div>
    <div class="incidents-wrap">
      {incidents.map((inc) => (
        <div class="incident-card" data-toggle-incident>
          <div class="incident-header">
            <div class={`incident-dot ${inc.resolved ? 'green' : ''}`}></div>
            <div class="incident-info">
              <div class="incident-title">{inc.title}</div>
              <div class="incident-meta">{inc.meta}</div>
            </div>
            <div class="incident-tag">{inc.resolved ? '✓ Resolvido' : 'Em andamento'}</div>
            <div class="service-expand-icon">&#9662;</div>
          </div>
          <div class="incident-body">
            <div class="timeline">
              {inc.timeline.map((step) => (
                <div class="timeline-item">
                  <div class="timeline-time">{step.time}</div>
                  <div class="timeline-content">
                    <div class={`timeline-status ${step.status}`}>{step.label}</div>
                    <div class="timeline-text">{step.text}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

</div>

<!-- SUBSCRIBE MODAL -->
<div class="modal-overlay" id="modal">
  <div class="status-modal">
    <button class="modal-close" id="modal-close-btn">&times;</button>
    <div class="modal-title">Receber alertas</div>
    <div class="modal-sub">Seja notificado por e-mail quando houver incidentes ou mudanças de status na plataforma yapt.</div>
    <input class="modal-input" type="email" placeholder="seu@email.com" id="sub-email">
    <input class="modal-input" type="text" placeholder="Nome (opcional)">
    <button class="modal-btn" id="modal-submit-btn">Ativar notificações</button>
  </div>
</div>

</SiteLayout>

<style>
  /* ─── STATUS PAGE DARK THEME ─── */
  .status-page {
    background: #0a0a0a;
    color: #ffffff;
    font-family: 'Inter', 'Poppins', sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .status-page h1, .status-page h2, .status-page h3, .status-page .font-poppins { font-family: 'Poppins', sans-serif; }

  /* ─── HERO ─── */
  .status-hero {
    background: #0a0a0a;
    padding: 120px 40px 60px;
  }

  .status-hero-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    font-family: 'Poppins', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #20B2AA;
    margin-bottom: 20px;
  }

  .hero-status-banner {
    background: #181818;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 20px;
    padding: 36px 44px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 48px;
    position: relative;
    overflow: hidden;
  }

  .hero-status-banner::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, #22c55e, rgba(34,197,94,0));
  }
  .hero-status-banner.degraded::before { background: linear-gradient(90deg, #f59e0b, rgba(245,158,11,0)); }
  .hero-status-banner.outage::before { background: linear-gradient(90deg, #ef4444, rgba(239,68,68,0)); }

  .banner-left { flex: 1; }

  .banner-indicator {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  .pulse-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #22c55e;
    position: relative;
    flex-shrink: 0;
  }
  .pulse-dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.25);
    animation: status-pulse 2s ease-in-out infinite;
  }
  .pulse-dot.yellow { background: #f59e0b; }
  .pulse-dot.yellow::after { background: rgba(245, 158, 11, 0.25); }
  .pulse-dot.red { background: #ef4444; }
  .pulse-dot.red::after { background: rgba(239, 68, 68, 0.25); }

  @keyframes status-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.8); opacity: 0; }
  }

  .banner-title {
    font-family: 'Poppins', sans-serif;
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.5px;
    color: #ffffff;
  }

  .banner-subtitle {
    font-size: 13px;
    color: #666;
    margin-top: 4px;
  }

  .banner-right {
    display: flex;
    gap: 32px;
  }

  .banner-stat { text-align: center; }

  .banner-stat-value {
    font-family: 'Poppins', sans-serif;
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -1px;
    color: #ffffff;
  }

  .banner-stat-value.green { color: #22c55e; }

  .banner-stat-label {
    font-size: 11px;
    color: #555;
    font-weight: 400;
    margin-top: 2px;
    letter-spacing: 0.5px;
  }

  .banner-divider {
    width: 1px;
    background: rgba(255,255,255,0.07);
    height: 48px;
    align-self: center;
  }

  /* ─── UPTIME BAR ─── */
  .uptime-strip {
    background: #181818;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    padding: 24px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 48px;
  }

  .uptime-label {
    font-size: 12px;
    color: #555;
    font-weight: 500;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .uptime-bars {
    display: flex;
    gap: 3px;
    flex: 1;
  }

  .uptime-bar {
    flex: 1;
    height: 28px;
    border-radius: 3px;
    background: rgba(34, 197, 94, 0.7);
    cursor: pointer;
    transition: all 0.15s;
  }
  .uptime-bar:hover { transform: scaleY(1.15); background: #22c55e; }
  .uptime-bar.degraded { background: rgba(245, 158, 11, 0.7); }
  .uptime-bar.degraded:hover { background: #f59e0b; }
  .uptime-bar.maintenance { background: rgba(59, 130, 246, 0.5); }

  .uptime-pct {
    font-family: 'Poppins', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #22c55e;
    letter-spacing: -0.5px;
    white-space: nowrap;
  }

  .uptime-period {
    font-size: 11px;
    color: #444;
    white-space: nowrap;
  }

  /* ─── SECTION ─── */
  .status-section {
    max-width: 1100px;
    margin: 0 auto 40px;
    padding: 0 40px;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .section-title {
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #444;
  }

  .section-meta {
    font-size: 11px;
    color: #444;
  }

  /* ─── LEGEND ─── */
  .legend {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: #555;
  }

  .legend-dot {
