---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { t, type Locale } from '../../lib/i18n';

const locale = 'pt-BR' as const;
const m = (key: string) => t(`partners.${key}`, locale);
const hero = m('hero') as any;
const problem = m('problem') as any;
const turn = m('turn') as any;
const trust = m('trust') as any;
const profiles = m('profiles') as any;
const cta = m('cta') as any;
---

<SiteLayout
  title="Programa de Parceiros"
  description="Seja parceiro yapt. e ganhe comissão recorrente. Programa para agências, consultorias e profissionais de tecnologia."
  path="/partners"
  locale={locale}
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-28 pb-16 lg:pt-36 lg:pb-24" style="background: linear-gradient(135deg, #0A3D2E, #064E3B, #0D9488);">
    <div class="absolute inset-0 pointer-events-none" style="opacity: 0.06;">
      <div class="absolute" style="top: -20%; left: -10%; width: 60%; height: 140%; background: linear-gradient(135deg, rgba(255,255,255,0.8) 0%, transparent 40%); transform: rotate(-15deg);"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <div data-fade style="opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;">
        <span class="inline-block rounded-full px-4 py-1.5 text-xs font-medium text-white/90 mb-4" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(8px);">
          {hero.partnersBadge}
        </span>
        <p class="text-sm text-teal-200/80 mb-6">{hero.byNewWay}</p>
      </div>
      <div data-fade style="opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;">
        <h1 class="font-poppins text-3xl lg:text-4xl xl:text-5xl font-bold text-white leading-tight">
          {hero.title} <span class="text-teal-300">{hero.titleHighlight}</span>
        </h1>
        <p class="font-poppins text-lg text-teal-200/70 mt-2">{hero.tagline}</p>
      </div>
      <div data-fade style="opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;">
        <p class="text-base text-white/70 mt-6 max-w-2xl mx-auto leading-relaxed">{hero.subtitle}</p>
      </div>
      <div data-fade style="opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;">
        <a href="/partners/discover" class="inline-block bg-white text-[#064E3B] font-poppins font-semibold px-8 py-4 rounded-xl text-lg hover:shadow-2xl transition-all duration-300 mt-8">
          {hero.cta}
        </a>
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section data-observe class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="inline-block text-xs font-semibold uppercase tracking-wider mb-3 text-amber-500">{problem.label}</span>
        <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-[#1a1a2e]">{problem.title}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[1,2,3,4,5].map((n) => {
          const quote = problem[`card${n}Quote`];
          const text = problem[`card${n}Text`];
          if (!quote) return null;
          return (
            <div
              data-fade
              style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;"
              class="bg-white rounded-2xl p-6 border border-gray-100 hover:shadow-lg transition-shadow"
            >
              <p class="text-sm font-medium text-amber-600 mb-3">"{quote}"</p>
              <p class="text-sm text-[#656D78] leading-relaxed" set:html={text} />
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Turn -->
  <section data-observe class="py-16 lg:py-24 bg-[#FAFBFC]">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div data-fade style="opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;">
        <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-[#1a1a2e] leading-tight">{turn.title}</h2>
        <p class="text-base text-[#656D78] mt-6 leading-relaxed" set:html={turn.text1} />
        <p class="text-base text-[#656D78] mt-4 leading-relaxed" set:html={turn.text2} />
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mt-12">
        {[1,2,3].map((n) => {
          const title = turn[`card${n}Title`];
          const text = turn[`card${n}Text`];
          if (!title) return null;
          return (
            <div
              data-fade
              style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;"
              class="bg-white rounded-2xl p-6"
            >
              <h3 class="font-poppins text-base font-semibold text-[#1a1a2e] mb-2">{title}</h3>
              <p class="text-sm text-[#656D78] leading-relaxed" set:html={text} />
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Trust / Numbers -->
  <section data-observe class="py-16 lg:py-24" style="background: linear-gradient(135deg, #1a1a2e, #0A3D2E);">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="inline-block text-xs font-semibold uppercase tracking-wider mb-3 text-teal-300">{trust.label}</span>
        <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-white">{trust.title}</h2>
        <p class="text-base text-white/60 mt-3">{trust.subtitle}</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {[1,2,3,4].map((n) => {
          const stat = trust[`stat${n}`];
          const label = trust[`stat${n}Label`];
          if (!stat) return null;
          return (
            <div
              data-fade
              style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;"
              class="text-center"
            >
              <div class="font-poppins text-3xl lg:text-4xl font-bold bg-gradient-to-r from-teal-300 to-cyan-300 bg-clip-text text-transparent">{stat}</div>
              <p class="text-sm text-white/50 mt-2">{label}</p>
            </div>
          );
        })}
      </div>
      {trust.footnote && <p class="text-xs text-white/30 text-center mt-8">{trust.footnote}</p>}
    </div>
  </section>

  <!-- Profiles -->
  <section data-observe class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="inline-block text-xs font-semibold uppercase tracking-wider mb-3 text-teal-500">{profiles.label}</span>
        <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-[#1a1a2e]">{profiles.title}</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {['agency','consulting','tech','independent'].map((key) => {
          const title = profiles[key];
          const desc = profiles[`${key}Desc`];
          if (!title) return null;
          return (
            <div
              data-fade
              style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;"
              class="bg-white rounded-2xl p-6 border border-gray-100 hover:border-teal-200 transition-colors"
            >
              <h3 class="font-poppins text-base font-semibold text-[#1a1a2e] mb-2">{title}</h3>
              <p class="text-sm text-[#656D78] leading-relaxed">{desc}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section data-observe class="py-16 lg:py-24" style="background: linear-gradient(135deg, #064E3B, #0D9488, #20B2AA);">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div data-fade style="opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;">
        <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-white">{cta.title}</h2>
        {cta.subtitle && <p class="text-base text-white/70 mt-4">{cta.subtitle}</p>}
        <a href="/partners/discover" class="inline-block bg-white text-[#064E3B] font-poppins font-semibold px-8 py-4 rounded-xl text-lg hover:shadow-2xl transition-all duration-300 mt-8">
          {cta.button || hero.cta}
        </a>
      </div>
    </div>
  </section>
</SiteLayout>
