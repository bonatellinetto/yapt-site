---
import SiteLayout from '../layouts/SiteLayout.astro';
import PageHero from '../components/PageHero.astro';
import ModuleDeepDive from '../components/ModuleDeepDive.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import SectionDivider from '../components/SectionDivider.astro';
import CTASection from '../components/CTASection.astro';
import MockupCampaignsTable from '../components/mockups/MockupCampaignsTable.astro';
import MockupInstantEngage from '../components/mockups/MockupInstantEngage.astro';
import MockupYaCampaigns from '../components/mockups/MockupYaCampaigns.astro';
import MockupProposalAccept from '../components/mockups/MockupProposalAccept.astro';
import MockupCAPI from '../components/mockups/MockupCAPI.astro';
import MockupTemplateBuilder from '../components/mockups/MockupTemplateBuilder.astro';
import { t, type Locale } from '../lib/i18n';
import { eagleSvg, genericIcons } from '../lib/fauna';

const locale = 'pt-BR' as const;
const m = (key: string) => t(`marketing.${key}`, locale);
const meta = m('meta') as { title: string; description: string };
const hero = m('hero') as { badge: string; title: string; subtitle: string };

const gridData = m('grid') as Record<string, any>;
const gridKeys = Object.keys(gridData).filter(k => k !== 'title' && k !== 'subtitle');
const gridFeatures = gridKeys.map(k => ({
  icon: genericIcons[k as keyof typeof genericIcons] || genericIcons.megaphone,
  title: gridData[k].title,
  description: gridData[k].description,
}));

const modules = ['campaigns','instantEngage','tracking','googleAds','templates','proposals','capi'] as const;

// Pain points
const painPoints = m('painPoints') as any;
const painPointKeys = painPoints ? Object.keys(painPoints).filter(k => k !== 'title' && k !== 'subtitle') : [];

// Statement / WOW
const statement = m('statement') as any;

// Timeline
const timeline = m('timeline') as any;
const timelineSteps = timeline?.steps || [];
---

<SiteLayout title={meta.title} description={meta.description} path="/marketing-site" locale={locale}>
  <PageHero
    gradient="linear-gradient(135deg, #92400E, #F59E0B, #FBBF24)"
    title={hero.title}
    subtitle={hero.subtitle}
    badge={hero.badge}
    fauna={eagleSvg}
  />

  {/* Statement WOW — WhatsApp branded */}
  {statement && (statement.title || statement.headline) && (
    <section data-observe class="py-20 lg:py-28 relative overflow-hidden" style="background: linear-gradient(135deg, #075E54 0%, #128C7E 40%, #25D366 100%);">
      {/* Decorative circles */}
      <div class="absolute top-0 left-0 w-full h-full pointer-events-none" style="opacity: 0.06;">
        <div style="position:absolute;top:-80px;right:-80px;width:300px;height:300px;border-radius:50%;border:2px solid white;"></div>
        <div style="position:absolute;bottom:-60px;left:-60px;width:250px;height:250px;border-radius:50%;border:2px solid white;"></div>
        <div style="position:absolute;top:40%;left:10%;width:120px;height:120px;border-radius:50%;border:1px solid white;"></div>
      </div>

      <div class="max-w-5xl mx-auto px-6 relative" style="z-index: 2;">
        {/* WhatsApp icon */}
        <div class="flex justify-center mb-8">
          <div style="width: 64px; height: 64px; border-radius: 16px; background: rgba(255,255,255,0.15); backdrop-filter: blur(10px); display: flex; align-items: center; justify-content: center; border: 1px solid rgba(255,255,255,0.2);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
        </div>

        <div data-fade style="opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;" class="text-center">
          <h2 class="font-poppins text-2xl lg:text-4xl font-bold text-white leading-tight max-w-3xl mx-auto">{statement.headline || statement.title}</h2>
          {(statement.subtext || statement.subtitle) && <p class="text-base lg:text-lg text-white/70 mt-6 max-w-2xl mx-auto leading-relaxed">{statement.subtext || statement.subtitle}</p>}

          {/* Platform logos */}
          <div class="flex flex-wrap justify-center items-center gap-6 mt-10">
            {/* Meta Ads */}
            <div style="background: rgba(255,255,255,0.12); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.2); border-radius: 12px; padding: 10px 20px; display: flex; align-items: center; gap: 8px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M12 2.04c-5.5 0-10 4.49-10 10.02 0 5 3.66 9.15 8.44 9.9v-7H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.93 3.78-3.93 1.09 0 2.23.2 2.23.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.9h-2.33v7a10 10 0 008.44-9.9c0-5.53-4.5-10.02-10-10.02z"/></svg>
              <div>
                <div style="font-size: 11px; font-weight: 700; color: white;">Meta Ads</div>
                <div style="font-size: 8px; color: rgba(255,255,255,0.6);">Integração Nativa</div>
              </div>
            </div>

            {/* Google Ads */}
            <div style="background: rgba(255,255,255,0.12); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.2); border-radius: 12px; padding: 10px 20px; display: flex; align-items: center; gap: 8px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 001 12c0 1.77.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              <div>
                <div style="font-size: 11px; font-weight: 700; color: white;">Google Ads</div>
                <div style="font-size: 8px; color: rgba(255,255,255,0.6);">Integração Nativa</div>
              </div>
            </div>

            {/* iLeadway */}
            <div style="background: rgba(255,255,255,0.12); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.2); border-radius: 12px; padding: 10px 20px; display: flex; align-items: center; gap: 8px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              <div>
                <div style="font-size: 11px; font-weight: 700; color: white;">iLeadway</div>
                <div style="font-size: 8px; color: rgba(255,255,255,0.6);">Landing Pages</div>
              </div>
            </div>
          </div>

          {/* Connection lines visual */}
          <div class="flex justify-center items-center gap-3 mt-8">
            <div style="width: 40px; height: 1px; background: rgba(255,255,255,0.3);"></div>
            <div style="font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.5);">→</div>
            <div style="background: rgba(255,255,255,0.2); border-radius: 8px; padding: 6px 16px; display: flex; align-items: center; gap: 6px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              <span style="font-size: 11px; font-weight: 700; color: white;">Rastreio 100% no WhatsApp</span>
            </div>
            <div style="font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.5);">→</div>
            <div style="width: 40px; height: 1px; background: rgba(255,255,255,0.3);"></div>
          </div>

          {/* Stats */}
          <div class="flex flex-wrap justify-center gap-8 mt-10">
            <div class="text-center">
              <div style="font-size: 24px; font-weight: 800; color: white;">100%</div>
              <div style="font-size: 10px; color: rgba(255,255,255,0.6);">Atribuição real</div>
            </div>
            <div style="width: 1px; height: 40px; background: rgba(255,255,255,0.15);"></div>
            <div class="text-center">
              <div style="font-size: 24px; font-weight: 800; color: white;">&lt;30s</div>
              <div style="font-size: 10px; color: rgba(255,255,255,0.6);">Instant Engage</div>
            </div>
            <div style="width: 1px; height: 40px; background: rgba(255,255,255,0.15);"></div>
            <div class="text-center">
              <div style="font-size: 24px; font-weight: 800; color: white;">ROAS</div>
              <div style="font-size: 10px; color: rgba(255,255,255,0.6);">Real, não estimativa</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* Pain Points */}
  {painPoints && (painPoints.items || painPointKeys.length > 0) && (
    <section data-observe class="py-16 lg:py-24 bg-[#FAFBFC]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-12">
          {(painPoints.header || painPoints.title) && <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-[#1a1a2e]">{painPoints.header || painPoints.title}</h2>}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {(Array.isArray(painPoints.items) ? painPoints.items : painPoints.items ? Object.values(painPoints.items) : painPointKeys.map(k => painPoints[k])).map((pp: any) => (
            <div
              data-fade
              style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;"
              class="bg-white rounded-2xl p-6 border border-amber-100"
            >
              <h3 class="font-poppins text-base font-semibold text-[#1a1a2e] mb-2">{pp.title}</h3>
              <p class="text-sm text-[#656D78] leading-relaxed">{pp.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <div class="[&>section]:py-12 [&>section]:lg:py-16">
    {modules.map((key, i) => {
      const mod = m(key) as { subtitle: string; title: string; description: string; features: string[] };
      if (!mod || !mod.title) return null;
      return (
        <>
          <ModuleDeepDive
            title={mod.title}
            subtitle={mod.subtitle}
            description={mod.description}
            features={mod.features || []}
            reversed={i % 2 === 1}
            accentColor="#F59E0B"
          >
            {key === 'campaigns' && <MockupCampaignsTable />}
            {key === 'instantEngage' && <MockupInstantEngage />}
            {key === 'tracking' && <MockupYaCampaigns />}
            {key === 'googleAds' && <MockupYaCampaigns />}
            {key === 'templates' && <MockupTemplateBuilder />}
            {key === 'proposals' && <MockupProposalAccept />}
            {key === 'capi' && <MockupCAPI />}
          </ModuleDeepDive>
          {i < modules.length - 1 && <SectionDivider variant="light" />}
        </>
      );
    })}
  </div>

  {/* Timeline */}
  {timelineSteps.length > 0 && (
    <section data-observe class="py-16 lg:py-24" style="background: linear-gradient(135deg, #1a1a2e, #92400E);">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-12">
          {timeline.title && <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-white">{timeline.title}</h2>}
        </div>
        <div class="relative">
          <div class="absolute left-6 top-0 bottom-0 w-px bg-amber-400/20"></div>
          {timelineSteps.map((step: any, i: number) => {
            const isString = typeof step === 'string';
            return (
              <div
                data-fade
                style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;"
                class="relative pl-16 pb-10 last:pb-0"
              >
                <div class="absolute left-4 w-5 h-5 rounded-full border-2 border-amber-400 bg-[#1a1a2e] flex items-center justify-center">
                  <span class="text-[10px] text-amber-300 font-bold">{i + 1}</span>
                </div>
                <h3 class="font-poppins text-base font-semibold text-white">{isString ? step : step.title}</h3>
                {!isString && step.description && <p class="text-sm text-white/50 mt-1 leading-relaxed">{step.description}</p>}
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <FeatureGrid
    title={gridData.title}
    features={gridFeatures}
    columns={3}
    accentColor="#F59E0B"
  />

  <CTASection locale={locale} />
</SiteLayout>
