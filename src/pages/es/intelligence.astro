---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ModuleDeepDive from '../../components/ModuleDeepDive.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import CTASection from '../../components/CTASection.astro';
import { t, type Locale } from '../../lib/i18n';
import { owlSvg, genericIcons } from '../../lib/fauna';

const locale = 'es-ES' as const;
const m = (key: string) => t(`intelligence.${key}`, locale);
const meta = m('meta') as { title: string; description: string };
const hero = m('hero') as { badge: string; title: string; subtitle: string };

const gridData = m('grid') as Record<string, any>;
const gridKeys = Object.keys(gridData).filter(k => k !== 'title' && k !== 'subtitle');
const gridFeatures = gridKeys.map(k => ({
  icon: genericIcons[k as keyof typeof genericIcons] || genericIcons.ai,
  title: gridData[k].title,
  description: gridData[k].description,
}));

const modules = ['ai','team','memory','mentor','scoring','emotion','audio'] as const;
---

<SiteLayout title={meta.title} description={meta.description} path="/es/intelligence" locale={locale}>
  <PageHero
    gradient="linear-gradient(135deg, #5B21B6, #8B5CF6, #A78BFA)"
    title={hero.title}
    subtitle={hero.subtitle}
    badge={hero.badge}
    fauna={owlSvg}
  />

  <div class="[&>section]:py-12 [&>section]:lg:py-16">
    {modules.map((key, i) => {
      const mod = m(key) as { subtitle: string; title: string; description: string; features: string[] };
      if (!mod || !mod.title) return null;
      return (
        <>
          <ModuleDeepDive
            title={mod.title}
            subtitle={mod.subtitle}
            description={mod.description}
            features={mod.features || []}
            reversed={i % 2 === 1}
            accentColor="#8B5CF6"
          />
          {i < modules.length - 1 && <SectionDivider variant="light" />}
        </>
      );
    })}
  </div>

  {/* AI Team Section */}
  {(() => {
    const aiTeam = m('aiTeam') as any;
    if (!aiTeam?.agents) return null;
    return (
      <section data-observe class="py-16 lg:py-24" style="background: linear-gradient(135deg, #1a1a2e, #2d1b69);">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-12">
            <span class="inline-block text-xs font-semibold tracking-wider mb-3 text-purple-300">{aiTeam.sectionLabel}</span>
            <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-white">{aiTeam.title}</h2>
            <p class="text-base text-white/60 mt-4 max-w-2xl mx-auto">{aiTeam.subtitle}</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {(Array.isArray(aiTeam.agents) ? aiTeam.agents : Object.values(aiTeam.agents)).map((agent: any) => (
              <div
                data-fade
                style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;"
                class="bg-white/5 backdrop-blur-sm rounded-2xl p-5 border border-white/10 hover:border-purple-400/30 transition-colors"
              >
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(139,92,246,0.2);">
                    <div class="w-3 h-3 rounded-full" style={`background: ${agent.active !== false ? '#8B5CF6' : '#475569'};`} />
                  </div>
                  <div>
                    <h3 class="font-poppins text-sm font-semibold text-white">{agent.name}</h3>
                    <span class="text-xs text-white/40">{agent.type}</span>
                  </div>
                </div>
                <p class="text-xs text-white/50 leading-relaxed">{agent.description}</p>
                {agent.active === false && (
                  <span class="inline-block mt-2 text-[10px] text-purple-300/60 uppercase tracking-wider">{aiTeam.comingSoon}</span>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  })()}

  <FeatureGrid
    title={gridData.title}
    features={gridFeatures}
    columns={3}
    accentColor="#8B5CF6"
  />

  <CTASection locale={locale} />
</SiteLayout>
