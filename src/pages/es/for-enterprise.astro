---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ModuleDeepDive from '../../components/ModuleDeepDive.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import CTASection from '../../components/CTASection.astro';
import MockupMultiTenant from '../../components/mockups/MockupMultiTenant.astro';
import MockupPermissions from '../../components/mockups/MockupPermissions.astro';
import MockupSLA from '../../components/mockups/MockupSLA.astro';
import MockupYaTrust from '../../components/mockups/MockupYaTrust.astro';
import { t, type Locale } from '../../lib/i18n';
import { elephantSvg } from '../../lib/fauna';

const locale = 'es-ES' as const;
const m = (key: string) => t(`enterprise.${key}`, locale);
const meta = m('meta') as { title: string; description: string };
const hero = m('hero') as { badge: string; title: string; subtitle: string };

const modules = ['multiTenant','permissions','sla','security'] as const;

// Trust badges
const trust = m('trust') as any;
const trustBadges = trust?.badges || [];
---

<SiteLayout title={meta.title} description={meta.description} path="/es/for-enterprise" locale={locale}>
  <PageHero
    gradient="linear-gradient(135deg, #1e293b, #475569, #64748b)"
    title={hero.title}
    subtitle={hero.subtitle}
    badge={hero.badge}
    fauna={elephantSvg}
  />

  <div class="[&>section]:py-12 [&>section]:lg:py-16">
    {modules.map((key, i) => {
      const mod = m(key) as { subtitle: string; title: string; description: string; features: string[] };
      if (!mod || !mod.title) return null;
      return (
        <>
          <ModuleDeepDive
            title={mod.title}
            subtitle={mod.subtitle}
            description={mod.description}
            features={mod.features || []}
            reversed={i % 2 === 1}
            accentColor="#475569"
          >
            {key === 'multiTenant' && <MockupMultiTenant />}
            {key === 'permissions' && <MockupPermissions />}
            {key === 'sla' && <MockupSLA />}
            {key === 'security' && <MockupYaTrust />}
          </ModuleDeepDive>
          {i < modules.length - 1 && <SectionDivider variant="light" />}
        </>
      );
    })}
  </div>

  {/* Trust Badges */}
  {trustBadges.length > 0 && (
    <section data-observe class="py-16 lg:py-24 bg-[#FAFBFC]">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex flex-wrap justify-center gap-4">
          {trustBadges.map((badge: string) => (
            <div
              data-fade
              style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;"
              class="bg-white rounded-2xl px-6 py-4 shadow-sm text-center"
            >
              <span class="text-sm text-[#434A54] font-medium">{badge}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTASection locale={locale} />
</SiteLayout>
