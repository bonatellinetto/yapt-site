---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import BlogSidebar from '../../../components/blog/BlogSidebar.astro';
import CTASection from '../../../components/CTASection.astro';
import { getAllPublishedPosts, getPostBySlug, getAllCategories, getRelatedPosts } from '../../../lib/blog';

const locale = 'es-ES' as const;

export async function getStaticPaths() {
  const posts = await getAllPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug!);

if (!post) {
  return Astro.redirect('/es/blog');
}

const categories = await getAllCategories();
const relatedPosts = await getRelatedPosts(post.id, post.category_id);

const date = post.published_at
  ? new Date(post.published_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' })
  : '';

const blogPostingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.seo_title || post.title,
  description: post.seo_description || post.excerpt || '',
  image: post.og_image_url || post.cover_image_url || 'https://yapt.ai/og-image.png',
  author: { '@type': 'Person', name: post.author_name },
  publisher: {
    '@type': 'Organization',
    name: 'yapt.',
    logo: { '@type': 'ImageObject', url: 'https://yapt.ai/yapt-logo.svg' },
  },
  datePublished: post.published_at,
  dateModified: post.updated_at,
  url: `https://yapt.ai/es/blog/${post.slug}`,
  mainEntityOfPage: `https://yapt.ai/es/blog/${post.slug}`,
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://yapt.ai/es' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://yapt.ai/es/blog' },
    { '@type': 'ListItem', position: 3, name: post.title, item: `https://yapt.ai/es/blog/${post.slug}` },
  ],
};
---

<BlogLayout
  title={post.seo_title || post.title}
  description={post.seo_description || post.excerpt || ''}
  path={`/blog/${post.slug}`}
  locale={locale}
  ogImage={post.og_image_url || post.cover_image_url || undefined}
  jsonLd={[blogPostingJsonLd, breadcrumbJsonLd]}
>
  <div class="pt-28 pb-16 lg:pt-36 lg:pb-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col lg:flex-row gap-12">
        <article class="flex-1 max-w-3xl">
          <nav class="flex items-center gap-2 text-sm text-[#AAB2BD] mb-6">
            <a href="/es" class="hover:text-teal-600">Inicio</a>
            <span>/</span>
            <a href="/es/blog" class="hover:text-teal-600">Blog</a>
            {post.category && (
              <>
                <span>/</span>
                <span style={`color: ${post.category.color};`}>{post.category.name_es || post.category.name}</span>
              </>
            )}
          </nav>

          <header class="mb-8">
            {post.category && (
              <span
                class="inline-block text-xs font-medium rounded-full px-3 py-1 mb-4"
                style={`background: ${post.category.color}15; color: ${post.category.color};`}
              >
                {post.category.name_es || post.category.name}
              </span>
            )}
            <h1 class="font-poppins text-2xl lg:text-3xl xl:text-4xl font-bold text-[#1a1a2e] leading-tight">
              {post.title}
            </h1>
            {post.subtitle && (
              <p class="text-lg text-[#656D78] mt-3">{post.subtitle}</p>
            )}
            <div class="flex items-center gap-4 mt-6 text-sm text-[#AAB2BD]">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-teal-100 flex items-center justify-center">
                  <span class="text-xs font-semibold text-teal-700">{post.author_name.charAt(0)}</span>
                </div>
                <div>
                  <span class="text-[#434A54] font-medium">{post.author_name}</span>
                  {post.author_role && <span class="text-[#AAB2BD] ml-1">· {post.author_role}</span>}
                </div>
              </div>
              <span>&middot;</span>
              <span>{date}</span>
              {post.reading_time_minutes > 0 && (
                <>
                  <span>&middot;</span>
                  <span>{post.reading_time_minutes} min de lectura</span>
                </>
              )}
            </div>
          </header>

          {post.cover_image_url && (
            <div class="aspect-[16/9] rounded-2xl overflow-hidden mb-8">
              <img src={post.cover_image_url} alt={post.title} class="w-full h-full object-cover" />
            </div>
          )}

          <div
            class="prose prose-sm lg:prose-base max-w-none text-[#434A54]
              [&_h2]:font-poppins [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-[#1a1a2e] [&_h2]:mt-10 [&_h2]:mb-4
              [&_h3]:font-poppins [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-[#1a1a2e] [&_h3]:mt-6 [&_h3]:mb-3
              [&_p]:leading-relaxed [&_p]:mb-4
              [&_a]:text-teal-600 [&_a:hover]:text-teal-700
              [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-2
              [&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:space-y-2
              [&_blockquote]:border-l-4 [&_blockquote]:border-teal-300 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-[#656D78]
              [&_img]:rounded-xl [&_img]:my-6
              [&_pre]:bg-[#1a1a2e] [&_pre]:text-white [&_pre]:rounded-xl [&_pre]:p-4 [&_pre]:overflow-x-auto
              [&_code]:bg-gray-100 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm
              [&_.callout]:bg-teal-50 [&_.callout]:border-l-4 [&_.callout]:border-teal-400 [&_.callout]:p-4 [&_.callout]:rounded-r-xl [&_.callout]:my-6
              [&_.warning]:bg-amber-50 [&_.warning]:border-l-4 [&_.warning]:border-amber-400 [&_.warning]:p-4 [&_.warning]:rounded-r-xl [&_.warning]:my-6
              [&_.stat-box]:bg-white [&_.stat-box]:rounded-2xl [&_.stat-box]:p-6 [&_.stat-box]:shadow-sm [&_.stat-box]:my-6
              [&_table]:w-full [&_th]:bg-gray-50 [&_th]:text-left [&_th]:p-3 [&_td]:p-3 [&_td]:border-b [&_td]:border-gray-100"
            set:html={post.content_html || ''}
          />

          {post.tags && post.tags.length > 0 && (
            <div class="mt-10 pt-6 border-t border-gray-100">
              <div class="flex flex-wrap gap-2">
                {post.tags.map((tag) => (
                  <span class="bg-gray-100 text-[#656D78] rounded-full px-3 py-1 text-xs">{tag}</span>
                ))}
              </div>
            </div>
          )}

          <div class="mt-10 bg-white rounded-2xl p-6 flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-teal-100 flex items-center justify-center flex-shrink-0">
              <span class="text-lg font-semibold text-teal-700">{post.author_name.charAt(0)}</span>
            </div>
            <div>
              <span class="font-poppins font-semibold text-[#1a1a2e]">{post.author_name}</span>
              {post.author_role && <p class="text-sm text-[#656D78]">{post.author_role}</p>}
            </div>
          </div>
        </article>

        <div class="lg:w-72 flex-shrink-0">
          <div class="lg:sticky lg:top-24">
            <BlogSidebar
              categories={categories}
              relatedPosts={relatedPosts}
              currentCategory={post.category?.slug}
              tags={post.tags}
              locale={locale}
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <CTASection locale={locale} />
</BlogLayout>
