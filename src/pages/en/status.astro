    ],
  },
];

const globalDegradedDays = [8, 22, 41, 65, 79];
const globalMaintenanceDays = [14, 55];

function statusBadgeClass(status: string) {
  const map: Record<string, string> = {
    operational: 'badge-operational',
    degraded: 'badge-degraded',
    outage: 'badge-outage',
    maintenance: 'badge-maintenance',
  };
  return map[status] || 'badge-operational';
}

function statusLabel(status: string) {
  const map: Record<string, string> = {
    operational: 'Operational',
    degraded: 'Degraded',
    outage: 'Outage',
    maintenance: 'Maintenance',
  };
  return map[status] || status;
}

function overallLabel(status: string) {
  const map: Record<string, string> = {
    operational: 'All Systems Operational',
    degraded: 'Partial System Degradation',
    outage: 'Major System Outage',
  };
  return map[status] || status;
}

function pulseDotClass(status: string) {
  if (status === 'degraded') return 'pulse-dot yellow';
  if (status === 'outage') return 'pulse-dot red';
  return 'pulse-dot';
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{meta.title}</title>
  <meta name="description" content={meta.description}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="canonical" href="https://yapt.ai/en/status">
  <link rel="alternate" hreflang="en" href="https://yapt.ai/en/status">
  <link rel="alternate" hreflang="pt-BR" href="https://yapt.ai/status">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --teal: #20B2AA;
      --teal-light: #2DD4BF;
      --teal-dark: #1A9690;
      --slate: #434A54;
      --dark: #0a0a0a;
      --dark-2: #111111;
      --dark-3: #181818;
      --dark-4: #222222;
      --white: #ffffff;
      --green: #22c55e;
      --green-dim: rgba(34, 197, 94, 0.12);
      --yellow: #f59e0b;
      --yellow-dim: rgba(245, 158, 11, 0.12);
      --red: #ef4444;
      --red-dim: rgba(239, 68, 68, 0.12);
      --blue: #3b82f6;
    }

    body {
      font-family: 'Inter', 'Poppins', sans-serif;
      background: var(--dark);
      color: var(--white);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, .font-poppins { font-family: 'Poppins', sans-serif; }

    .topbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: rgba(10, 10, 10, 0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 40px;
      height: 64px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 14px;
      text-decoration: none;
    }

    .logo-icon { width: 32px; height: 32px; }

    .logo-text {
      font-family: 'Poppins', sans-serif;
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -0.5px;
      color: var(--white);
    }

    .logo-text .dot { font-weight: 300; color: var(--teal); }

    .topbar-center {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      color: #666;
      font-weight: 400;
      letter-spacing: 0.5px;
    }

    .topbar-center .sep { color: #333; }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 24px;
    }

    .subscribe-btn {
      font-family: 'Poppins', sans-serif;
      font-size: 12px;
      font-weight: 500;
      color: var(--teal);
      background: rgba(32, 178, 170, 0.1);
      border: 1px solid rgba(32, 178, 170, 0.2);
      border-radius: 8px;
      padding: 7px 16px;
      cursor: pointer;
      transition: all 0.15s;
      letter-spacing: 0.3px;
    }
    .subscribe-btn:hover {
      background: rgba(32, 178, 170, 0.18);
      border-color: rgba(32, 178, 170, 0.4);
    }

    .hero {
      padding: 120px 40px 60px;
      max-width: 1100px;
      margin: 0 auto;
    }

    .hero-eyebrow {
      font-family: 'Poppins', sans-serif;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 20px;
    }

    .hero-status-banner {
      background: var(--dark-3);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 20px;
      padding: 36px 44px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
      margin-bottom: 48px;
      position: relative;
      overflow: hidden;
    }

    .hero-status-banner::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--green), rgba(34,197,94,0));
    }
    .hero-status-banner.degraded::before { background: linear-gradient(90deg, var(--yellow), rgba(245,158,11,0)); }
    .hero-status-banner.outage::before { background: linear-gradient(90deg, var(--red), rgba(239,68,68,0)); }

    .banner-left { flex: 1; }

    .banner-indicator {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
    }

    .pulse-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--green);
      position: relative;
      flex-shrink: 0;
    }
    .pulse-dot::after {
      content: '';
      position: absolute;
      inset: -4px;
      border-radius: 50%;
      background: rgba(34, 197, 94, 0.25);
      animation: pulse 2s ease-in-out infinite;
    }
    .pulse-dot.yellow { background: var(--yellow); }
    .pulse-dot.yellow::after { background: rgba(245, 158, 11, 0.25); }
    .pulse-dot.red { background: var(--red); }
    .pulse-dot.red::after { background: rgba(239, 68, 68, 0.25); }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.8); opacity: 0; }
    }

    .banner-title {
      font-family: 'Poppins', sans-serif;
      font-size: 26px;
      font-weight: 600;
      letter-spacing: -0.5px;
      color: var(--white);
    }

    .banner-subtitle {
      font-size: 13px;
      color: #666;
      margin-top: 4px;
    }

    .banner-right {
      display: flex;
      gap: 32px;
    }

    .banner-stat { text-align: center; }

    .banner-stat-value {
      font-family: 'Poppins', sans-serif;
      font-size: 28px;
      font-weight: 600;
      letter-spacing: -1px;
      color: var(--white);
    }

    .banner-stat-value.green { color: var(--green); }

    .banner-stat-label {
      font-size: 11px;
      color: #555;
      font-weight: 400;
      margin-top: 2px;
      letter-spacing: 0.5px;
    }

    .banner-divider {
      width: 1px;
      background: rgba(255,255,255,0.07);
      height: 48px;
      align-self: center;
    }

    .uptime-strip {
      background: var(--dark-3);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px;
      padding: 24px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 48px;
    }

    .uptime-label {
      font-size: 12px;
      color: #555;
      font-weight: 500;
      letter-spacing: 0.5px;
      white-space: nowrap;
    }

    .uptime-bars {
      display: flex;
      gap: 3px;
      flex: 1;
    }

    .uptime-bar {
      flex: 1;
      height: 28px;
      border-radius: 3px;
      background: rgba(34, 197, 94, 0.7);
      cursor: pointer;
      transition: all 0.15s;
    }
    .uptime-bar:hover { transform: scaleY(1.15); background: var(--green); }
    .uptime-bar.degraded { background: rgba(245, 158, 11, 0.7); }
    .uptime-bar.degraded:hover { background: var(--yellow); }
    .uptime-bar.maintenance { background: rgba(59, 130, 246, 0.5); }

    .uptime-pct {
      font-family: 'Poppins', sans-serif;
      font-size: 20px;
      font-weight: 600;
      color: var(--green);
      letter-spacing: -0.5px;
      white-space: nowrap;
    }

    .uptime-period {
      font-size: 11px;
      color: #444;
      white-space: nowrap;
    }

    .section {
      max-width: 1100px;
      margin: 0 auto 40px;
      padding: 0 40px;
    }

    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .section-title {
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #444;
    }

    .section-meta {
      font-size: 11px;
      color: #444;
    }

    .legend {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: #555;
    }

    .legend-dot {
      width: 8px;
      height: 8px;
      border-radius: 2px;
    }

    .services-grid {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .service-card {
      background: var(--dark-3);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px;
      overflow: hidden;
      transition: border-color 0.15s;
    }
    .service-card:hover { border-color: rgba(255,255,255,0.1); }

    .service-row {
      display: flex;
      align-items: center;
      gap: 20px;
      padding: 22px 28px;
      cursor: pointer;
    }

    .service-icon {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 16px;
    }

    .service-info { flex: 1; }

    .service-name {
      font-family: 'Poppins', sans-serif;
      font-size: 14px;
      font-weight: 600;
      color: var(--white);
      margin-bottom: 2px;
    }

    .service-desc {
      font-size: 12px;
      color: #555;
      font-weight: 400;
    }

    .service-uptime-bars {
      display: flex;
      gap: 2px;
      width: 180px;
    }

    .mini-bar {
      flex: 1;
      height: 20px;
      border-radius: 2px;
      background: rgba(34, 197, 94, 0.6);
    }
    .mini-bar.degraded { background: rgba(245, 158, 11, 0.6); }
    .mini-bar.maintenance { background: rgba(59, 130, 246, 0.4); }

    .service-uptime-pct {
      font-size: 12px;
      font-weight: 600;
      color: #888;
      width: 52px;
      text-align: right;
    }

    .service-badge {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 12px;
      font-weight: 500;
      padding: 5px 13px;
      border-radius: 20px;
      white-space: nowrap;
    }

    .badge-operational { color: var(--green); background: var(--green-dim); }
    .badge-degraded { color: var(--yellow); background: var(--yellow-dim); }
    .badge-outage { color: var(--red); background: var(--red-dim); }
    .badge-maintenance { color: var(--blue); background: rgba(59, 130, 246, 0.1); }

    .badge-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: currentColor;
    }

    .service-expand-icon {
      color: #333;
      font-size: 12px;
      transition: transform 0.15s;
      margin-left: 4px;
    }
    .service-card.open .service-expand-icon { transform: rotate(180deg); }

    .service-detail {
      display: none;
      border-top: 1px solid rgba(255,255,255,0.05);
      padding: 20px 28px 24px;
      background: rgba(0,0,0,0.2);
    }
    .service-card.open .service-detail { display: block; }

    .component-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .component-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .component-name {
      font-size: 12px;
      color: #666;
      font-family: 'Inter', monospace;
      font-weight: 400;
    }

    .component-status {
      font-size: 11px;
      font-weight: 500;
      color: var(--green);
    }
    .component-status.yellow { color: var(--yellow); }

    .component-latency {
      font-size: 11px;
      color: #444;
      width: 60px;
      text-align: right;
    }

    .component-bar-wrap {
      flex: 1;
      height: 4px;
      background: rgba(255,255,255,0.06);
      border-radius: 2px;
      max-width: 120px;
    }

    .component-bar-fill {
      height: 100%;
      border-radius: 2px;
      background: var(--green);
    }
    .component-bar-fill.yellow { background: var(--yellow); }

    .sla-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2px;
    }

    .sla-card {
      background: var(--dark-3);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px;
      padding: 28px;
      text-align: center;
    }

    .sla-value {
      font-family: 'Poppins', sans-serif;
      font-size: 32px;
      font-weight: 600;
      letter-spacing: -1px;
      color: var(--white);
      margin-bottom: 6px;
    }

    .sla-value.teal { color: var(--teal); }

    .sla-label {
      font-size: 11px;
      color: #555;
      font-weight: 400;
      letter-spacing: 0.5px;
    }

    .maintenance-card {
      background: var(--dark-3);
      border: 1px solid rgba(59, 130, 246, 0.15);
      border-radius: 14px;
      padding: 24px 28px;
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .maintenance-icon {
      width: 40px;
      height: 40px;
      background: rgba(59, 130, 246, 0.1);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }

    .maintenance-info { flex: 1; }

    .maintenance-title {
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--white);
      margin-bottom: 3px;
    }

    .maintenance-meta {
      font-size: 12px;
      color: #555;
    }

    .maintenance-badge {
      font-size: 11px;
      font-weight: 500;
      color: var(--blue);
      background: rgba(59, 130, 246, 0.1);
      border: 1px solid rgba(59, 130, 246, 0.15);
      padding: 4px 12px;
      border-radius: 20px;
      white-space: nowrap;
    }

    .incidents-wrap {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .incident-card {
      background: var(--dark-3);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px;
      overflow: hidden;
    }

    .incident-header {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      padding: 22px 28px;
      cursor: pointer;
    }

    .incident-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--yellow);
      flex-shrink: 0;
      margin-top: 5px;
    }

    .incident-dot.green { background: var(--green); }

    .incident-info { flex: 1; }

    .incident-title {
      font-family: 'Poppins', sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: var(--white);
      margin-bottom: 4px;
    }

    .incident-meta {
      font-size: 12px;
      color: #555;
    }

    .incident-tag {
      font-size: 11px;
      font-weight: 500;
      color: var(--green);
      background: var(--green-dim);
      padding: 3px 10px;
      border-radius: 20px;
      white-space: nowrap;
    }

    .incident-body {
      display: none;
      border-top: 1px solid rgba(255,255,255,0.05);
      padding: 20px 28px 24px;
    }
    .incident-card.open .incident-body { display: block; }

    .timeline {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .timeline-item {
      display: flex;
      gap: 16px;
      align-items: flex-start;
    }

    .timeline-time {
      font-size: 11px;
      color: #444;
      white-space: nowrap;
      min-width: 80px;
      padding-top: 1px;
    }

    .timeline-content { flex: 1; }

    .timeline-status {
      font-size: 11px;
      font-weight: 600;
      margin-bottom: 2px;
    }

    .timeline-status.investigating { color: var(--yellow); }
    .timeline-status.identified { color: var(--blue); }
    .timeline-status.resolved { color: var(--green); }

    .timeline-text {
      font-size: 12px;
      color: #666;
      line-height: 1.6;
    }

    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.8);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
    }
    .modal-overlay.open {
      opacity: 1;
      pointer-events: all;
    }

    .modal {
      background: var(--dark-3);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 20px;
      padding: 48px;
      width: 440px;
      max-width: 90vw;
      position: relative;
      transform: translateY(20px);
      transition: transform 0.2s;
    }
    .modal-overlay.open .modal { transform: translateY(0); }

    .modal-title {
      font-family: 'Poppins', sans-serif;
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -0.5px;
      margin-bottom: 8px;
    }

    .modal-sub {
      font-size: 13px;
      color: #666;
      margin-bottom: 28px;
      line-height: 1.6;
    }

    .modal-input {
      width: 100%;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px;
      padding: 13px 16px;
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      color: var(--white);
      margin-bottom: 12px;
      outline: none;
      transition: border-color 0.15s;
    }
    .modal-input:focus { border-color: var(--teal); }
    .modal-input::placeholder { color: #444; }

    .modal-btn {
      width: 100%;
      background: var(--teal);
      color: white;
      border: none;
      border-radius: 10px;
      padding: 13px;
      font-family: 'Poppins', sans-serif;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
      letter-spacing: 0.3px;
    }
    .modal-btn:hover { background: var(--teal-dark); }

    .modal-close {
      position: absolute;
      top: 20px;
      right: 20px;
      background: none;
      border: none;
      color: #555;
      font-size: 20px;
      cursor: pointer;
      line-height: 1;
    }

    .footer {
      max-width: 1100px;
      margin: 60px auto 0;
      padding: 32px 40px 48px;
      border-top: 1px solid rgba(255,255,255,0.06);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: 'Poppins', sans-serif;
      font-size: 16px;
      font-weight: 600;
      color: #444;
    }

    .footer-logo .dot { color: var(--teal); opacity: 0.5; }

    .footer-meta {
      font-size: 11px;
      color: #333;
    }

    .footer-link {
      font-size: 12px;
      color: #444;
      text-decoration: none;
      transition: color 0.15s;
    }
    .footer-link:hover { color: var(--teal); }

    @media (max-width: 768px) {
      .topbar { padding: 0 20px; }
      .topbar-center { display: none; }
      .hero { padding: 100px 20px 40px; }
      .section { padding: 0 20px; }
      .hero-status-banner {
        flex-direction: column;
        align-items: flex-start;
        gap: 24px;
        padding: 28px;
      }
      .banner-right { width: 100%; justify-content: flex-start; }
      .sla-grid { grid-template-columns: repeat(2, 1fr); }
      .service-uptime-bars { display: none; }
      .footer {
        flex-direction: column;
        gap: 16px;
        text-align: center;
      }
      .maintenance-card {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      }
      .uptime-strip { flex-wrap: wrap; }
    }
  </style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <a href="https://yapt.ai" class="logo">
    <svg class="logo-icon" viewBox="0 0 40 40" fill="none">
      <rect width="40" height="40" rx="10" fill="#20B2AA" opacity="0.15"/>
      <path d="M8 28L20 12L32 28" stroke="#20B2AA" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M14 22L20 14L26 22" stroke="#2DD4BF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span class="logo-text">yapt<span class="dot">.</span></span>
  </a>

  <div class="topbar-center">
    <span>status.yapt.ai</span>
    <span class="sep">&middot;</span>
    <span id="live-clock"></span>
  </div>

  <div class="topbar-right">
    <button class="subscribe-btn" id="subscribe-open-btn">&#8599; Subscribe to updates</button>
  </div>
</div>

<!-- HERO -->
<div class="hero">
  <div class="hero-eyebrow">System Status</div>

  <div class={`hero-status-banner ${overallStatus !== 'operational' ? overallStatus : ''}`}>
    <div class="banner-left">
      <div class="banner-indicator">
        <div class={pulseDotClass(overallStatus)}></div>
        <div class="banner-title">{overallLabel(overallStatus)}</div>
      </div>
      <div class="banner-subtitle">Last checked {lastCheck} ago &middot; Monitoring 7 services and 14 components</div>
    </div>
    <div class="banner-right">
      <div class="banner-stat">
        <div class="banner-stat-value green">{uptimePct}%</div>
        <div class="banner-stat-label">Uptime 90 days</div>
      </div>
      <div class="banner-divider"></div>
      <div class="banner-stat">
        <div class="banner-stat-value">{avgLatency}</div>
        <div class="banner-stat-label">Avg latency</div>
      </div>
      <div class="banner-divider"></div>
      <div class="banner-stat">
        <div class="banner-stat-value">{mttr}</div>
        <div class="banner-stat-label">Avg MTTR</div>
      </div>
    </div>
  </div>

  <!-- Global uptime bar (90 days) -->
  <div class="uptime-strip">
    <div class="uptime-label">90 days</div>
    <div class="uptime-bars">
      {Array.from({ length: 90 }, (_, i) => {
        let cls = 'uptime-bar';
        if (globalMaintenanceDays.includes(i)) cls += ' maintenance';
        else if (globalDegradedDays.includes(i)) cls += ' degraded';
        return <div class={cls} />;
      })}
    </div>
    <div class="uptime-period">Today</div>
    <div class="uptime-pct">{uptimePct}%</div>
  </div>
</div>

<!-- SERVICES -->
<div class="section">
  <div class="section-header">
    <div class="section-title">Services</div>
    <div class="legend">
      <div class="legend-item"><div class="legend-dot" style="background:rgba(34,197,94,0.7)"></div>Operational</div>
      <div class="legend-item"><div class="legend-dot" style="background:rgba(245,158,11,0.6)"></div>Degraded</div>
      <div class="legend-item"><div class="legend-dot" style="background:rgba(59,130,246,0.5)"></div>Maintenance</div>
    </div>
  </div>

  <div class="services-grid">
    {services.map((svc) => (
      <div class="service-card" data-toggle>
        <div class="service-row">
          <div class="service-icon" style={`background:${svc.iconBg}`}>
            {svc.icon === 'wa' ? (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.025.507 3.934 1.395 5.61L0 24l6.59-1.374C8.202 23.51 10.063 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.895 0-3.665-.513-5.18-1.405l-.371-.22-3.852.804.823-3.76-.241-.389C2.516 15.593 2 13.86 2 12 2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            ) : (
              <Fragment set:text={svc.icon} />
            )}
          </div>
          <div class="service-info">
            <div class="service-name">{svc.name}</div>
            <div class="service-desc">{svc.desc}</div>
          </div>
          <div class="service-uptime-bars">
            {Array.from({ length: 30 }, (_, i) => {
              let cls = 'mini-bar';
              if (svc.maintenanceDays.includes(i)) cls += ' maintenance';
              else if (svc.degradedDays.includes(i)) cls += ' degraded';
              return <div class={cls} />;
            })}
          </div>
          <div class="service-uptime-pct">{svc.uptime}%</div>
          <div class={`service-badge ${statusBadgeClass(svc.status)}`}>
            <div class="badge-dot"></div>{statusLabel(svc.status)}
          </div>
          <div class="service-expand-icon">&#9662;</div>
        </div>
        <div class="service-detail">
          <div class="component-list">
            {svc.components.map((comp) => (
              <div class="component-item">
                <div class="component-name">{comp.name}</div>
                <div class="component-bar-wrap">
                  <div class="component-bar-fill" style={`width:${comp.pct}%`}></div>
                </div>
                <div class="component-latency">{comp.latency}</div>
                <div class={`component-status ${comp.status === 'degraded' ? 'yellow' : ''}`}>
                  {statusLabel(comp.status)}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

<!-- SLA METRICS -->
<div class="section" style="margin-top:40px">
  <div class="section-header">
    <div class="section-title">SLA &amp; Metrics</div>
    <div class="section-meta">Last 90 days</div>
  </div>
  <div class="sla-grid">
    {slaMetrics.map((m) => (
      <div class="sla-card">
        <div class={`sla-value ${m.teal ? 'teal' : ''}`}>{m.value}</div>
        <div class="sla-label">{m.label}</div>
      </div>
    ))}
  </div>
</div>

<!-- MAINTENANCE -->
{maintenance.length > 0 && (
  <div class="section" style="margin-top:40px">
    <div class="section-header">
      <div class="section-title">Scheduled Maintenance</div>
    </div>
    {maintenance.map((m) => (
      <div class="maintenance-card">
        <div class="maintenance-icon">&#128295;</div>
        <div class="maintenance-info">
          <div class="maintenance-title">{m.title}</div>
          <div class="maintenance-meta">{m.meta}</div>
        </div>
        <div class="maintenance-badge">{m.badge}</div>
      </div>
    ))}
  </div>
)}

<!-- INCIDENT HISTORY -->
<div class="section" style="margin-top:40px">
  <div class="section-header">
    <div class="section-title">Incident History</div>
    <div class="section-meta">Last 30 days — resolved only</div>
  </div>
  <div class="incidents-wrap">
    {incidents.map((inc) => (
      <div class="incident-card" data-toggle-incident>
        <div class="incident-header">
          <div class={`incident-dot ${inc.resolved ? 'green' : ''}`}></div>
          <div class="incident-info">
            <div class="incident-title">{inc.title}</div>
            <div class="incident-meta">{inc.meta}</div>
          </div>
          <div class="incident-tag">{inc.resolved ? 'Resolved' : 'Ongoing'}</div>
          <div class="service-expand-icon">&#9662;</div>
        </div>
        <div class="incident-body">
          <div class="timeline">
            {inc.timeline.map((step) => (
              <div class="timeline-item">
                <div class="timeline-time">{step.time}</div>
                <div class="timeline-content">
                  <div class={`timeline-status ${step.status}`}>{step.label}</div>
                  <div class="timeline-text">{step.text}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

<!-- FOOTER -->
<div class="footer">
  <div class="footer-logo">
    <svg width="22" height="22" viewBox="0 0 40 40" fill="none">
      <path d="M8 28L20 12L32 28" stroke="#20B2AA" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
    </svg>
    yapt<span class="dot">.</span>
  </div>
  <div class="footer-meta">
    <span id="footer-time"></span>
  </div>
  <a href="https://yapt.ai" class="footer-link">&larr; Back to yapt.ai</a>
</div>

<!-- SUBSCRIBE MODAL -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <button class="modal-close" id="modal-close-btn">&times;</button>
    <div class="modal-title">Subscribe to alerts</div>
    <div class="modal-sub">Get notified by email when there are incidents or status changes on the yapt. platform.</div>
    <input class="modal-input" type="email" placeholder="you@email.com" id="sub-email">
    <input class="modal-input" type="text" placeholder="Name (optional)">
    <button class="modal-btn" id="modal-submit-btn">Enable notifications</button>
  </div>
</div>

<script>
  // ─── Clock
  function updateClock() {
    const now = new Date();
    const opts: Intl.DateTimeFormatOptions = { timeZone: 'America/Sao_Paulo', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false };
    const time = now.toLocaleTimeString('en-US', opts);
    const clockEl = document.getElementById('live-clock');
    if (clockEl) clockEl.textContent = time + ' BRT';
    const footerEl = document.getElementById('footer-time');
    if (footerEl) {
      footerEl.textContent = 'Updated ' + now.toLocaleString('en-US', {
        timeZone: 'America/Sao_Paulo', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit'
      }) + ' BRT';
    }
  }
  updateClock();
  setInterval(updateClock, 1000);

  // ─── Toggle service cards
  document.querySelectorAll('[data-toggle]').forEach(card => {
    const row = card.querySelector('.service-row');
    if (row) {
      row.addEventListener('click', () => card.classList.toggle('open'));
    }
  });

  // ─── Toggle incidents
  document.querySelectorAll('[data-toggle-incident]').forEach(card => {
    const header = card.querySelector('.incident-header');
    if (header) {
      header.addEventListener('click', () => card.classList.toggle('open'));
    }
  });

  // ─── Modal
  const modal = document.getElementById('modal')!;
  const openBtn = document.getElementById('subscribe-open-btn')!;
  const closeBtn = document.getElementById('modal-close-btn')!;
  const submitBtn = document.getElementById('modal-submit-btn')!;

  openBtn.addEventListener('click', () => modal.classList.add('open'));
  closeBtn.addEventListener('click', () => modal.classList.remove('open'));
  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.classList.remove('open');
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') modal.classList.remove('open');
  });

  submitBtn.addEventListener('click', () => {
    const emailEl = document.getElementById('sub-email') as HTMLInputElement;
    const email = emailEl.value;
    if (!email || !email.includes('@')) {
      emailEl.style.borderColor = '#ef4444';
      return;
    }
    submitBtn.textContent = 'Notifications enabled!';
    submitBtn.style.background = '#22c55e';
    setTimeout(() => modal.classList.remove('open'), 1500);
  });
</script>

</body>
</html>
