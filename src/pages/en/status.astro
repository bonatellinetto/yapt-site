    ],
  },
  {
    title: 'Intermittent failure on ai-orchestrator',
    meta: 'Feb 19, 2026 · Duration: 9 minutes · Affected: Artificial Intelligence',
    resolved: true,
    timeline: [
      { time: '09:42 BRT', status: 'investigating', label: 'Investigating', text: 'Excessive timeout detected in external LLM model calls. Error rate rose to 12%.' },
      { time: '09:51 BRT', status: 'resolved', label: 'Resolved', text: 'Circuit-breaker activated, fallback to secondary model. Service normalized. Postmortem: add adaptive timeout per model.' },
    ],
  },
  {
    title: 'Database maintenance — Supabase Auth',
    meta: 'Feb 02, 2026 · Duration: 4 minutes · Scheduled maintenance',
    resolved: true,
    timeline: [
      { time: '03:00 BRT', status: 'identified', label: 'Maintenance started', text: 'Supabase version upgrade as scheduled. Window: 03:00–03:30 BRT.' },
