---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ModuleDeepDive from '../../components/ModuleDeepDive.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import CTASection from '../../components/CTASection.astro';
import { t, type Locale } from '../../lib/i18n';
import { chameleonSvg, genericIcons } from '../../lib/fauna';

const locale = 'en-US' as const;
const m = (key: string) => t(`automations.${key}`, locale);
const meta = m('meta') as { title: string; description: string };
const hero = m('hero') as { badge: string; title: string; subtitle: string };

const gridData = m('grid') as Record<string, any>;
const gridKeys = Object.keys(gridData).filter(k => k !== 'title' && k !== 'subtitle');
const gridFeatures = gridKeys.map(k => ({
  icon: genericIcons[k as keyof typeof genericIcons] || genericIcons.automation,
  title: gridData[k].title,
  description: gridData[k].description,
}));

const modules = ['builder','dualExperience','multiAI','integrations'] as const;

// Numbers section
const numbers = m('numbers') as any;
const numberKeys = numbers ? Object.keys(numbers).filter(k => k !== 'title') : [];

// SuperMemory section
const superMemory = m('superMemory') as any;

// WA Flows section
const waFlows = m('waFlows') as any;
---

<SiteLayout title={meta.title} description={meta.description} path="/en/automations" locale={locale}>
  <PageHero
    gradient="linear-gradient(135deg, #064E3B, #0D9488, #20B2AA)"
    title={hero.title}
    subtitle={hero.subtitle}
    badge={hero.badge}
    fauna={chameleonSvg}
  />

  {/* Numbers */}
  {numberKeys.length > 0 && (
    <section data-observe class="py-16 lg:py-20 bg-[#FAFBFC]">
      <div class="max-w-5xl mx-auto px-6">
        {numbers.title && <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-[#1a1a2e] text-center mb-12">{numbers.title}</h2>}
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
          {numberKeys.map((k) => {
            const n = numbers[k];
            return (
              <div data-fade style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;" class="text-center">
                <div class="font-poppins text-3xl lg:text-4xl font-bold bg-gradient-to-r from-teal-500 to-cyan-400 bg-clip-text text-transparent">{n.value}</div>
                <p class="text-sm text-[#656D78] mt-2">{n.label}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <div class="[&>section]:py-12 [&>section]:lg:py-16">
    {modules.map((key, i) => {
      const mod = m(key) as { subtitle: string; title: string; description: string; features: string[] };
      if (!mod || !mod.title) return null;
      return (
        <>
          <ModuleDeepDive
            title={mod.title}
            subtitle={mod.subtitle}
            description={mod.description}
            features={mod.features || []}
            reversed={i % 2 === 1}
            accentColor="#20B2AA"
          />
          {i < modules.length - 1 && <SectionDivider variant="light" />}
        </>
      );
    })}
  </div>

  {/* SuperMemory */}
  {superMemory && superMemory.title && (
    <section data-observe class="py-16 lg:py-24" style="background: linear-gradient(135deg, #1a1a2e, #0f3b30);">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <div data-fade style="opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;">
          <span class="inline-block text-xs font-semibold uppercase tracking-wider mb-3 text-purple-300">{superMemory.subtitle || 'yaMemory'}</span>
          <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-white">{superMemory.title}</h2>
          <p class="text-base text-white/60 mt-4 max-w-2xl mx-auto">{superMemory.description}</p>
        </div>
        {superMemory.features && (
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            {(superMemory.features as string[]).map((f: string) => (
              <span class="bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 text-sm text-white/80">{f}</span>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  {/* WA Flows */}
  {waFlows && waFlows.title && (
    <section data-observe class="py-16 lg:py-24" style="background: linear-gradient(135deg, #064E3B, #25D366);">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <div data-fade style="opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;">
          <span class="inline-block text-xs font-semibold uppercase tracking-wider mb-3 text-white/70">{waFlows.subtitle || 'WhatsApp Flows'}</span>
          <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-white">{waFlows.title}</h2>
          <p class="text-base text-white/70 mt-4 max-w-2xl mx-auto">{waFlows.description}</p>
        </div>
        {waFlows.features && (
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            {(waFlows.features as string[]).map((f: string) => (
              <span class="bg-white/15 backdrop-blur-sm rounded-full px-4 py-2 text-sm text-white/90">{f}</span>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  <FeatureGrid
    title={gridData.title}
    features={gridFeatures}
    columns={3}
    accentColor="#20B2AA"
  />

  <CTASection locale={locale} />
</SiteLayout>
