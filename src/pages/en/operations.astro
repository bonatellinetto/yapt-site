---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ModuleDeepDive from '../../components/ModuleDeepDive.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import CTASection from '../../components/CTASection.astro';
import MockupYaInbox from '../../components/mockups/MockupYaInbox.astro';
import MockupHandoff from '../../components/mockups/MockupHandoff.astro';
import MockupYaTeam from '../../components/mockups/MockupYaTeam.astro';
import MockupEmotion from '../../components/mockups/MockupEmotion.astro';
import MockupYaDeals from '../../components/mockups/MockupYaDeals.astro';
import MockupYaCampaigns from '../../components/mockups/MockupYaCampaigns.astro';
import { t, type Locale } from '../../lib/i18n';
import { antColonySvg, genericIcons } from '../../lib/fauna';

const locale = 'en-US' as const;
const m = (key: string) => t(`operations.${key}`, locale);
const meta = m('meta') as { title: string; description: string };
const hero = m('hero') as { badge: string; title: string; subtitle: string };

const gridData = m('grid') as Record<string, any>;
const gridKeys = Object.keys(gridData).filter(k => k !== 'title' && k !== 'subtitle');
const gridFeatures = gridKeys.map(k => ({
  icon: genericIcons[k as keyof typeof genericIcons] || genericIcons.settings,
  title: gridData[k].title,
  description: gridData[k].description,
}));

const modules = ['inbox','routing','sla','monitor','deals','analytics'] as const;

// Roadmap
const roadmap = m('roadmap') as any;
const roadmapItems = roadmap?.items || [];
---

<SiteLayout title={meta.title} description={meta.description} path="/en/operations" locale={locale}>
  <PageHero
    gradient="linear-gradient(135deg, #064E3B, #10B981, #34D399)"
    title={hero.title}
    subtitle={hero.subtitle}
    badge={hero.badge}
    fauna={antColonySvg}
  />

  <div class="[&>section]:py-12 [&>section]:lg:py-16">
    {modules.map((key, i) => {
      const mod = m(key) as { subtitle: string; title: string; description: string; features: string[] };
      if (!mod || !mod.title) return null;
      return (
        <>
          <ModuleDeepDive
            title={mod.title}
            subtitle={mod.subtitle}
            description={mod.description}
            features={mod.features || []}
            reversed={i % 2 === 1}
            accentColor="#10B981"
          >
            {key === 'inbox' && <MockupYaInbox />}
            {key === 'routing' && <MockupHandoff />}
            {key === 'sla' && <MockupYaTeam />}
            {key === 'monitor' && <MockupEmotion />}
            {key === 'deals' && <MockupYaDeals />}
            {key === 'analytics' && <MockupYaCampaigns />}
          </ModuleDeepDive>
          {i < modules.length - 1 && <SectionDivider variant="light" />}
        </>
      );
    })}
  </div>

  <FeatureGrid
    title={gridData.title}
    subtitle={gridData.subtitle}
    features={gridFeatures}
    columns={3}
    accentColor="#10B981"
  />

  {/* Roadmap */}
  {roadmapItems.length > 0 && (
    <section data-observe class="py-16 lg:py-24" style="background: linear-gradient(135deg, #1a1a2e, #064E3B);">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-12">
          {roadmap.title && <h2 class="font-poppins text-2xl lg:text-3xl font-bold text-white">{roadmap.title}</h2>}
          {roadmap.subtitle && <p class="text-base text-white/60 mt-4">{roadmap.subtitle}</p>}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {roadmapItems.map((item: any) => (
            <div
              data-fade
              style="opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;"
              class="bg-white/5 backdrop-blur-sm rounded-2xl p-5 border border-white/10"
            >
              <h3 class="font-poppins text-sm font-semibold text-white mb-1">{item.title}</h3>
              <p class="text-xs text-white/50 leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTASection locale={locale} />
</SiteLayout>
