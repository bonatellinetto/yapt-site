---
// WhatsApp chat mockup — pure HTML + CSS animation (no JS needed for display)
---

<div
  class="w-full max-w-[340px] rounded-2xl overflow-hidden shadow-2xl"
  style="background: #ECE5DD; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;"
>
  <!-- Header -->
  <div class="flex items-center gap-3 px-4 py-3" style="background: #075E54;">
    <div class="flex items-center justify-center w-9 h-9 rounded-full bg-white/20 text-white text-xs font-bold shrink-0">
      y.
    </div>
    <div class="flex-1 min-w-0">
      <div class="text-white text-sm font-semibold truncate">yapt. AI</div>
      <div class="text-white/70 text-[11px]">online</div>
    </div>
    <div class="flex items-center gap-3 text-white/70">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
    </div>
  </div>

  <!-- Chat area -->
  <div
    class="flex flex-col gap-2 px-3 py-4 overflow-hidden"
    style="min-height: 280px; background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c5bfb3' fill-opacity='0.15'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"
  >
    <!-- Date chip -->
    <div class="flex justify-center mb-1">
      <span class="text-[11px] px-3 py-1 rounded-lg" style="background: #E1F2FB; color: #5f7e8a;">HOJE</span>
    </div>

    <!-- Message 1: yapt bot -->
    <div class="flex justify-start wa-msg" style="animation: wa-msg-in 0.5s ease forwards 0.6s; opacity: 0;">
      <div class="relative max-w-[85%] rounded-lg px-3 py-2 text-[13px] leading-[1.35] bg-white" style="color: #303030; box-shadow: 0 1px 1px rgba(0,0,0,0.08);">
        <div class="absolute top-0 -left-1.5 w-3 h-3" style="border-top: 6px solid #FFFFFF; border-right: 6px solid transparent;"></div>
        <div class="text-[12px] font-semibold mb-0.5" style="color: #075E54;">yapt. AI ✓</div>
        <span style="white-space: pre-line;">Oi Marina! 👋 Vi que você interagiu com nosso anúncio de Plano Business Pro e estou fazendo contato para seguir com seu atendimento. É um bom momento pra conversarmos?</span>
        <span class="float-right ml-2 mt-1 text-[10px]" style="color: #8696a0;">10:42</span>
        <!-- Quick replies -->
        <div class="flex flex-col gap-1.5 mt-2 pt-2 border-t border-black/5">
          <div class="text-center text-[13px] font-medium py-2 rounded-md" style="color: #00a884; background: rgba(0,168,132,0.06);">Sim, pode ser agora</div>
          <div class="text-center text-[13px] font-medium py-2 rounded-md" style="color: #00a884; background: rgba(0,168,132,0.06);">Prefiro agendar</div>
        </div>
      </div>
    </div>

    <!-- Message 2: Marina -->
    <div class="flex justify-end wa-msg" style="animation: wa-msg-in 0.5s ease forwards 2.4s; opacity: 0;">
      <div class="relative max-w-[85%] rounded-lg px-3 py-2 text-[13px] leading-[1.35]" style="background: #DCF8C6; color: #303030; box-shadow: 0 1px 1px rgba(0,0,0,0.08);">
        <div class="absolute top-0 -right-1.5 w-3 h-3" style="border-top: 6px solid #DCF8C6; border-left: 6px solid transparent;"></div>
        <span>Sim, pode ser agora!</span>
        <span class="float-right ml-2 mt-1 text-[10px]" style="color: #8696a0;">
          10:43
          <svg class="inline ml-0.5 -mt-px" width="16" height="11" viewBox="0 0 16 11">
            <path d="M11.07 0.73L4.53 7.26 1.97 4.7 0.56 6.11 4.53 10.08 12.49 2.14z" fill="#53bdeb"/>
            <path d="M14.07 0.73L7.53 7.26 6.63 6.36 5.22 7.77 7.53 10.08 15.49 2.14z" fill="#53bdeb"/>
          </svg>
        </span>
      </div>
    </div>

    <!-- Message 3: yapt bot -->
    <div class="flex justify-start wa-msg" style="animation: wa-msg-in 0.5s ease forwards 4s; opacity: 0;">
      <div class="relative max-w-[85%] rounded-lg px-3 py-2 text-[13px] leading-[1.35] bg-white" style="color: #303030; box-shadow: 0 1px 1px rgba(0,0,0,0.08);">
        <div class="absolute top-0 -left-1.5 w-3 h-3" style="border-top: 6px solid #FFFFFF; border-right: 6px solid transparent;"></div>
        <div class="text-[12px] font-semibold mb-0.5" style="color: #075E54;">yapt. AI ✓</div>
        <span style="white-space: pre-line;">Que ótimo, Marina! Nossa solução é mesmo incrível como você viu no anúncio e eu vou te ajudar por aqui. 😊

Me diz uma coisa, o que te fez buscar nossa solução?</span>
        <span class="float-right ml-2 mt-1 text-[10px]" style="color: #8696a0;">10:43</span>
      </div>
    </div>

    <!-- Typing indicator -->
    <div class="flex justify-start wa-msg" style="animation: wa-msg-in 0.5s ease forwards 5.5s; opacity: 0;">
      <div class="rounded-lg px-4 py-3 bg-white" style="box-shadow: 0 1px 1px rgba(0,0,0,0.08);">
        <div class="flex gap-1">
          <span class="w-2 h-2 rounded-full bg-gray-400 animate-bounce" style="animation-delay: 0ms;"></span>
          <span class="w-2 h-2 rounded-full bg-gray-400 animate-bounce" style="animation-delay: 150ms;"></span>
          <span class="w-2 h-2 rounded-full bg-gray-400 animate-bounce" style="animation-delay: 300ms;"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Input bar -->
  <div class="flex items-center gap-2 px-3 py-2" style="background: #F0F0F0;">
    <div class="text-gray-500">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
    </div>
    <div class="flex-1 rounded-full px-4 py-2 text-[13px] bg-white" style="color: #8696a0;">
      Mensagem
    </div>
    <div class="text-gray-500">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
    </div>
  </div>
</div>

<style>
  @keyframes wa-msg-in {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
