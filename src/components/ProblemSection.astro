---
import { t, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const cards = t('problem.cards', locale) as { title: string; description: string }[];
---

<section class="relative overflow-hidden" style="background: #f5f5f7;">
  <!-- Dot pattern -->
  <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(0,0,0,0.04) 1px, transparent 1px); background-size: 20px 20px;"></div>

  <!-- Decorative animals -->
  <svg class="absolute pointer-events-none hidden md:block" style="top: 40px; left: -60px; width: 180px; height: 180px; opacity: 0.06;" viewBox="0 0 120 120" fill="none" aria-hidden="true">
    <ellipse cx="60" cy="70" rx="35" ry="40" fill="#1d1d1f"/>
    <ellipse cx="60" cy="35" rx="28" ry="25" fill="#1d1d1f"/>
    <path d="M40 38 Q47 42, 54 38" stroke="#1d1d1f" stroke-width="3" fill="none"/>
    <path d="M66 38 Q73 42, 80 38" stroke="#1d1d1f" stroke-width="3" fill="none"/>
  </svg>
  <svg class="absolute pointer-events-none hidden md:block" style="top: 120px; right: -40px; width: 120px; height: 120px; opacity: 0.06; transform: rotate(15deg);" viewBox="0 0 100 100" fill="none" aria-hidden="true">
    <ellipse cx="50" cy="55" rx="20" ry="24" fill="#1d1d1f"/>
    <ellipse cx="50" cy="32" rx="14" ry="12" fill="#1d1d1f"/>
    <path d="M30 48 Q50 45, 70 48" stroke="#666" stroke-width="3"/>
    <path d="M30 58 Q50 55, 70 58" stroke="#666" stroke-width="3"/>
  </svg>
  <svg class="absolute pointer-events-none hidden md:block" style="bottom: 60px; left: 20px; width: 140px; height: 140px; opacity: 0.06;" viewBox="0 0 120 120" fill="none" aria-hidden="true">
    <ellipse cx="60" cy="65" rx="35" ry="30" fill="#1d1d1f"/>
    <ellipse cx="60" cy="40" rx="22" ry="18" fill="#1d1d1f"/>
    <path d="M60 55 Q60 75, 60 95" stroke="#1d1d1f" stroke-width="8" stroke-linecap="round"/>
  </svg>

  <div class="relative z-10 max-w-[1100px] mx-auto px-6 py-16 lg:py-24">
    <!-- Header -->
    <div data-fade class="max-w-[700px] mb-14" style="opacity: 0; transform: translateY(2rem); transition: opacity 700ms ease, transform 700ms ease;">
      <h2 style="font-size: clamp(32px, 4vw, 44px); font-weight: 700; letter-spacing: -0.03em; line-height: 1.1; color: #1d1d1f; margin-bottom: 20px;">
        {t('problem.title', locale)}
      </h2>
      <p style="font-size: 18px; color: #6e6e73; line-height: 1.7;">
        {t('problem.description', locale)}
      </p>
    </div>

    <!-- Problem Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {Array.isArray(cards) && cards.map((card, i) => (
        <div
          data-fade
          class="rounded-2xl transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
          style={`background: #ffffff; border: 1px solid rgba(0,0,0,0.06); padding: 32px 28px; opacity: 0; transform: translateY(2rem); transition: all 0.5s ease ${i * 150}ms;`}
        >
          <!-- Animal icon -->
          {i === 0 && (
            <svg viewBox="0 0 56 56" fill="none" class="w-14 h-14 mb-6" style="opacity: 0.25;">
              <path d="M8 26 Q18 18, 28 22 Q34 24, 36 28" fill="#6e6e73"/>
              <path d="M48 26 Q38 18, 28 22" fill="#6e6e73"/>
              <ellipse cx="28" cy="36" rx="12" ry="14" fill="#6e6e73"/>
              <circle cx="28" cy="26" r="9" fill="#aeaeb2"/>
              <path d="M24 24 L28 28 M28 24 L24 28" stroke="#6e6e73" stroke-width="2" stroke-linecap="round"/>
            </svg>
          )}
          {i === 1 && (
            <svg viewBox="0 0 56 56" fill="none" class="w-14 h-14 mb-6" style="opacity: 0.25;">
              <ellipse cx="28" cy="34" rx="16" ry="18" fill="#6e6e73"/>
              <ellipse cx="28" cy="18" rx="13" ry="11" fill="#6e6e73"/>
              <circle cx="22" cy="18" r="5" fill="#aeaeb2"/>
              <circle cx="34" cy="18" r="5" fill="#aeaeb2"/>
              <path d="M20 16 L24 20 M24 16 L20 20" stroke="#6e6e73" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M32 16 L36 20 M36 16 L32 20" stroke="#6e6e73" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M26 26 L28 30 L30 26 Z" fill="#86868b"/>
            </svg>
          )}
          {i === 2 && (
            <svg viewBox="0 0 56 56" fill="none" class="w-14 h-14 mb-6" style="opacity: 0.25;">
              <ellipse cx="28" cy="32" rx="16" ry="14" fill="#6e6e73"/>
              <ellipse cx="28" cy="20" rx="10" ry="8" fill="#6e6e73"/>
              <path d="M28 28 Q28 38, 28 48" stroke="#6e6e73" stroke-width="5" stroke-linecap="round"/>
              <path d="M14 18 Q10 22, 12 28" stroke="#6e6e73" stroke-width="4" stroke-linecap="round" fill="none"/>
              <path d="M42 18 Q46 22, 44 28" stroke="#6e6e73" stroke-width="4" stroke-linecap="round" fill="none"/>
            </svg>
          )}
          <h3 class="font-semibold leading-tight" style="font-size: 17px; color: #1d1d1f; margin-bottom: 12px;">
            {card.title}
          </h3>
          <p style="font-size: 14px; color: #6e6e73; line-height: 1.65;">
            {card.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
