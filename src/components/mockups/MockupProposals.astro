---
/** MockupProposals — WhatsApp Proposal Tracker (sales page) */
---
<div class="prop-frame">
  <!-- Header -->
  <div class="prop-header">
    <div style="display: flex; align-items: center; gap: 8px;">
      <div style="width: 28px; height: 28px; border-radius: 8px; background: linear-gradient(135deg, #6366F1, #4F46E5); display: flex; align-items: center; justify-content: center;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      </div>
      <div>
        <div style="font-size: 13px; font-weight: 700; color: #1F2937;">Propostas</div>
        <div style="font-size: 9px; color: #9CA3AF;">3 ativas</div>
      </div>
    </div>
    <div class="prop-wa-badge">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.96 9.96 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2z"/></svg>
      Via WhatsApp
    </div>
  </div>

  <!-- Proposal List -->
  <div class="prop-list">
    <!-- Proposal 1 -->
    <div class="prop-card">
      <div class="prop-card-top">
        <div class="prop-card-info">
          <div class="prop-card-name">Plano Enterprise — Rodrigo Pimentel</div>
          <div class="prop-card-value">R$ 18.500/mes</div>
        </div>
        <div class="prop-badge prop-badge-green">
          <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          Visualizada 3x
        </div>
      </div>
      <div class="prop-card-meta">
        <span class="prop-time">Enviada 2h atras</span>
        <span class="prop-dot"></span>
        <span class="prop-engagement">Tempo medio: 4min por visita</span>
      </div>
      <div class="prop-progress-row">
        <div class="prop-progress-bar">
          <div class="prop-progress-fill prop-fill-green" style="width: 75%;"></div>
        </div>
        <span class="prop-progress-label">75%</span>
      </div>
    </div>

    <!-- Proposal 2 -->
    <div class="prop-card">
      <div class="prop-card-top">
        <div class="prop-card-info">
          <div class="prop-card-name">Plano Professional — Marina Costa</div>
          <div class="prop-card-value">R$ 4.200/mes</div>
        </div>
        <div class="prop-badge prop-badge-blue">
          <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
          Aceita
        </div>
      </div>
      <div class="prop-card-meta">
        <span class="prop-time">Enviada 1d atras</span>
        <span class="prop-dot"></span>
        <span class="prop-engagement">Assinada digitalmente</span>
      </div>
      <div class="prop-progress-row">
        <div class="prop-progress-bar">
          <div class="prop-progress-fill prop-fill-blue" style="width: 100%;"></div>
        </div>
        <span class="prop-progress-label">100%</span>
      </div>
    </div>

    <!-- Proposal 3 -->
    <div class="prop-card">
      <div class="prop-card-top">
        <div class="prop-card-info">
          <div class="prop-card-name">Plano Starter — Carlos Mendes</div>
          <div class="prop-card-value">R$ 890/mes</div>
        </div>
        <div class="prop-badge prop-badge-gray">
          <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
          Enviada
        </div>
      </div>
      <div class="prop-card-meta">
        <span class="prop-time">Enviada 5h atras</span>
        <span class="prop-dot"></span>
        <span class="prop-engagement">Aberta 1x</span>
      </div>
      <div class="prop-progress-row">
        <div class="prop-progress-bar">
          <div class="prop-progress-fill prop-fill-gray" style="width: 25%;"></div>
        </div>
        <span class="prop-progress-label">25%</span>
      </div>
    </div>
  </div>

  <!-- Footer Metrics -->
  <div class="prop-footer">
    <div class="prop-footer-title">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
      Metricas
    </div>
    <div class="prop-stats">
      <div class="prop-stat">
        <div class="prop-stat-value">68%</div>
        <div class="prop-stat-label">Taxa de aceite</div>
      </div>
      <div class="prop-stat-divider"></div>
      <div class="prop-stat">
        <div class="prop-stat-value">1.8 dias</div>
        <div class="prop-stat-label">Tempo medio</div>
      </div>
      <div class="prop-stat-divider"></div>
      <div class="prop-stat">
        <div class="prop-stat-value">R$ 23.590</div>
        <div class="prop-stat-label">Valor total</div>
      </div>
    </div>
  </div>
</div>

<style>
  .prop-frame {
    width: 100%; max-width: 540px; border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.03);
    background: #ffffff; border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
  }

  /* Header */
  .prop-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px; border-bottom: 1px solid #F3F4F6;
  }
  .prop-wa-badge {
    display: flex; align-items: center; gap: 4px;
    font-size: 8px; font-weight: 600; color: #25D366;
    padding: 3px 8px; border-radius: 8px;
    background: rgba(37,211,102,0.06); border: 1px solid rgba(37,211,102,0.2);
  }

  /* Proposal List */
  .prop-list {
    display: flex; flex-direction: column; gap: 6px;
    padding: 10px 14px;
  }

  /* Proposal Card */
  .prop-card {
    padding: 10px 12px; border-radius: 10px;
    border: 1px solid #E5E7EB; background: #FAFBFC;
  }
  .prop-card-top {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 8px;
  }
  .prop-card-info { flex: 1; min-width: 0; }
  .prop-card-name {
    font-size: 10px; font-weight: 600; color: #1F2937;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .prop-card-value {
    font-size: 11px; font-weight: 700; color: #4F46E5;
    margin-top: 1px;
  }

  /* Status Badges */
  .prop-badge {
    display: flex; align-items: center; gap: 3px;
    font-size: 8px; font-weight: 600;
    padding: 3px 7px; border-radius: 6px;
    white-space: nowrap; flex-shrink: 0;
  }
  .prop-badge-green {
    color: #059669; background: rgba(5,150,105,0.06);
    border: 1px solid rgba(5,150,105,0.2);
  }
  .prop-badge-blue {
    color: #4F46E5; background: rgba(79,70,229,0.06);
    border: 1px solid rgba(79,70,229,0.2);
  }
  .prop-badge-gray {
    color: #6B7280; background: rgba(107,114,128,0.06);
    border: 1px solid rgba(107,114,128,0.15);
  }

  /* Meta Row */
  .prop-card-meta {
    display: flex; align-items: center; gap: 6px;
    margin-top: 6px;
  }
  .prop-time { font-size: 8px; color: #9CA3AF; }
  .prop-dot {
    width: 2px; height: 2px; border-radius: 50%;
    background: #D1D5DB; flex-shrink: 0;
  }
  .prop-engagement { font-size: 8px; color: #9CA3AF; }

  /* Progress Bar */
  .prop-progress-row {
    display: flex; align-items: center; gap: 6px;
    margin-top: 7px;
  }
  .prop-progress-bar {
    flex: 1; height: 4px; border-radius: 2px;
    background: #E5E7EB; overflow: hidden;
  }
  .prop-progress-fill {
    height: 100%; border-radius: 2px;
  }
  .prop-fill-green { background: linear-gradient(90deg, #34D399, #059669); }
  .prop-fill-blue { background: linear-gradient(90deg, #818CF8, #4F46E5); }
  .prop-fill-gray { background: linear-gradient(90deg, #D1D5DB, #9CA3AF); }
  .prop-progress-label {
    font-size: 8px; font-weight: 700; color: #6B7280;
    min-width: 24px; text-align: right;
  }

  /* Footer */
  .prop-footer {
    padding: 10px 14px; border-top: 1px solid #F3F4F6;
    background: #FAFBFC;
  }
  .prop-footer-title {
    display: flex; align-items: center; gap: 5px;
    font-size: 10px; font-weight: 700; color: #1F2937;
    margin-bottom: 8px;
  }
  .prop-stats {
    display: flex; align-items: center; justify-content: space-between;
  }
  .prop-stat {
    flex: 1; text-align: center;
  }
  .prop-stat-value {
    font-size: 12px; font-weight: 800; color: #4F46E5;
  }
  .prop-stat-label {
    font-size: 8px; color: #9CA3AF; margin-top: 1px;
  }
  .prop-stat-divider {
    width: 1px; height: 24px; background: #E5E7EB; flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .prop-card-name { font-size: 9px; }
    .prop-card-value { font-size: 10px; }
  }
</style>
