---
/** MockupWaFlowForm — WhatsApp Flow native form inside phone mockup (CSS-only, no JS/images) */
---
<div class="wff-frame">
  <div class="wff-phone">
    <!-- WhatsApp Header -->
    <div class="wff-wa-header">
      <div style="display: flex; align-items: center; gap: 6px; flex: 1; min-width: 0;">
        <!-- Back arrow -->
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        <!-- Avatar -->
        <div style="width: 22px; height: 22px; border-radius: 50%; background: #20B2AA; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <span style="font-size: 9px; font-weight: 700; color: white; font-family: 'Poppins', Inter, sans-serif;">Y</span>
        </div>
        <div style="min-width: 0;">
          <div style="font-size: 9px; font-weight: 600; color: white; font-family: 'Poppins', Inter, sans-serif; line-height: 1.2;">yapt.</div>
          <div style="font-size: 6px; color: rgba(255,255,255,0.75); line-height: 1;">online</div>
        </div>
      </div>
      <div style="display: flex; align-items: center; gap: 8px;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="white"><path d="M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94M20 16v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 3 6.18 2 2 0 0 1 5 4h3a2 2 0 0 1 2 1.72c.13.81.36 1.59.68 2.32a2 2 0 0 1-.45 2.11L9.09 11.3a16 16 0 0 0 6.61 6.61l1.15-1.14a2 2 0 0 1 2.11-.45c.73.32 1.51.55 2.32.68A2 2 0 0 1 23 19z" fill="none" stroke="white" stroke-width="1.5"/></svg>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
      </div>
    </div>

    <!-- Chat background -->
    <div class="wff-chat-bg">
      <!-- Subtle chat pattern overlay -->
      <div class="wff-chat-pattern"></div>

      <!-- Bot message bubble -->
      <div style="display: flex; justify-content: flex-start; padding: 6px 8px 2px;">
        <div style="background: white; border-radius: 0 6px 6px 6px; padding: 5px 7px; max-width: 80%; box-shadow: 0 0.5px 1px rgba(0,0,0,0.08);">
          <div style="font-size: 7px; color: #303030; line-height: 1.4;">Oi! Queremos ouvir voce. Responda nossa pesquisa rapida:</div>
          <div style="font-size: 5.5px; color: #999; text-align: right; margin-top: 2px;">10:42</div>
        </div>
      </div>

      <!-- Flow CTA bubble -->
      <div style="display: flex; justify-content: flex-start; padding: 2px 8px 4px;">
        <div style="background: white; border-radius: 0 6px 6px 6px; overflow: hidden; max-width: 80%; box-shadow: 0 0.5px 1px rgba(0,0,0,0.08);">
          <div style="padding: 5px 7px;">
            <div style="font-size: 7px; color: #303030; line-height: 1.3; font-weight: 500;">📋 Pesquisa de Satisfacao</div>
            <div style="font-size: 6px; color: #667781; line-height: 1.3; margin-top: 1px;">Leva menos de 1 min</div>
          </div>
          <div style="border-top: 1px solid #E8E8E8; padding: 4px 7px; text-align: center;">
            <span style="font-size: 7px; font-weight: 600; color: #00A884;">Abrir formulario</span>
          </div>
        </div>
      </div>

      <!-- Flow Overlay Card -->
      <div class="wff-flow-overlay">
        <!-- Flow header -->
        <div class="wff-flow-header">
          <div style="display: flex; align-items: center; gap: 5px;">
            <div style="width: 16px; height: 16px; border-radius: 50%; background: linear-gradient(135deg, #20B2AA, #2DD4BF); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <span style="font-size: 7px; font-weight: 700; color: white; font-family: 'Poppins', Inter, sans-serif;">y</span>
            </div>
            <div>
              <div style="font-size: 8px; font-weight: 600; color: #1F2937; line-height: 1.2;">Pesquisa de Satisfacao</div>
              <div style="font-size: 6px; color: #9CA3AF; line-height: 1;">yapt. &middot; Formulario seguro</div>
            </div>
          </div>
          <div style="display: flex; align-items: center; gap: 4px;">
            <span style="font-size: 6px; color: #9CA3AF; font-weight: 500;">1 de 3</span>
            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </div>
        </div>

        <!-- Flow body / Step 1 -->
        <div class="wff-flow-body">
          <!-- Question 1: Star rating -->
          <div style="margin-bottom: 10px;">
            <div style="font-size: 7px; font-weight: 600; color: #374151; margin-bottom: 4px;">Como voce avalia nosso atendimento?</div>
            <div style="display: flex; gap: 3px;">
              <!-- 4 filled stars -->
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#20B2AA" stroke="#20B2AA" stroke-width="1"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#20B2AA" stroke="#20B2AA" stroke-width="1"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#20B2AA" stroke="#20B2AA" stroke-width="1"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#20B2AA" stroke="#20B2AA" stroke-width="1"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <!-- 1 empty star -->
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#D1D5DB" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
          </div>

          <!-- Question 2: Dropdown -->
          <div style="margin-bottom: 10px;">
            <div style="font-size: 7px; font-weight: 600; color: #374151; margin-bottom: 4px;">O que mais gostou?</div>
            <div class="wff-select">
              <span style="font-size: 7px; color: #374151;">Rapidez no atendimento</span>
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
            </div>
          </div>

          <!-- Question 3: Textarea -->
          <div style="margin-bottom: 12px;">
            <div style="font-size: 7px; font-weight: 600; color: #374151; margin-bottom: 4px;">Comentario <span style="font-weight: 400; color: #9CA3AF;">(opcional)</span></div>
            <div class="wff-textarea">
              <span style="font-size: 7px; color: #6B7280;">Equipe muito atenciosa, resolveram meu problema rapidamente...</span>
            </div>
          </div>

          <!-- Progress bar -->
          <div style="margin-bottom: 8px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3px;">
              <span style="font-size: 6px; color: #9CA3AF; font-weight: 500;">Progresso</span>
              <span style="font-size: 6px; color: #20B2AA; font-weight: 600;">33%</span>
            </div>
            <div class="wff-progress-track">
              <div class="wff-progress-fill"></div>
            </div>
          </div>

          <!-- Button -->
          <div class="wff-btn-next">
            <span style="font-size: 8px; font-weight: 600; color: white;">Proximo</span>
            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom WhatsApp input bar -->
    <div class="wff-input-bar">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
      <div class="wff-input-placeholder">
        <span style="font-size: 7px; color: #999;">Responda o formulario acima</span>
      </div>
      <svg width="10" height="10" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2" fill="none" stroke="#9CA3AF" stroke-width="1.5"/></svg>
    </div>
  </div>
</div>

<style>
  .wff-frame {
    width: 100%;
    max-width: 300px;
    background: white;
    border-radius: 16px;
    box-shadow: 0 12px 48px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.04);
    border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }

  .wff-phone {
    display: flex;
    flex-direction: column;
    height: 480px;
  }

  /* WhatsApp header */
  .wff-wa-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 10px;
    background: #075E54;
    flex-shrink: 0;
  }

  /* Chat background */
  .wff-chat-bg {
    flex: 1;
    background: #ECE5DD;
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .wff-chat-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image:
      radial-gradient(circle, #000 0.5px, transparent 0.5px);
    background-size: 12px 12px;
    pointer-events: none;
  }

  /* Flow overlay card */
  .wff-flow-overlay {
    position: relative;
    margin: 4px 8px 6px;
    background: white;
    border-radius: 10px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12), 0 1px 4px rgba(0,0,0,0.06);
    overflow: hidden;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .wff-flow-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 10px;
    border-bottom: 1px solid #F3F4F6;
    flex-shrink: 0;
  }

  .wff-flow-body {
    padding: 10px 12px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* Select / dropdown */
  .wff-select {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 8px;
    border: 1px solid #E5E7EB;
    border-radius: 6px;
    background: #FAFAFA;
  }

  /* Textarea */
  .wff-textarea {
    padding: 6px 8px;
    border: 1px solid #E5E7EB;
    border-radius: 6px;
    background: #FAFAFA;
    min-height: 36px;
    line-height: 1.4;
  }

  /* Progress bar */
  .wff-progress-track {
    height: 4px;
    background: #E5E7EB;
    border-radius: 2px;
    overflow: hidden;
  }

  .wff-progress-fill {
    width: 33%;
    height: 100%;
    background: linear-gradient(90deg, #20B2AA, #2DD4BF);
    border-radius: 2px;
  }

  /* Next button */
  .wff-btn-next {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 8px;
    background: #20B2AA;
    border-radius: 8px;
    margin-top: auto;
  }

  /* Bottom input bar */
  .wff-input-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 8px;
    background: #F0F0F0;
    flex-shrink: 0;
  }

  .wff-input-placeholder {
    flex: 1;
    padding: 5px 8px;
    background: white;
    border-radius: 12px;
  }
</style>
