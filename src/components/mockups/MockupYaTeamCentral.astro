---
/** MockupYaTeamCentral — yaTeam Central de Criação de IAs (intelligence page, populated) */
---
<div class="ytc-frame">
  <!-- Top bar -->
  <div class="ytc-topbar">
    <div style="display: flex; align-items: center; gap: 8px;">
      <div style="width: 24px; height: 24px; border-radius: 8px; background: linear-gradient(135deg, #8B5CF6, #A78BFA); display: flex; align-items: center; justify-content: center;">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
      </div>
      <div>
        <span style="font-size: 12px; font-weight: 700; color: #1F2937;">Central de Criacao de IAs</span>
      </div>
    </div>
    <div class="ytc-btn-create">+ Criar Agente</div>
  </div>

  <div class="ytc-body">
    <!-- Sidebar -->
    <div class="ytc-sidebar">
      <div class="ytc-nav-label">Visao geral</div>
      <div class="ytc-nav-item ytc-nav-active">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
        Overview
      </div>
      <div class="ytc-nav-label" style="margin-top: 6px;">Agentes</div>
      <div class="ytc-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3z"/></svg>
        Mentores
        <span class="ytc-badge-purple">3</span>
      </div>
      <div class="ytc-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/></svg>
        Atendentes
        <span class="ytc-badge-purple">5</span>
      </div>
      <div class="ytc-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        Automacoes
        <span class="ytc-badge-purple">2</span>
      </div>
      <div class="ytc-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Protetor 24h
        <span class="ytc-badge-gray">1</span>
      </div>
      <div class="ytc-nav-label" style="margin-top: 6px;">Config</div>
      <div class="ytc-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9c.2.65.77 1.1 1.45 1.12H21a2 2 0 010 4h-.09c-.68.02-1.25.47-1.45 1.12z"/></svg>
        Skills
      </div>
    </div>

    <!-- Main content -->
    <div class="ytc-main">
      <!-- Hero purple card -->
      <div class="ytc-hero">
        <div style="font-size: 9px; color: rgba(255,255,255,0.7);">Ola, Marina!</div>
        <div style="font-size: 14px; font-weight: 700; color: white; margin: 3px 0;">Seu Time de IAs</div>
        <div style="font-size: 8px; color: rgba(255,255,255,0.7); margin-bottom: 10px;">Crie e gerencie agentes inteligentes que trabalham 24/7 para sua empresa.</div>
        <div class="ytc-hero-kpis">
          <div class="ytc-hero-kpi">
            <div style="font-size: 18px; font-weight: 700;">11</div>
            <div style="font-size: 7px; opacity: 0.7;">Agentes Ativos</div>
          </div>
          <div class="ytc-hero-kpi">
            <div style="font-size: 18px; font-weight: 700;">1.247</div>
            <div style="font-size: 7px; opacity: 0.7;">Atendimentos Hoje</div>
          </div>
          <div class="ytc-hero-kpi">
            <div style="font-size: 18px; font-weight: 700;">R$ 18k</div>
            <div style="font-size: 7px; opacity: 0.7;">Economia/Mes*</div>
          </div>
        </div>
        <div style="font-size: 6px; color: rgba(255,255,255,0.5); margin-top: 4px;">* Economia estimada vs atendente humano (R$ 5,00/interacao — Gartner, 2022)</div>
      </div>

      <!-- Agent type cards -->
      <div class="ytc-types">
        <div class="ytc-type-card" style="border-top: 3px solid #F59E0B;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px;">
            <div style="width: 20px; height: 20px; border-radius: 6px; background: rgba(245,158,11,0.1); display: flex; align-items: center; justify-content: center;">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3z"/></svg>
            </div>
            <span class="ytc-type-badge-active">Ativo</span>
          </div>
          <div style="font-size: 9px; font-weight: 600; color: #1F2937;">Mentores</div>
          <div style="font-size: 7px; color: #9CA3AF;">Treinam o time em tempo real</div>
          <div style="font-size: 10px; font-weight: 700; color: #1F2937; margin-top: 4px;">3 <span style="font-size: 7px; font-weight: 400; color: #9CA3AF;">ativos</span></div>
        </div>

        <div class="ytc-type-card" style="border-top: 3px solid #3B82F6;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px;">
            <div style="width: 20px; height: 20px; border-radius: 6px; background: rgba(59,130,246,0.1); display: flex; align-items: center; justify-content: center;">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/></svg>
            </div>
            <span class="ytc-type-badge-active">Ativo</span>
          </div>
          <div style="font-size: 9px; font-weight: 600; color: #1F2937;">Atendentes</div>
          <div style="font-size: 7px; color: #9CA3AF;">Respondem clientes 24/7</div>
          <div style="font-size: 10px; font-weight: 700; color: #1F2937; margin-top: 4px;">5 <span style="font-size: 7px; font-weight: 400; color: #9CA3AF;">ativos</span></div>
        </div>

        <div class="ytc-type-card" style="border-top: 3px solid #10B981;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px;">
            <div style="width: 20px; height: 20px; border-radius: 6px; background: rgba(16,185,129,0.1); display: flex; align-items: center; justify-content: center;">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <span class="ytc-type-badge-active">Ativo</span>
          </div>
          <div style="font-size: 9px; font-weight: 600; color: #1F2937;">Automacoes</div>
          <div style="font-size: 7px; color: #9CA3AF;">Executam tarefas em segundo plano</div>
          <div style="font-size: 10px; font-weight: 700; color: #1F2937; margin-top: 4px;">2 <span style="font-size: 7px; font-weight: 400; color: #9CA3AF;">ativos</span></div>
        </div>

        <div class="ytc-type-card" style="border-top: 3px solid #8B5CF6;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px;">
            <div style="width: 20px; height: 20px; border-radius: 6px; background: rgba(139,92,246,0.1); display: flex; align-items: center; justify-content: center;">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <span class="ytc-type-badge-active">Ativo</span>
          </div>
          <div style="font-size: 9px; font-weight: 600; color: #1F2937;">Protetor 24h</div>
          <div style="font-size: 7px; color: #9CA3AF;">Mantem janela do WhatsApp ativa</div>
          <div style="font-size: 10px; font-weight: 700; color: #1F2937; margin-top: 4px;">1 <span style="font-size: 7px; font-weight: 400; color: #9CA3AF;">ativo</span></div>
        </div>
      </div>

      <!-- Agent list -->
      <div class="ytc-agents-header">
        <span style="font-size: 10px; font-weight: 600; color: #1F2937;">Seus Agentes</span>
        <span style="font-size: 8px; color: #8B5CF6; font-weight: 500;">Ver todos →</span>
      </div>

      <div class="ytc-agent-row">
        <div style="width: 24px; height: 24px; border-radius: 6px; background: rgba(59,130,246,0.1); display: flex; align-items: center; justify-content: center;">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/></svg>
        </div>
        <div style="flex: 1;">
          <div style="font-size: 9px; font-weight: 600; color: #1F2937;">SDR Comercial</div>
          <div style="font-size: 7px; color: #9CA3AF;">Atendente</div>
        </div>
        <div style="text-align: right; margin-right: 6px;">
          <div style="font-size: 9px; font-weight: 700; color: #1F2937;">847</div>
          <div style="font-size: 6px; color: #9CA3AF;">interacoes</div>
        </div>
        <div style="text-align: right; margin-right: 6px;">
          <div style="font-size: 9px; font-weight: 700; color: #1F2937;">94%</div>
          <div style="font-size: 6px; color: #9CA3AF;">resolucao</div>
        </div>
        <div class="ytc-online-badge">Online</div>
      </div>

      <div class="ytc-agent-row">
        <div style="width: 24px; height: 24px; border-radius: 6px; background: rgba(245,158,11,0.1); display: flex; align-items: center; justify-content: center;">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3z"/></svg>
        </div>
        <div style="flex: 1;">
          <div style="font-size: 9px; font-weight: 600; color: #1F2937;">Mentor de Vendas</div>
          <div style="font-size: 7px; color: #9CA3AF;">Mentor</div>
        </div>
        <div style="text-align: right; margin-right: 6px;">
          <div style="font-size: 9px; font-weight: 700; color: #1F2937;">312</div>
          <div style="font-size: 6px; color: #9CA3AF;">interacoes</div>
        </div>
        <div style="text-align: right; margin-right: 6px;">
          <div style="font-size: 9px; font-weight: 700; color: #1F2937;">89%</div>
          <div style="font-size: 6px; color: #9CA3AF;">aceitas</div>
        </div>
        <div class="ytc-online-badge">Online</div>
      </div>
    </div>
  </div>
</div>

<style>
  .ytc-frame {
    width: 100%; max-width: 580px; border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.03);
    background: #ffffff; border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
  }
  .ytc-topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px; border-bottom: 1px solid #F3F4F6;
  }
  .ytc-btn-create {
    font-size: 8px; font-weight: 600; color: white;
    padding: 4px 10px; border-radius: 6px; background: #8B5CF6;
  }
  .ytc-body { display: grid; grid-template-columns: 120px 1fr; }

  /* Sidebar */
  .ytc-sidebar { padding: 8px 6px; border-right: 1px solid #F3F4F6; background: #FAFBFC; }
  .ytc-nav-label { font-size: 7px; font-weight: 600; color: #9CA3AF; padding: 4px 6px 2px; }
  .ytc-nav-item {
    display: flex; align-items: center; gap: 5px;
    padding: 4px 6px; border-radius: 5px;
    font-size: 8px; color: #374151;
  }
  .ytc-nav-active { background: rgba(139,92,246,0.08); color: #8B5CF6; font-weight: 600; }
  .ytc-badge-purple {
    margin-left: auto; font-size: 7px; font-weight: 700; color: white;
    background: #8B5CF6; border-radius: 8px; padding: 1px 5px;
  }
  .ytc-badge-gray {
    margin-left: auto; font-size: 7px; font-weight: 600; color: #6B7280;
    background: #F3F4F6; border-radius: 8px; padding: 1px 5px;
  }

  /* Main */
  .ytc-main { padding: 8px; }
  .ytc-hero {
    background: linear-gradient(135deg, #7C3AED, #8B5CF6, #A78BFA);
    border-radius: 10px; padding: 12px; color: white; margin-bottom: 8px;
  }
  .ytc-hero-kpis { display: flex; gap: 16px; }
  .ytc-hero-kpi { text-align: center; }

  /* Types */
  .ytc-types { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 6px; margin-bottom: 10px; }
  .ytc-type-card {
    background: white; border: 1px solid #F3F4F6; border-radius: 8px; padding: 8px;
  }
  .ytc-type-badge-active {
    font-size: 6px; font-weight: 600; color: #059669;
    padding: 1px 5px; border-radius: 4px;
    border: 1px solid rgba(5,150,105,0.2); background: rgba(5,150,105,0.06);
  }

  /* Agents */
  .ytc-agents-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 6px;
  }
  .ytc-agent-row {
    display: flex; align-items: center; gap: 8px;
    padding: 8px; border: 1px solid #F3F4F6; border-radius: 8px; margin-bottom: 4px;
  }
  .ytc-online-badge {
    font-size: 7px; font-weight: 600; color: #059669;
    padding: 2px 8px; border-radius: 10px;
    border: 1px solid rgba(5,150,105,0.2); background: rgba(5,150,105,0.06);
    display: flex; align-items: center; gap: 3px;
  }
  .ytc-online-badge::before {
    content: ''; width: 4px; height: 4px; border-radius: 50%; background: #22C55E;
  }

  @media (max-width: 640px) {
    .ytc-body { grid-template-columns: 1fr; }
    .ytc-sidebar { display: none; }
    .ytc-types { grid-template-columns: 1fr 1fr; }
  }
</style>
