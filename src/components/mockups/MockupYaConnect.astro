---
/** MockupYaConnect — Channel Hub with connected integrations (conversations page) */
---
<div class="ycon-frame">
  <!-- Header -->
  <div class="ycon-header">
    <div style="display: flex; align-items: center; gap: 8px;">
      <div style="width: 28px; height: 28px; border-radius: 8px; background: linear-gradient(135deg, #3B82F6, #60A5FA); display: flex; align-items: center; justify-content: center;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9l-7-7z"/><path d="M13 2v7h7"/></svg>
      </div>
      <div>
        <div style="font-size: 13px; font-weight: 700; color: #1F2937;">yaConnect</div>
        <div style="font-size: 9px; color: #9CA3AF;">Hub de canais — todos convergem aqui</div>
      </div>
    </div>
    <div class="ycon-badge-channels">
      <span style="font-size: 14px; font-weight: 700; color: #3B82F6;">5</span>
      <span style="font-size: 8px; color: #6B7280;">canais<br/>ativos</span>
    </div>
  </div>

  <!-- Active Channels -->
  <div class="ycon-channels">
    <!-- WhatsApp -->
    <div class="ycon-channel">
      <div class="ycon-ch-icon" style="background: #25D366;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2z"/></svg>
      </div>
      <div class="ycon-ch-info">
        <div class="ycon-ch-name">WhatsApp Business API</div>
        <div class="ycon-ch-desc">BSP oficial · 3 números conectados</div>
      </div>
      <div class="ycon-ch-stats">
        <div class="ycon-ch-stat-num">2.4k</div>
        <div class="ycon-ch-stat-label">msg/dia</div>
      </div>
      <div class="ycon-status-on"></div>
    </div>

    <!-- Instagram -->
    <div class="ycon-channel">
      <div class="ycon-ch-icon" style="background: linear-gradient(135deg, #833AB4, #E1306C, #F77737);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><rect x="2" y="2" width="20" height="20" rx="5" fill="none" stroke="white" stroke-width="2"/><circle cx="12" cy="12" r="5" fill="none" stroke="white" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.5" fill="white"/></svg>
      </div>
      <div class="ycon-ch-info">
        <div class="ycon-ch-name">Instagram DM</div>
        <div class="ycon-ch-desc">@logtech.oficial · DMs + Comentários</div>
      </div>
      <div class="ycon-ch-stats">
        <div class="ycon-ch-stat-num">380</div>
        <div class="ycon-ch-stat-label">msg/dia</div>
      </div>
      <div class="ycon-status-on"></div>
    </div>

    <!-- Messenger -->
    <div class="ycon-channel">
      <div class="ycon-ch-icon" style="background: #0084FF;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M12 2C6.36 2 2 6.13 2 11.7c0 2.91 1.2 5.42 3.15 7.18V22l3.04-1.67c.86.24 1.78.37 2.81.37 5.64 0 10-3.93 10-9.7C21 6.13 17.64 2 12 2zm1.06 13.06l-2.55-2.73L5.2 15.2l5.73-6.08 2.55 2.73 5.31-2.87-5.73 6.08z"/></svg>
      </div>
      <div class="ycon-ch-info">
        <div class="ycon-ch-name">Messenger</div>
        <div class="ycon-ch-desc">Facebook Page · Roteamento ativo</div>
      </div>
      <div class="ycon-ch-stats">
        <div class="ycon-ch-stat-num">125</div>
        <div class="ycon-ch-stat-label">msg/dia</div>
      </div>
      <div class="ycon-status-on"></div>
    </div>

    <!-- Email / Gmail -->
    <div class="ycon-channel">
      <div class="ycon-ch-icon" style="background: #EA4335;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" fill="none" stroke="white" stroke-width="2"/><path d="M22 6l-10 7L2 6" fill="none" stroke="white" stroke-width="2"/></svg>
      </div>
      <div class="ycon-ch-info">
        <div class="ycon-ch-name">Email (Gmail)</div>
        <div class="ycon-ch-desc">contato@logtech.com.br · IMAP sync</div>
      </div>
      <div class="ycon-ch-stats">
        <div class="ycon-ch-stat-num">89</div>
        <div class="ycon-ch-stat-label">msg/dia</div>
      </div>
      <div class="ycon-status-on"></div>
    </div>

    <!-- Widget -->
    <div class="ycon-channel">
      <div class="ycon-ch-icon" style="background: linear-gradient(135deg, #20B2AA, #14B8A6);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      </div>
      <div class="ycon-ch-info">
        <div class="ycon-ch-name">Widget Inteligente</div>
        <div class="ycon-ch-desc">IA nativa · 4 LPs + site principal</div>
      </div>
      <div class="ycon-ch-stats">
        <div class="ycon-ch-stat-num">210</div>
        <div class="ycon-ch-stat-label">msg/dia</div>
      </div>
      <div class="ycon-status-on"></div>
    </div>
  </div>

  <!-- Coming soon -->
  <div class="ycon-coming">
    <div style="font-size: 9px; font-weight: 600; color: #6B7280; margin-bottom: 8px;">Em breve</div>
    <div class="ycon-coming-row">
      <div class="ycon-coming-item">
        <div class="ycon-coming-icon">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-7.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.88-2.89 2.89 2.89 0 012.88-2.89c.28 0 .54.04.79.12V9.01a6.36 6.36 0 00-.79-.05 6.3 6.3 0 00-6.3 6.3A6.3 6.3 0 005.49 22a6.3 6.3 0 006.3-6.3V8.22a8.28 8.28 0 004.85 1.56h.8V6.69h-.85z"/></svg>
        </div>
        <span>TikTok</span>
      </div>
      <div class="ycon-coming-item">
        <div class="ycon-coming-icon">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M22.46 6c-.85.38-1.78.64-2.73.76 1-.6 1.76-1.54 2.12-2.67-.93.55-1.96.95-3.06 1.17A4.84 4.84 0 0015.46 4c-2.65 0-4.81 2.15-4.81 4.81 0 .38.04.75.13 1.1A13.67 13.67 0 013.1 4.9a4.82 4.82 0 001.49 6.42A4.75 4.75 0 012.4 10.7v.06c0 2.33 1.66 4.28 3.86 4.72-.4.11-.83.17-1.27.17-.31 0-.61-.03-.91-.08a4.81 4.81 0 004.49 3.34A9.65 9.65 0 012 20.41a13.6 13.6 0 007.38 2.16c8.85 0 13.69-7.33 13.69-13.69 0-.21 0-.42-.02-.63A9.77 9.77 0 0024 6.55a9.56 9.56 0 01-2.54.7z"/></svg>
        </div>
        <span>X (Twitter)</span>
      </div>
      <div class="ycon-coming-item">
        <div class="ycon-coming-icon">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
        </div>
        <span>Discord</span>
      </div>
      <div class="ycon-coming-item">
        <div class="ycon-coming-icon">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        </div>
        <span>Telegram</span>
      </div>
      <div class="ycon-coming-item">
        <div class="ycon-coming-icon">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/></svg>
        </div>
        <span>RCS</span>
      </div>
    </div>
  </div>

  <!-- Footer: convergence visual -->
  <div class="ycon-footer">
    <div class="ycon-converge">
      <div class="ycon-converge-lines">
        <div class="ycon-cline" style="background: #25D366;"></div>
        <div class="ycon-cline" style="background: #E1306C;"></div>
        <div class="ycon-cline" style="background: #0084FF;"></div>
        <div class="ycon-cline" style="background: #EA4335;"></div>
        <div class="ycon-cline" style="background: #20B2AA;"></div>
      </div>
      <div class="ycon-converge-center">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </div>
      <div class="ycon-converge-label">1 inbox unificado</div>
    </div>
  </div>
</div>

<style>
  .ycon-frame {
    width: 100%; max-width: 540px; border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.03);
    background: #ffffff; border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
  }

  .ycon-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px; border-bottom: 1px solid #F3F4F6;
  }
  .ycon-badge-channels {
    display: flex; align-items: center; gap: 4px;
    padding: 4px 10px; border-radius: 10px;
    background: rgba(59,130,246,0.06); border: 1px solid rgba(59,130,246,0.15);
  }

  /* Channels */
  .ycon-channels {
    padding: 6px 0;
  }
  .ycon-channel {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    transition: background 0.15s;
  }
  .ycon-channel:hover { background: #FAFBFC; }
  .ycon-ch-icon {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .ycon-ch-info { flex: 1; min-width: 0; }
  .ycon-ch-name { font-size: 11px; font-weight: 600; color: #1F2937; }
  .ycon-ch-desc { font-size: 9px; color: #9CA3AF; margin-top: 1px; }
  .ycon-ch-stats { text-align: right; flex-shrink: 0; }
  .ycon-ch-stat-num { font-size: 12px; font-weight: 700; color: #1F2937; }
  .ycon-ch-stat-label { font-size: 7px; color: #9CA3AF; }
  .ycon-status-on {
    width: 8px; height: 8px; border-radius: 50%;
    background: #22C55E; flex-shrink: 0;
    box-shadow: 0 0 0 2px rgba(34,197,94,0.2);
  }

  /* Coming soon */
  .ycon-coming {
    padding: 10px 14px; border-top: 1px solid #F3F4F6;
  }
  .ycon-coming-row {
    display: flex; gap: 6px; flex-wrap: wrap;
  }
  .ycon-coming-item {
    display: flex; align-items: center; gap: 4px;
    padding: 4px 10px; border-radius: 8px;
    background: #F9FAFB; border: 1px dashed #E5E7EB;
    font-size: 9px; color: #9CA3AF;
  }
  .ycon-coming-icon {
    width: 18px; height: 18px; display: flex;
    align-items: center; justify-content: center;
  }

  /* Footer convergence */
  .ycon-footer {
    padding: 12px 14px; border-top: 1px solid #F3F4F6;
    background: #FAFBFC;
  }
  .ycon-converge {
    display: flex; align-items: center; gap: 10px;
    justify-content: center;
  }
  .ycon-converge-lines {
    display: flex; flex-direction: column; gap: 3px;
  }
  .ycon-cline {
    width: 40px; height: 3px; border-radius: 2px; opacity: 0.6;
  }
  .ycon-converge-center {
    width: 32px; height: 32px; border-radius: 50%;
    background: linear-gradient(135deg, #3B82F6, #20B2AA);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 8px rgba(59,130,246,0.3);
  }
  .ycon-converge-label {
    font-size: 11px; font-weight: 600; color: #3B82F6;
  }
</style>
