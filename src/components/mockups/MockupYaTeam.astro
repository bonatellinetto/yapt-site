---
/** MockupYaTeam — AI Agents + Team Management (static HTML/CSS mockup) */
---
<div class="mockup-frame">
  <!-- Top bar -->
  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #EF4444;"></div>
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #F59E0B;"></div>
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #22C55E;"></div>
    <div style="flex:1;"></div>
    <div style="font-size: 10px; font-weight: 600; color: #8B5CF6; font-family: Poppins, sans-serif;">yaTeam</div>
  </div>

  <!-- Header -->
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px;">
    <div>
      <div style="font-size: 12px; font-weight: 600; color: #1F2937; font-family: Poppins, sans-serif;">Agentes Ativos</div>
      <div style="font-size: 9px; color: #9CA3AF;">3 IA + 4 humanos online</div>
    </div>
    <div style="display: flex; gap: -4px;">
      <div style="width: 22px; height: 22px; border-radius: 50%; background: linear-gradient(135deg, #8B5CF6, #6D28D9); border: 2px solid white; display: flex; align-items: center; justify-content: center;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="white"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
      </div>
    </div>
  </div>

  <!-- Agent cards -->
  <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px;">
    <!-- AI Agent -->
    <div style="display: flex; align-items: center; gap: 10px; background: linear-gradient(135deg, rgba(139,92,246,0.06), rgba(139,92,246,0.02)); border: 1px solid rgba(139,92,246,0.1); border-radius: 10px; padding: 10px;">
      <div style="width: 30px; height: 30px; border-radius: 10px; background: linear-gradient(135deg, #8B5CF6, #7C3AED); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
      </div>
      <div style="flex: 1; min-width: 0;">
        <div style="display: flex; align-items: center; gap: 4px;">
          <div style="font-size: 10px; font-weight: 600; color: #1F2937;">yaAgent Sales</div>
          <div style="font-size: 7px; padding: 1px 5px; border-radius: 8px; background: rgba(139,92,246,0.1); color: #7C3AED; font-weight: 600;">IA</div>
        </div>
        <div style="font-size: 8px; color: #9CA3AF;">12 conversas ativas &middot; 94% resolucao</div>
      </div>
      <div style="width: 6px; height: 6px; border-radius: 50%; background: #22C55E; animation: mockup-pulse 2s ease-in-out infinite;"></div>
    </div>

    <!-- AI Mentor -->
    <div style="display: flex; align-items: center; gap: 10px; background: linear-gradient(135deg, rgba(139,92,246,0.06), rgba(139,92,246,0.02)); border: 1px solid rgba(139,92,246,0.1); border-radius: 10px; padding: 10px;">
      <div style="width: 30px; height: 30px; border-radius: 10px; background: linear-gradient(135deg, #A78BFA, #8B5CF6); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/></svg>
      </div>
      <div style="flex: 1; min-width: 0;">
        <div style="display: flex; align-items: center; gap: 4px;">
          <div style="font-size: 10px; font-weight: 600; color: #1F2937;">yaMentor</div>
          <div style="font-size: 7px; padding: 1px 5px; border-radius: 8px; background: rgba(139,92,246,0.1); color: #7C3AED; font-weight: 600;">COACH</div>
        </div>
        <div style="font-size: 8px; color: #9CA3AF;">Treinando 4 agentes &middot; 3 dicas enviadas</div>
      </div>
      <div style="width: 6px; height: 6px; border-radius: 50%; background: #22C55E; animation: mockup-pulse 2s ease-in-out infinite;"></div>
    </div>

    <!-- Human agent -->
    <div style="display: flex; align-items: center; gap: 10px; background: #F9FAFB; border: 1px solid rgba(0,0,0,0.05); border-radius: 10px; padding: 10px;">
      <div style="width: 30px; height: 30px; border-radius: 50%; background: linear-gradient(135deg, #60A5FA, #3B82F6); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 11px; font-weight: 600; color: white;">ML</div>
      <div style="flex: 1; min-width: 0;">
        <div style="font-size: 10px; font-weight: 600; color: #1F2937;">Marina Lima</div>
        <div style="font-size: 8px; color: #9CA3AF;">5 conversas &middot; SLA OK &middot; NPS 4.8</div>
      </div>
      <div style="width: 6px; height: 6px; border-radius: 50%; background: #22C55E;"></div>
    </div>

    <!-- Human agent 2 -->
    <div style="display: flex; align-items: center; gap: 10px; background: #F9FAFB; border: 1px solid rgba(0,0,0,0.05); border-radius: 10px; padding: 10px;">
      <div style="width: 30px; height: 30px; border-radius: 50%; background: linear-gradient(135deg, #F472B6, #EC4899); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 11px; font-weight: 600; color: white;">RS</div>
      <div style="flex: 1; min-width: 0;">
        <div style="font-size: 10px; font-weight: 600; color: #1F2937;">Rafael Santos</div>
        <div style="font-size: 8px; color: #9CA3AF;">3 conversas &middot; SLA Risk &middot; NPS 4.5</div>
      </div>
      <div style="width: 6px; height: 6px; border-radius: 50%; background: #F59E0B;"></div>
    </div>
  </div>

  <!-- Mentor suggestion -->
  <div style="background: linear-gradient(135deg, rgba(139,92,246,0.05), rgba(167,139,250,0.05)); border: 1px dashed rgba(139,92,246,0.2); border-radius: 10px; padding: 8px 10px;">
    <div style="font-size: 8px; font-weight: 600; color: #7C3AED; margin-bottom: 3px;">Sugestao do Mentor</div>
    <div style="font-size: 8px; color: #6B7280; line-height: 1.4;">"Rafael, tente oferecer o plano anual — o cliente ja demonstrou interesse em longo prazo."</div>
  </div>
</div>

<style>
  .mockup-frame {
    width: 100%; max-width: 480px; border-radius: 20px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.08);
    background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
    border: 1px solid rgba(0,0,0,0.06);
    padding: 18px; overflow: hidden;
  }
  @keyframes mockup-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>
