---
/** MockupYaTeam — Mentor de Vendas panel (replicates real product UI) */
---
<div class="yateam-frame">
  <!-- Top status bar -->
  <div class="yateam-topbar">
    <div class="yateam-badge-lead">
      <div class="yateam-dot-green"></div>
      Lead
    </div>
    <div class="yateam-pipeline">
      <span class="yateam-pipe-active">LEAD</span>
      <span class="yateam-pipe">MQL</span>
      <span class="yateam-pipe">SAL</span>
      <span class="yateam-pipe">SQL</span>
      <span class="yateam-pipe">OPORT</span>
    </div>
    <div class="yateam-badge-mentor">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3z"/></svg>
      Mentor
    </div>
    <div class="yateam-badge-status">Aberta</div>
    <div class="yateam-badge-ia">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#8B5CF6" stroke-width="2"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z"/></svg>
      IA Ativa
    </div>
    <div class="yateam-badge-sla">
      <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
      21h restantes
    </div>
  </div>

  <!-- Main content: conversation + mentor panel -->
  <div class="yateam-body">
    <!-- Left: conversation preview (partial) -->
    <div class="yateam-conv">
      <!-- Sidebar icons -->
      <div class="yateam-sidebar-icons">
        <div class="yateam-sidebar-icon yateam-sidebar-icon-active">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3z"/></svg>
        </div>
        <div class="yateam-sidebar-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.8"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/></svg></div>
        <div class="yateam-sidebar-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg></div>
        <div class="yateam-sidebar-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
        <div class="yateam-sidebar-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.8"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
        <div class="yateam-sidebar-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.8"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
        <div class="yateam-sidebar-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.8"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/></svg></div>
        <div class="yateam-sidebar-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.8"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></div>
      </div>

      <!-- Chat messages (partial, like the screenshot) -->
      <div class="yateam-chat">
        <!-- IA message (left, white) -->
        <div class="yateam-chat-label">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="#20B2AA"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
          <span style="font-size: 8px; color: #20B2AA; font-weight: 600;">IA</span>
        </div>
        <div class="yateam-bubble-ia">
          <div style="font-size: 9px; color: #1F2937; line-height: 1.5;">
            Oi! Vi que voce tem interesse no plano Pro. Temos <strong>condicoes especiais</strong> para operacoes acima de 10 atendentes. Posso te contar mais?
          </div>
          <div style="font-size: 7px; color: #9CA3AF; margin-top: 4px;">18:41 <span style="opacity: 0.7;">✓✓</span></div>
        </div>

        <!-- Client message (right, green) -->
        <div class="yateam-bubble-client">
          <div style="font-size: 9px; color: #1F2937; line-height: 1.5;">
            Sim! Temos 25 pessoas no time e um budget entre R$2-5k/mes. Quero entender melhor.
          </div>
          <div style="font-size: 7px; color: #6B7280; text-align: right; margin-top: 4px;">18:44</div>
        </div>

        <!-- IA message (left, white) -->
        <div class="yateam-bubble-ia">
          <div style="font-size: 9px; color: #1F2937; line-height: 1.5;">
            Perfeito! Com 25 atendentes, o plano Pro com IA fica ideal. Qual o nome da sua empresa pra eu montar uma proposta?
          </div>
          <div style="font-size: 7px; color: #9CA3AF; margin-top: 4px;">18:47 <span style="opacity: 0.7;">✓✓</span></div>
        </div>
        <!-- Send button -->
        <div style="display: flex; justify-content: center; margin-top: 12px;">
          <div style="width: 28px; height: 28px; border-radius: 50%; background: #E5E7EB; display: flex; align-items: center; justify-content: center;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Mentor panel -->
    <div class="yateam-mentor">
      <!-- Mentor header -->
      <div class="yateam-mentor-header">
        <div style="width: 32px; height: 32px; border-radius: 10px; background: linear-gradient(135deg, #20B2AA, #14B8A6); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/></svg>
        </div>
        <div style="flex: 1; min-width: 0;">
          <div style="display: flex; align-items: center; gap: 6px;">
            <div style="font-size: 12px; font-weight: 700; color: #1F2937; font-family: Poppins, sans-serif;">Mentor de Vendas</div>
            <div style="font-size: 7px; padding: 2px 6px; border-radius: 4px; background: rgba(249,115,22,0.1); color: #EA580C; font-weight: 600;">Mentor</div>
          </div>
          <div style="display: flex; align-items: center; gap: 4px; margin-top: 2px;">
            <div style="width: 5px; height: 5px; border-radius: 50%; background: #22C55E;"></div>
            <div style="font-size: 8px; color: #9CA3AF;">InsideSales Comercial</div>
          </div>
        </div>
      </div>

      <!-- Mentor icon centered -->
      <div style="display: flex; flex-direction: column; align-items: center; margin: 20px 0 16px;">
        <div style="width: 48px; height: 48px; border-radius: 14px; background: rgba(245,158,11,0.1); display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="#F59E0B"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/></svg>
        </div>
        <div style="font-size: 13px; font-weight: 700; color: #1F2937; font-family: Poppins, sans-serif; text-align: center;">Mentor de Vendas</div>
        <div style="font-size: 9px; color: #9CA3AF; text-align: center; margin-top: 4px; max-width: 180px; line-height: 1.4;">Pergunte sobre estrategias de venda, objecoes ou proximos passos</div>
      </div>

      <!-- Suggestions label -->
      <div style="font-size: 8px; font-weight: 600; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.05em; text-align: center; margin-bottom: 8px;">Sugestoes</div>

      <!-- Suggestion cards -->
      <div style="display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px;">
        <div class="yateam-suggestion">Como posso qualificar melhor esse lead?</div>
        <div class="yateam-suggestion">Qual objecao devo antecipar?</div>
        <div class="yateam-suggestion">Qual proximo passo sugerir?</div>
      </div>

      <!-- Input field -->
      <div class="yateam-mentor-input">
        <div style="flex: 1; font-size: 9px; color: #9CA3AF;">Pergunte ao Mentor...</div>
        <div style="width: 24px; height: 24px; border-radius: 50%; background: linear-gradient(135deg, #D1D5DB, #9CA3AF); display: flex; align-items: center; justify-content: center;">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="white"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .yateam-frame {
    width: 100%; max-width: 520px; border-radius: 16px;
    box-shadow: 0 12px 48px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.04);
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
  }

  /* Top bar */
  .yateam-topbar {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 12px; border-bottom: 1px solid #F3F4F6;
    overflow-x: auto; white-space: nowrap;
  }
  .yateam-badge-lead {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 9px; font-weight: 600; color: #22C55E;
    padding: 3px 10px; border-radius: 20px; border: 1px solid rgba(34,197,94,0.2);
    flex-shrink: 0;
  }
  .yateam-dot-green { width: 5px; height: 5px; border-radius: 50%; background: #22C55E; }
  .yateam-pipeline {
    display: flex; align-items: center; gap: 1px; flex-shrink: 0;
  }
  .yateam-pipe, .yateam-pipe-active {
    font-size: 6px; font-weight: 700; color: #D1D5DB; letter-spacing: 0.04em; padding: 0 3px;
  }
  .yateam-pipe-active { color: #1F2937; }
  .yateam-badge-mentor {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 9px; font-weight: 600; color: white;
    padding: 3px 10px; border-radius: 20px; background: #F59E0B; flex-shrink: 0;
  }
  .yateam-badge-status {
    font-size: 8px; font-weight: 500; color: #6B7280;
    padding: 3px 8px; border-radius: 6px; border: 1px solid #E5E7EB; flex-shrink: 0;
  }
  .yateam-badge-ia {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 8px; font-weight: 600; color: #8B5CF6;
    padding: 3px 8px; border-radius: 20px; border: 1px solid rgba(139,92,246,0.2); flex-shrink: 0;
  }
  .yateam-badge-sla {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 8px; font-weight: 600; color: #22C55E;
    padding: 3px 8px; border-radius: 20px; border: 1px solid rgba(34,197,94,0.2); flex-shrink: 0;
  }

  /* Body */
  .yateam-body {
    display: grid; grid-template-columns: 1fr 1fr; min-height: 300px;
  }

  /* Conversation side */
  .yateam-conv {
    display: grid; grid-template-columns: 36px 1fr;
    border-right: 1px solid #F3F4F6;
  }
  .yateam-sidebar-icons {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    padding: 10px 4px; border-right: 1px solid #F3F4F6;
  }
  .yateam-sidebar-icon {
    width: 26px; height: 26px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s;
  }
  .yateam-sidebar-icon-active {
    background: #20B2AA;
  }
  .yateam-chat {
    padding: 10px; display: flex; flex-direction: column;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 23px, rgba(0,0,0,0.015) 23px, rgba(0,0,0,0.015) 24px
    );
  }
  .yateam-chat-label {
    display: flex; align-items: center; gap: 3px; margin-bottom: 6px;
  }
  .yateam-bubble-ia {
    background: #F3F4F6; border-radius: 10px 0 10px 10px;
    padding: 8px 10px; margin-bottom: 6px; max-width: 90%; align-self: flex-end;
  }
  .yateam-bubble-client {
    background: #D1FAE5; border-radius: 0 10px 10px 10px;
    padding: 8px 10px; margin-bottom: 6px; max-width: 90%; align-self: flex-start;
  }

  /* Mentor panel */
  .yateam-mentor {
    display: flex; flex-direction: column; padding: 12px;
  }
  .yateam-mentor-header {
    display: flex; align-items: center; gap: 10px;
    padding-bottom: 10px; border-bottom: 1px solid #F3F4F6;
  }
  .yateam-suggestion {
    font-size: 9px; color: #374151; padding: 8px 12px;
    border: 1px solid #E5E7EB; border-radius: 8px;
    line-height: 1.3; cursor: default;
  }
  .yateam-mentor-input {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 12px; border: 1px solid #E5E7EB; border-radius: 24px;
    margin-top: auto;
  }

  /* Mobile: stack vertically */
  @media (max-width: 640px) {
    .yateam-body { grid-template-columns: 1fr; }
    .yateam-conv { display: none; }
    .yateam-mentor { min-height: 280px; }
  }
</style>
