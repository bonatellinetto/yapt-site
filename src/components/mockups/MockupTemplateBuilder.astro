---
/** MockupTemplateBuilder — WhatsApp Template Builder (Marketing template creation UI) */
---
<div class="tb-frame">
  <!-- Header bar -->
  <div class="tb-header">
    <div class="tb-header-left">
      <div class="tb-wa-icon">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492l4.636-1.467A11.932 11.932 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-2.24 0-4.31-.735-5.981-1.977l-.429-.312-2.748.87.898-2.686-.343-.457A9.708 9.708 0 012.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75z"/></svg>
      </div>
      <div>
        <div class="tb-title">Template Builder</div>
        <div class="tb-subtitle">Criar novo template</div>
      </div>
    </div>
    <div class="tb-header-right">
      <span class="tb-badge-green">Marketing</span>
      <span class="tb-badge-amber">Rascunho</span>
    </div>
  </div>

  <!-- Template info row -->
  <div class="tb-info-row">
    <span class="tb-info-item">Nome: <strong>black_friday_2026</strong></span>
    <span class="tb-info-sep">|</span>
    <span class="tb-info-item">Idioma: <strong>pt_BR</strong></span>
    <span class="tb-info-sep">|</span>
    <span class="tb-info-item">Categoria: <strong>Marketing</strong></span>
  </div>

  <!-- Two-column layout -->
  <div class="tb-columns">
    <!-- LEFT: Editor -->
    <div class="tb-editor">
      <!-- Header section -->
      <div class="tb-section">
        <div class="tb-section-label">Header</div>
        <div class="tb-pills">
          <span class="tb-pill">Nenhum</span>
          <span class="tb-pill">Texto</span>
          <span class="tb-pill tb-pill-active">Imagem</span>
          <span class="tb-pill">Video</span>
          <span class="tb-pill">Documento</span>
        </div>
        <div class="tb-upload-box">📷 black-friday-banner.jpg (320×180)</div>
      </div>

      <!-- Body section -->
      <div class="tb-section">
        <div class="tb-section-label">Body</div>
        <div class="tb-textarea">Ola &#123;&#123;1&#125;&#125;! 🎉<br/><br/>A Black Friday chegou na &#123;&#123;2&#125;&#125;!<br/><br/>🔥 Ate 60% OFF em todos os planos<br/>⏰ Valido ate 30/11<br/>💳 Parcelamento em ate 12x<br/><br/>Nao perca essa oportunidade!</div>
        <div class="tb-vars-row">
          <span class="tb-var-badge">&#123;&#123;1&#125;&#125; = nome_contato</span>
          <span class="tb-var-badge">&#123;&#123;2&#125;&#125; = nome_empresa</span>
        </div>
      </div>

      <!-- Footer section -->
      <div class="tb-section">
        <div class="tb-section-label">Footer</div>
        <div class="tb-input">Responda SAIR para nao receber mais</div>
      </div>

      <!-- Buttons section -->
      <div class="tb-section">
        <div class="tb-section-label">Botoes</div>
        <div class="tb-button-row">
          <span class="tb-btn-type">Quick Reply</span>
          <span class="tb-btn-text">🛒 Quero aproveitar</span>
        </div>
        <div class="tb-button-row">
          <span class="tb-btn-type">URL</span>
          <span class="tb-btn-text">Ver ofertas</span>
          <span class="tb-btn-url">https://loja.com/bf</span>
        </div>
      </div>
    </div>

    <!-- RIGHT: Phone Preview -->
    <div class="tb-preview">
      <div class="tb-phone">
        <!-- Phone header -->
        <div class="tb-phone-header">
          <div class="tb-phone-avatar">T</div>
          <div>
            <div class="tb-phone-name">TechStore</div>
            <div class="tb-phone-status">online</div>
          </div>
        </div>
        <!-- Chat area -->
        <div class="tb-phone-chat">
          <div class="tb-bubble">
            <!-- Image placeholder -->
            <div class="tb-bubble-img">📷</div>
            <!-- Message -->
            <div class="tb-bubble-text">
              Ola <strong>Mariana</strong>! 🎉<br/><br/>
              A Black Friday chegou na <strong>TechStore</strong>!<br/><br/>
              🔥 Ate 60% OFF em todos os planos<br/>
              ⏰ Valido ate 30/11<br/>
              💳 Parcelamento em ate 12x<br/><br/>
              Nao perca essa oportunidade!
            </div>
            <!-- Footer -->
            <div class="tb-bubble-footer">Responda SAIR para nao receber mais</div>
            <!-- Timestamp -->
            <div class="tb-bubble-time">18:42 ✓✓</div>
          </div>
          <!-- Quick reply buttons -->
          <div class="tb-reply-buttons">
            <div class="tb-reply-btn">🛒 Quero aproveitar</div>
            <div class="tb-reply-btn">
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#20B2AA" stroke-width="2.5" style="margin-right:3px;vertical-align:middle;"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              Ver ofertas
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="tb-bottom">
    <div class="tb-sync-btn">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
      Sync com Meta
    </div>
    <span class="tb-status-amber">Status: Aguardando aprovacao</span>
    <div class="tb-toggle-row">
      <span class="tb-toggle-label">A/B Test</span>
      <div class="tb-toggle-track">
        <div class="tb-toggle-thumb"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .tb-frame {
    max-width: 540px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.10), 0 1px 4px rgba(0,0,0,0.06);
    overflow: hidden;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 9px;
    color: #1F2937;
    line-height: 1.4;
  }

  /* Header */
  .tb-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid #F3F4F6;
  }
  .tb-header-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .tb-wa-icon {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: linear-gradient(135deg, #25D366, #128C7E);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .tb-title {
    font-size: 10px;
    font-weight: 700;
    color: #111827;
  }
  .tb-subtitle {
    font-size: 7px;
    color: #9CA3AF;
    margin-top: 1px;
  }
  .tb-header-right {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .tb-badge-green {
    font-size: 7px;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 8px;
    background: rgba(37,211,102,0.12);
    color: #128C7E;
  }
  .tb-badge-amber {
    font-size: 7px;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 8px;
    background: rgba(245,158,11,0.12);
    color: #B45309;
  }

  /* Info row */
  .tb-info-row {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    background: #F9FAFB;
    border-bottom: 1px solid #F3F4F6;
    font-size: 8px;
    color: #6B7280;
  }
  .tb-info-item strong {
    color: #374151;
    font-weight: 600;
  }
  .tb-info-sep {
    color: #D1D5DB;
  }

  /* Columns */
  .tb-columns {
    display: flex;
    gap: 0;
    min-height: 320px;
  }

  /* Editor */
  .tb-editor {
    flex: 0 0 55%;
    padding: 10px 12px;
    border-right: 1px solid #F3F4F6;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .tb-section {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .tb-section-label {
    font-size: 8px;
    font-weight: 700;
    color: #374151;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Pills */
  .tb-pills {
    display: flex;
    gap: 3px;
    flex-wrap: wrap;
  }
  .tb-pill {
    font-size: 7px;
    padding: 2px 7px;
    border-radius: 6px;
    background: #F3F4F6;
    color: #6B7280;
    font-weight: 500;
  }
  .tb-pill-active {
    background: rgba(32,178,170,0.15);
    color: #0D9488;
    font-weight: 600;
  }

  /* Upload box */
  .tb-upload-box {
    border: 1.5px dashed #D1D5DB;
    border-radius: 8px;
    padding: 10px;
    text-align: center;
    font-size: 8px;
    color: #9CA3AF;
    background: #FAFAFA;
  }

  /* Textarea */
  .tb-textarea {
    background: #F9FAFB;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    padding: 8px 9px;
    font-size: 8px;
    color: #374151;
    line-height: 1.5;
    min-height: 80px;
  }

  /* Variables */
  .tb-vars-row {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }
  .tb-var-badge {
    font-size: 7px;
    font-weight: 500;
    padding: 2px 6px;
    border-radius: 6px;
    background: rgba(32,178,170,0.1);
    color: #0D9488;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }

  /* Input */
  .tb-input {
    background: #fff;
    border: 1px solid #E5E7EB;
    border-radius: 6px;
    padding: 5px 8px;
    font-size: 8px;
    color: #374151;
  }

  /* Button rows */
  .tb-button-row {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 4px 0;
    border-bottom: 1px solid #F3F4F6;
  }
  .tb-button-row:last-child {
    border-bottom: none;
  }
  .tb-btn-type {
    font-size: 7px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 4px;
    background: #EEF2FF;
    color: #4F46E5;
    white-space: nowrap;
  }
  .tb-btn-text {
    font-size: 8px;
    color: #374151;
    font-weight: 500;
  }
  .tb-btn-url {
    font-size: 7px;
    color: #9CA3AF;
    font-family: 'SF Mono', 'Fira Code', monospace;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Preview */
  .tb-preview {
    flex: 0 0 45%;
    padding: 10px;
    background: #F3F4F6;
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }
  .tb-phone {
    width: 100%;
    max-width: 200px;
    border-radius: 14px;
    overflow: hidden;
    background: #ECE5DD;
    box-shadow: 0 2px 12px rgba(0,0,0,0.12);
  }
  .tb-phone-header {
    background: linear-gradient(135deg, #128C7E, #075E54);
    padding: 8px 10px;
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .tb-phone-avatar {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tb-phone-name {
    font-size: 9px;
    font-weight: 600;
    color: #fff;
  }
  .tb-phone-status {
    font-size: 7px;
    color: rgba(255,255,255,0.7);
  }

  /* Chat */
  .tb-phone-chat {
    padding: 8px 7px;
    min-height: 220px;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .tb-bubble {
    background: #fff;
    border-radius: 0 10px 10px 10px;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(0,0,0,0.06);
    max-width: 95%;
  }
  .tb-bubble-img {
    width: 100%;
    height: 70px;
    background: #E5E7EB;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: #9CA3AF;
    border-radius: 0 10px 0 0;
  }
  .tb-bubble-text {
    padding: 6px 8px 3px;
    font-size: 7.5px;
    color: #1F2937;
    line-height: 1.45;
  }
  .tb-bubble-footer {
    padding: 0 8px 3px;
    font-size: 6.5px;
    color: #9CA3AF;
    font-style: italic;
  }
  .tb-bubble-time {
    text-align: right;
    padding: 0 8px 5px;
    font-size: 6px;
    color: #9CA3AF;
  }

  /* Reply buttons */
  .tb-reply-buttons {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-top: 2px;
  }
  .tb-reply-btn {
    background: #fff;
    border-radius: 8px;
    padding: 5px 8px;
    text-align: center;
    font-size: 7.5px;
    font-weight: 500;
    color: #20B2AA;
    box-shadow: 0 1px 2px rgba(0,0,0,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Bottom bar */
  .tb-bottom {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    border-top: 1px solid #F3F4F6;
    background: #FAFAFA;
  }
  .tb-sync-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 6px;
    background: #20B2AA;
    color: #fff;
    font-size: 8px;
    font-weight: 600;
    white-space: nowrap;
  }
  .tb-status-amber {
    font-size: 7px;
    font-weight: 500;
    color: #B45309;
    background: rgba(245,158,11,0.1);
    padding: 2px 7px;
    border-radius: 6px;
    white-space: nowrap;
  }
  .tb-toggle-row {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-left: auto;
  }
  .tb-toggle-label {
    font-size: 7px;
    font-weight: 500;
    color: #6B7280;
    white-space: nowrap;
  }
  .tb-toggle-track {
    width: 22px;
    height: 12px;
    border-radius: 6px;
    background: #D1D5DB;
    position: relative;
  }
  .tb-toggle-thumb {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #fff;
    position: absolute;
    top: 1px;
    left: 1px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.15);
  }
</style>
