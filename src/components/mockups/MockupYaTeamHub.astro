---
/** MockupYaTeamHub — yaTeam Central de Criação de IAs (replicates real product UI) */
---
<div class="yth-frame">
  <div class="yth-body">
    <!-- Left sidebar -->
    <div class="yth-sidebar">
      <!-- yaTeam header -->
      <div style="display: flex; align-items: center; gap: 6px; padding: 10px 10px 8px;">
        <div style="width: 24px; height: 24px; border-radius: 8px; background: linear-gradient(135deg, #8B5CF6, #7C3AED); display: flex; align-items: center; justify-content: center;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
        </div>
        <div>
          <div style="font-size: 10px; font-weight: 700; color: #1F2937; font-family: Poppins, sans-serif;">yaTeam</div>
          <div style="font-size: 6px; color: #9CA3AF;">Central de Criacao</div>
        </div>
      </div>

      <!-- Visão Geral -->
      <div class="yth-section-label">VISAO GERAL</div>
      <div class="yth-nav-item yth-nav-active">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        Overview
      </div>

      <!-- Agentes -->
      <div class="yth-section-label">AGENTES</div>
      <div class="yth-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Mentores
        <span class="yth-count" style="background: #22C55E;">2</span>
      </div>
      <div class="yth-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
        Atendentes
        <span class="yth-count" style="background: #3B82F6;">3</span>
      </div>
      <div class="yth-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/></svg>
        Automacoes
        <span class="yth-count" style="background: #9CA3AF;">0</span>
      </div>
      <div class="yth-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Protetor 24h
        <span class="yth-badge-new">Novo</span>
      </div>

      <!-- Configurações -->
      <div class="yth-section-label">CONFIGURACOES</div>
      <div class="yth-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4"/></svg>
        Skills
      </div>
      <div class="yth-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
        Secrets
      </div>

      <!-- Monitoramento -->
      <div class="yth-section-label">MONITORAMENTO</div>
      <div class="yth-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
        Uso &amp; Tokens
      </div>
      <div class="yth-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
        Logs
      </div>
    </div>

    <!-- Main content -->
    <div class="yth-main">
      <!-- Page header -->
      <div style="margin-bottom: 12px;">
        <div style="font-size: 13px; font-weight: 700; color: #1F2937; font-family: Poppins, sans-serif;">Central de Criacao de IAs</div>
        <div style="font-size: 8px; color: #9CA3AF;">Gerencie seu time de agentes inteligentes</div>
      </div>

      <!-- Hero card -->
      <div class="yth-hero-card">
        <div style="font-size: 8px; color: rgba(255,255,255,0.8);">Ola, Netto!</div>
        <div style="font-size: 14px; font-weight: 700; color: white; font-family: Poppins, sans-serif; margin: 4px 0;">Seu Time de IAs</div>
        <div style="font-size: 7px; color: rgba(255,255,255,0.7); margin-bottom: 10px;">Crie e gerencie agentes inteligentes que trabalham 24/7 para sua empresa.</div>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px;">
          <div style="text-align: center;">
            <div style="font-size: 18px; font-weight: 700; color: white;">5</div>
            <div style="font-size: 6px; color: rgba(255,255,255,0.7);">Agentes Ativos</div>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 18px; font-weight: 700; color: white;">847</div>
            <div style="font-size: 6px; color: rgba(255,255,255,0.7);">Atendimentos Hoje</div>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 18px; font-weight: 700; color: white;">R$ 12k</div>
            <div style="font-size: 6px; color: rgba(255,255,255,0.7);">Economia/Mes*</div>
          </div>
        </div>
        <div style="font-size: 5px; color: rgba(255,255,255,0.5); margin-top: 6px;">* Economia estimada vs atendente humano (R$ 5,00/interacao — Gartner, 2022)</div>
      </div>

      <!-- Agent type cards -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px;">
        <!-- Mentores -->
        <div class="yth-type-card" style="border-top: 3px solid #F59E0B;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px;">
            <div style="width: 22px; height: 22px; border-radius: 8px; background: rgba(245,158,11,0.1); display: flex; align-items: center; justify-content: center;">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <span class="yth-active-badge">Ativo</span>
          </div>
          <div style="font-size: 10px; font-weight: 700; color: #1F2937;">Mentores</div>
          <div style="font-size: 7px; color: #6B7280; margin: 2px 0 6px; line-height: 1.4;">Ajudam sua equipe a tomar decisoes melhores</div>
          <div style="font-size: 12px; font-weight: 700; color: #1F2937;">2 <span style="font-size: 7px; font-weight: 400; color: #9CA3AF;">ativos</span></div>
        </div>

        <!-- Atendentes -->
        <div class="yth-type-card" style="border-top: 3px solid #3B82F6;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px;">
            <div style="width: 22px; height: 22px; border-radius: 8px; background: rgba(59,130,246,0.1); display: flex; align-items: center; justify-content: center;">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <span class="yth-active-badge">Ativo</span>
          </div>
          <div style="font-size: 10px; font-weight: 700; color: #1F2937;">Atendentes</div>
          <div style="font-size: 7px; color: #6B7280; margin: 2px 0 6px; line-height: 1.4;">Respondem clientes automaticamente 24/7</div>
          <div style="font-size: 12px; font-weight: 700; color: #1F2937;">3 <span style="font-size: 7px; font-weight: 400; color: #9CA3AF;">ativos</span></div>
        </div>
      </div>

      <!-- Seus Agentes -->
      <div style="font-size: 10px; font-weight: 700; color: #1F2937; margin-bottom: 6px;">Seus Agentes</div>
      <div style="display: flex; flex-direction: column; gap: 4px;">
        <div class="yth-agent-row">
          <div style="width: 24px; height: 24px; border-radius: 8px; background: rgba(245,158,11,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </div>
          <div style="flex: 1; min-width: 0;">
            <div style="font-size: 8px; font-weight: 600; color: #1F2937;">Mentor de Vendas Pro</div>
            <div style="font-size: 6px; color: #9CA3AF;">Mentor &middot; Estrategias de venda e qualificacao</div>
          </div>
        </div>
        <div class="yth-agent-row">
          <div style="width: 24px; height: 24px; border-radius: 8px; background: rgba(245,158,11,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </div>
          <div style="flex: 1; min-width: 0;">
            <div style="font-size: 8px; font-weight: 600; color: #1F2937;">Mentor de Suporte</div>
            <div style="font-size: 6px; color: #9CA3AF;">Mentor &middot; Guia tecnico para atendentes</div>
          </div>
        </div>
        <div class="yth-agent-row">
          <div style="width: 24px; height: 24px; border-radius: 8px; background: rgba(59,130,246,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div style="flex: 1; min-width: 0;">
            <div style="font-size: 8px; font-weight: 600; color: #1F2937;">Agente Comercial WhatsApp</div>
            <div style="font-size: 6px; color: #9CA3AF;">Atendente &middot; Qualificacao e agendamento automatico</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .yth-frame {
    width: 100%; max-width: 480px; border-radius: 14px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.03);
    background: #ffffff; border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
  }
  .yth-body {
    display: grid; grid-template-columns: 130px 1fr;
  }

  /* Sidebar */
  .yth-sidebar {
    border-right: 1px solid #F3F4F6; padding-bottom: 8px;
    background: #FAFBFC;
  }
  .yth-section-label {
    font-size: 6px; font-weight: 700; color: #9CA3AF; letter-spacing: 0.05em;
    padding: 8px 10px 3px;
  }
  .yth-nav-item {
    display: flex; align-items: center; gap: 5px;
    padding: 4px 10px; font-size: 8px; color: #6B7280; cursor: default;
  }
  .yth-nav-active {
    background: rgba(139,92,246,0.06); color: #8B5CF6; font-weight: 600;
    border-radius: 6px; margin: 0 4px;
  }
  .yth-count {
    font-size: 6px; font-weight: 700; color: white;
    padding: 1px 5px; border-radius: 8px; margin-left: auto;
  }
  .yth-badge-new {
    font-size: 6px; font-weight: 600; color: #6B7280;
    padding: 1px 5px; border-radius: 4px; border: 1px solid #E5E7EB;
    margin-left: auto;
  }

  /* Main */
  .yth-main { padding: 12px; }

  .yth-hero-card {
    background: linear-gradient(135deg, #8B5CF6, #7C3AED, #6D28D9);
    border-radius: 12px; padding: 12px; margin-bottom: 10px;
  }

  .yth-type-card {
    background: white; border: 1px solid #F3F4F6; border-radius: 10px;
    padding: 10px;
  }
  .yth-active-badge {
    font-size: 6px; font-weight: 600; color: #22C55E;
    padding: 2px 6px; border-radius: 4px; background: rgba(34,197,94,0.08);
  }

  .yth-agent-row {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 8px; border: 1px solid #F3F4F6; border-radius: 8px;
  }

  @media (max-width: 480px) {
    .yth-body { grid-template-columns: 1fr; }
    .yth-sidebar { display: none; }
  }
</style>
