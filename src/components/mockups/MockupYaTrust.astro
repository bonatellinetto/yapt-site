---
/** MockupYaTrust — Security & Compliance Dashboard (static HTML/CSS mockup) */
---
<div class="mockup-frame">
  <!-- Top bar -->
  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #EF4444;"></div>
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #F59E0B;"></div>
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #22C55E;"></div>
    <div style="flex:1;"></div>
    <div style="font-size: 10px; font-weight: 600; color: #374151; font-family: Poppins, sans-serif;">yaTrust</div>
  </div>

  <!-- Security score -->
  <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 14px;">
    <div style="position: relative; width: 56px; height: 56px; flex-shrink: 0;">
      <svg viewBox="0 0 36 36" style="width: 56px; height: 56px; transform: rotate(-90deg);">
        <circle cx="18" cy="18" r="15" fill="none" stroke="rgba(34,197,94,0.12)" stroke-width="3"/>
        <circle cx="18" cy="18" r="15" fill="none" stroke="#22C55E" stroke-width="3" stroke-dasharray="89 94.2" stroke-linecap="round"/>
      </svg>
      <div style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <div style="font-size: 14px; font-weight: 700; color: #22C55E; line-height: 1;">94</div>
        <div style="font-size: 6px; color: #9CA3AF;">/100</div>
      </div>
    </div>
    <div>
      <div style="font-size: 12px; font-weight: 600; color: #1F2937; font-family: Poppins, sans-serif;">Security Score</div>
      <div style="font-size: 9px; color: #22C55E;">Excelente — todos os checks passaram</div>
    </div>
  </div>

  <!-- Compliance badges -->
  <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 14px;">
    <div class="trust-badge">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="#22C55E"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
      <span>LGPD</span>
    </div>
    <div class="trust-badge">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="#22C55E"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
      <span>SOC 2</span>
    </div>
    <div class="trust-badge">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="#22C55E"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
      <span>GDPR</span>
    </div>
    <div class="trust-badge">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="#22C55E"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
      <span>ISO 27001</span>
    </div>
  </div>

  <!-- Security checks -->
  <div style="display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px;">
    <div class="trust-check">
      <div style="width: 18px; height: 18px; border-radius: 50%; background: rgba(34,197,94,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="#22C55E"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
      </div>
      <div style="flex: 1;">
        <div style="font-size: 9px; font-weight: 600; color: #1F2937;">Criptografia E2E</div>
        <div style="font-size: 7px; color: #9CA3AF;">AES-256-GCM em todas as mensagens</div>
      </div>
    </div>
    <div class="trust-check">
      <div style="width: 18px; height: 18px; border-radius: 50%; background: rgba(34,197,94,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="#22C55E"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
      </div>
      <div style="flex: 1;">
        <div style="font-size: 9px; font-weight: 600; color: #1F2937;">RLS Multi-tenant</div>
        <div style="font-size: 7px; color: #9CA3AF;">Isolamento total por tenant — zero leaks</div>
      </div>
    </div>
    <div class="trust-check">
      <div style="width: 18px; height: 18px; border-radius: 50%; background: rgba(34,197,94,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="#22C55E"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
      </div>
      <div style="flex: 1;">
        <div style="font-size: 9px; font-weight: 600; color: #1F2937;">Backup automatico</div>
        <div style="font-size: 7px; color: #9CA3AF;">Point-in-time recovery &middot; 30 dias</div>
      </div>
    </div>
    <div class="trust-check">
      <div style="width: 18px; height: 18px; border-radius: 50%; background: rgba(34,197,94,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="#22C55E"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
      </div>
      <div style="flex: 1;">
        <div style="font-size: 9px; font-weight: 600; color: #1F2937;">AI Governance</div>
        <div style="font-size: 7px; color: #9CA3AF;">Audit trail completo &middot; Sem dados em treinamento</div>
      </div>
    </div>
  </div>

  <!-- Uptime -->
  <div style="background: #F9FAFB; border-radius: 10px; padding: 10px;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px;">
      <div style="font-size: 8px; font-weight: 600; color: #374151;">Uptime 90 dias</div>
      <div style="font-size: 10px; font-weight: 700; color: #22C55E;">99.97%</div>
    </div>
    <div style="display: flex; gap: 1px; height: 8px;">
      <div style="flex:1; background: #22C55E; border-radius: 2px 0 0 2px;"></div>
      <div style="flex:1; background: #22C55E;"></div>
      <div style="flex:1; background: #22C55E;"></div>
      <div style="flex:1; background: #22C55E;"></div>
      <div style="flex:1; background: #22C55E;"></div>
      <div style="flex:1; background: #22C55E;"></div>
      <div style="flex:1; background: #22C55E;"></div>
      <div style="flex:1; background: #F59E0B;"></div>
      <div style="flex:1; background: #22C55E;"></div>
      <div style="flex:1; background: #22C55E;"></div>
      <div style="flex:1; background: #22C55E;"></div>
      <div style="flex:1; background: #22C55E; border-radius: 0 2px 2px 0;"></div>
    </div>
  </div>
</div>

<style>
  .mockup-frame {
    width: 100%; max-width: 420px; border-radius: 20px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.08);
    background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
    border: 1px solid rgba(0,0,0,0.06);
    padding: 18px; overflow: hidden;
  }
  .trust-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 10px; border-radius: 8px;
    background: rgba(34,197,94,0.06); border: 1px solid rgba(34,197,94,0.12);
    font-size: 8px; font-weight: 600; color: #166534;
  }
  .trust-check {
    display: flex; align-items: center; gap: 8px;
    background: #F9FAFB; border-radius: 8px; padding: 8px 10px;
  }
</style>
