---
/** MockupRouting — yaOps Torre de Controle routing flow view */
---
<div class="rt-frame">
  <!-- Header -->
  <div style="padding: 10px 14px 0; border-bottom: 1px solid #F3F4F6;">
    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
      <div style="width: 26px; height: 26px; border-radius: 8px; background: linear-gradient(135deg, #20B2AA, #14B8A6); display: flex; align-items: center; justify-content: center;">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="white"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg>
      </div>
      <div>
        <div style="font-size: 11px; font-weight: 700; color: #1F2937; font-family: Inter, sans-serif;">yaOps Torre de Controle</div>
      </div>
      <div style="margin-left: auto; display: flex; align-items: center; gap: 4px;">
        <div style="width: 6px; height: 6px; border-radius: 50%; background: #22C55E;"></div>
        <span style="font-size: 8px; color: #22C55E; font-weight: 600;">Online</span>
      </div>
    </div>
    <!-- Tabs -->
    <div style="display: flex; gap: 0; overflow-x: auto;">
      <div style="padding: 5px 8px; font-size: 8px; color: #9CA3AF; font-weight: 500; white-space: nowrap; position: relative;">
        Live
        <div style="position: absolute; top: 2px; right: 2px; width: 4px; height: 4px; border-radius: 50%; background: #22C55E;"></div>
      </div>
      <div style="padding: 5px 8px; font-size: 8px; color: #9CA3AF; font-weight: 500; white-space: nowrap;">Saude</div>
      <div style="padding: 5px 8px; font-size: 8px; color: #9CA3AF; font-weight: 500; white-space: nowrap;">Equipe</div>
      <div style="padding: 5px 8px; font-size: 8px; font-weight: 700; color: #20B2AA; white-space: nowrap; border-bottom: 2px solid #20B2AA;">
        Circuito
        <div style="font-size: 7px; font-weight: 400; color: #6B7280; margin-top: 1px;">Fluxo de distribuicao</div>
      </div>
      <div style="padding: 5px 8px; font-size: 8px; color: #9CA3AF; font-weight: 500; white-space: nowrap;">Historico</div>
      <div style="padding: 5px 8px; font-size: 8px; color: #9CA3AF; font-weight: 500; white-space: nowrap;">Regras</div>
    </div>
  </div>

  <!-- Main content -->
  <div style="padding: 12px 14px;">
    <!-- Section title -->
    <div style="font-size: 9px; font-weight: 700; color: #374151; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Fluxo de Roteamento</div>

    <!-- Top row: 3 metric cards -->
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px;">
      <!-- ENTRADA -->
      <div class="rt-metric-card" style="border-left: 2px solid #22C55E;">
        <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 4px;">
          <div style="width: 16px; height: 16px; border-radius: 4px; background: rgba(34,197,94,0.1); display: flex; align-items: center; justify-content: center;">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="#22C55E"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </div>
          <span style="font-size: 7px; font-weight: 600; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.03em;">Entrada</span>
        </div>
        <div style="font-size: 16px; font-weight: 800; color: #1F2937; line-height: 1;">247</div>
        <div style="font-size: 7px; color: #6B7280; margin-top: 2px;">msg/min</div>
      </div>

      <!-- AVALIACAO -->
      <div class="rt-metric-card">
        <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 4px;">
          <div style="width: 16px; height: 16px; border-radius: 4px; background: rgba(32,178,170,0.1); display: flex; align-items: center; justify-content: center;">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="#20B2AA"><path d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
          </div>
          <span style="font-size: 7px; font-weight: 600; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.03em;">Avaliacao</span>
        </div>
        <div style="font-size: 16px; font-weight: 800; color: #1F2937; line-height: 1;">94%</div>
        <div style="font-size: 7px; color: #6B7280; margin-top: 2px;">taxa de match</div>
      </div>

      <!-- FILA -->
      <div class="rt-metric-card">
        <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 4px;">
          <div style="width: 16px; height: 16px; border-radius: 4px; background: rgba(99,102,241,0.1); display: flex; align-items: center; justify-content: center;">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="#6366F1"><path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/></svg>
          </div>
          <span style="font-size: 7px; font-weight: 600; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.03em;">Fila</span>
        </div>
        <div style="font-size: 16px; font-weight: 800; color: #1F2937; line-height: 1;">12</div>
        <div style="font-size: 7px; color: #6B7280; margin-top: 2px;">media 8s</div>
      </div>
    </div>

    <!-- Arrow down -->
    <div style="display: flex; justify-content: center; padding: 6px 0;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#CBD5E1" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>

    <!-- Bottom row: 3 metric cards -->
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px;">
      <!-- RESERVADO -->
      <div class="rt-metric-card">
        <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 4px;">
          <div style="width: 16px; height: 16px; border-radius: 4px; background: rgba(245,158,11,0.1); display: flex; align-items: center; justify-content: center;">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="#F59E0B"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
          </div>
          <span style="font-size: 7px; font-weight: 600; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.03em;">Reservado</span>
        </div>
        <div style="font-size: 16px; font-weight: 800; color: #1F2937; line-height: 1;">3</div>
        <div style="font-size: 7px; color: #6B7280; margin-top: 2px;">timeout 30s</div>
      </div>

      <!-- ATRIBUIDO -->
      <div class="rt-metric-card">
        <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 4px;">
          <div style="width: 16px; height: 16px; border-radius: 4px; background: rgba(99,102,241,0.1); display: flex; align-items: center; justify-content: center;">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="#6366F1"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
          </div>
          <span style="font-size: 7px; font-weight: 600; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.03em;">Atribuido</span>
        </div>
        <div style="font-size: 16px; font-weight: 800; color: #1F2937; line-height: 1;">18</div>
        <div style="font-size: 7px; color: #6B7280; margin-top: 2px;">aguardando operador</div>
      </div>

      <!-- ATIVO -->
      <div class="rt-metric-card" style="border-left: 2px solid #22C55E;">
        <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 4px;">
          <div style="width: 16px; height: 16px; border-radius: 4px; background: rgba(34,197,94,0.1); display: flex; align-items: center; justify-content: center;">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="#22C55E"><path d="M12 1a3 3 0 00-3 3v4a3 3 0 006 0V4a3 3 0 00-3-3zm7 7h-2c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V18H8v2h8v-2h-3v-3.08c3.39-.49 6-3.39 6-6.92z"/></svg>
          </div>
          <span style="font-size: 7px; font-weight: 600; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.03em;">Ativo</span>
        </div>
        <div style="font-size: 16px; font-weight: 800; color: #22C55E; line-height: 1;">226</div>
        <div style="font-size: 7px; color: #6B7280; margin-top: 2px;">em atendimento</div>
      </div>
    </div>

    <!-- Mecanismos de Protecao -->
    <div style="margin-top: 12px; padding-top: 10px; border-top: 1px solid #F3F4F6;">
      <div style="font-size: 9px; font-weight: 700; color: #374151; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Mecanismos de Protecao</div>

      <div style="display: flex; flex-direction: column; gap: 6px;">
        <!-- Protecao de Setor -->
        <div class="rt-protection-card">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px;">
            <div style="font-size: 9px; font-weight: 700; color: #1F2937;">Protecao de Setor</div>
            <div style="display: flex; gap: 4px;">
              <span style="font-size: 7px; font-weight: 700; color: #22C55E; background: rgba(34,197,94,0.1); padding: 1px 6px; border-radius: 6px;">OK</span>
              <span style="font-size: 7px; font-weight: 600; color: #20B2AA; background: rgba(32,178,170,0.1); padding: 1px 6px; border-radius: 6px;">Ativo</span>
            </div>
          </div>
          <div style="font-size: 8px; color: #6B7280;">Comercial</div>
        </div>

        <!-- Auto-Redistribuicao -->
        <div class="rt-protection-card">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px;">
            <div style="font-size: 9px; font-weight: 700; color: #1F2937;">Auto-Redistribuicao</div>
            <span style="font-size: 7px; font-weight: 600; color: #20B2AA; background: rgba(32,178,170,0.1); padding: 1px 6px; border-radius: 6px;">Ativo</span>
          </div>
          <div style="display: flex; flex-direction: column; gap: 2px;">
            <div style="font-size: 8px; color: #6B7280;"><span style="color: #9CA3AF;">Gatilho:</span> operador saiu</div>
            <div style="font-size: 8px; color: #6B7280;"><span style="color: #9CA3AF;">Espera:</span> 10s</div>
            <div style="font-size: 8px; color: #6B7280;"><span style="color: #9CA3AF;">Impulso de prioridade:</span> +10</div>
          </div>
        </div>

        <!-- Fila de Revisao -->
        <div class="rt-protection-card" style="border-left: 2px solid #EF4444;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px;">
            <div style="font-size: 9px; font-weight: 700; color: #1F2937;">Fila de Revisao</div>
            <span style="font-size: 7px; font-weight: 700; color: white; background: #EF4444; padding: 1px 6px; border-radius: 6px;">16</span>
          </div>
          <div style="display: flex; flex-direction: column; gap: 2px;">
            <div style="font-size: 8px; color: #6B7280;"><span style="color: #9CA3AF;">Re-tentativa automatica:</span> a cada 2min</div>
            <div style="font-size: 8px; color: #6B7280;"><span style="color: #9CA3AF;">Tentativas maximas:</span> 3</div>
          </div>
          <div style="font-size: 8px; color: #EF4444; font-weight: 600; margin-top: 4px;">16 conversas precisam de atencao</div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .rt-frame {
    width: 100%; max-width: 380px; border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.03);
    background: #ffffff; border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden; font-family: Inter, system-ui, sans-serif;
  }

  .rt-metric-card {
    background: #FAFBFC;
    border: 1px solid #F3F4F6;
    border-radius: 10px;
    padding: 8px 10px;
  }

  .rt-protection-card {
    background: #FAFBFC;
    border: 1px solid #F3F4F6;
    border-radius: 10px;
    padding: 8px 10px;
  }
</style>
