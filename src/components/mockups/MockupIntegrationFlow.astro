---
/** MockupIntegrationFlow — Flow Builder canvas mockup (CSS-only, no JS, no images) */
---
<div class="if-frame">
  <div class="if-canvas">

    <!-- Background grid dots (CSS-driven via pseudo-elements) -->

    <!-- === Node 1: Enviar Mensagem === -->
    <div class="if-node if-node-msg" style="left: 24px; top: 28px;">
      <!-- Top row: icon + title + badge -->
      <div class="if-node-header">
        <div class="if-icon-circle if-icon-teal">
          <svg width="7" height="7" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <span class="if-node-title">Enviar Mensagem</span>
        <span class="if-badge-teal">WHATSAPP</span>
      </div>
      <!-- Chat bubble -->
      <div class="if-chat-bubble">
        <span class="if-chat-text">Ola &#123;&#123;nome&#125;&#125;, tudo bem?</span>
        <div class="if-chat-meta">
          <span class="if-chat-time">09:41</span>
          <!-- Double check icon -->
          <svg width="10" height="6" viewBox="0 0 16 8" fill="none">
            <polyline points="1,4.5 4.5,7.5 11,1" stroke="#34B7F1" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <polyline points="5,4.5 8.5,7.5 15,1" stroke="#34B7F1" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>
      </div>
      <!-- Right connector dot + plus -->
      <div class="if-connector-right" style="top: 50%;">
        <div class="if-dot if-dot-green"></div>
        <div class="if-plus-btn">+</div>
      </div>
    </div>

    <!-- === Connection line between Node 1 and Node 2 === -->
    <svg class="if-connection-svg" style="position: absolute; left: 0; top: 0; width: 100%; height: 100%; pointer-events: none;">
      <path d="M 186 72 C 210 72, 220 62, 240 62" stroke="#374151" stroke-width="1.5" fill="none"/>
    </svg>

    <!-- === Node 2: Switch === -->
    <div class="if-node if-node-switch" style="left: 186px; top: 22px;">
      <div class="if-node-header">
        <div class="if-icon-circle if-icon-purple">
          <svg width="7" height="7" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </div>
        <div class="if-node-title-group">
          <span class="if-node-title">Switch</span>
          <span class="if-node-subtitle">1 caminhos</span>
        </div>
      </div>
      <!-- Switch items -->
      <div class="if-switch-items">
        <div class="if-switch-item">
          <span class="if-badge-teal-sm">Caminho 1</span>
        </div>
        <div class="if-switch-item">
          <span class="if-switch-default">Default</span>
        </div>
      </div>
      <!-- Right connectors -->
      <div class="if-connector-right" style="top: 58px;">
        <div class="if-dot if-dot-green"></div>
        <div class="if-plus-btn">+</div>
      </div>
      <div class="if-connector-right" style="top: 72px;">
        <div class="if-dot if-dot-green"></div>
        <div class="if-plus-btn">+</div>
      </div>
    </div>

    <!-- === Floating teal circles (decorative background) === -->
    <div class="if-bg-circle" style="width: 18px; height: 18px; left: 8px; top: 8px; opacity: 0.08;"></div>
    <div class="if-bg-circle" style="width: 12px; height: 12px; right: 16px; top: 12px; opacity: 0.06;"></div>
    <div class="if-bg-circle" style="width: 22px; height: 22px; left: 140px; bottom: 80px; opacity: 0.05;"></div>
    <div class="if-bg-circle" style="width: 10px; height: 10px; right: 40px; bottom: 100px; opacity: 0.07;"></div>
    <div class="if-bg-circle" style="width: 14px; height: 14px; left: 40px; bottom: 50px; opacity: 0.06;"></div>

    <!-- === Floating Action Menu (bottom-right) === -->
    <div class="if-action-menu">
      <!-- Search bar -->
      <div class="if-action-search">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="if-action-search-text">Buscar acao...</span>
      </div>
      <!-- Menu items -->
      <div class="if-action-list">
        <div class="if-action-item">
          <div class="if-action-icon" style="background: #22C55E;">
            <svg width="6" height="6" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </div>
          <span class="if-action-label">Mover Deal</span>
        </div>
        <div class="if-action-item">
          <div class="if-action-icon" style="background: #20B2AA;">
            <svg width="6" height="6" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <span class="if-action-label">Inscrever em Flow</span>
        </div>
        <!-- Section: INTEGRACOES -->
        <div class="if-action-section">
          <span class="if-action-section-text">INTEGRACOES</span>
        </div>
        <div class="if-action-item">
          <div class="if-action-icon" style="background: #3B82F6;">
            <svg width="6" height="6" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </div>
          <span class="if-action-label">Webhook</span>
        </div>
        <div class="if-action-item">
          <div class="if-action-icon" style="background: #3B82F6;">
            <svg width="6" height="6" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <span class="if-action-label">HTTP Request</span>
        </div>
        <div class="if-action-item">
          <div class="if-action-icon" style="background: #F97316;">
            <svg width="6" height="6" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <span class="if-action-label">Zapier</span>
        </div>
        <!-- Section: CONTROLE DE FLUXO -->
        <div class="if-action-section">
          <span class="if-action-section-text">CONTROLE DE FLUXO</span>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
  /* === Frame === */
  .if-frame {
    width: 100%;
    max-width: 360px;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.03);
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
    font-family: Inter, sans-serif;
  }

  /* === Canvas === */
  .if-canvas {
    position: relative;
    width: 100%;
    height: 240px;
    background: #F8F9FA;
    background-image: radial-gradient(circle, #D1D5DB 0.6px, transparent 0.6px);
    background-size: 14px 14px;
    overflow: hidden;
  }

  /* === Decorative teal circles === */
  .if-bg-circle {
    position: absolute;
    border-radius: 50%;
    background: #20B2AA;
    pointer-events: none;
  }

  /* === Node base === */
  .if-node {
    position: absolute;
    background: #ffffff;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06), 0 0.5px 1px rgba(0,0,0,0.03);
    font-family: Inter, sans-serif;
  }

  /* === Node: Enviar Mensagem === */
  .if-node-msg {
    width: 148px;
    padding: 7px 8px 6px;
  }

  .if-node-header {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .if-icon-circle {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .if-icon-teal {
    background: #20B2AA;
  }

  .if-icon-purple {
    background: #7C3AED;
  }

  .if-node-title {
    font-size: 7px;
    font-weight: 600;
    color: #1F2937;
    white-space: nowrap;
  }

  .if-node-title-group {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .if-node-subtitle {
    font-size: 5.5px;
    color: #9CA3AF;
    font-weight: 400;
  }

  .if-badge-teal {
    font-size: 5px;
    font-weight: 700;
    color: #20B2AA;
    background: rgba(32,178,170,0.1);
    padding: 1px 4px;
    border-radius: 4px;
    letter-spacing: 0.04em;
    white-space: nowrap;
    margin-left: auto;
  }

  .if-badge-teal-sm {
    font-size: 5.5px;
    font-weight: 600;
    color: #20B2AA;
    background: rgba(32,178,170,0.1);
    padding: 1.5px 5px;
    border-radius: 4px;
  }

  /* === Chat bubble === */
  .if-chat-bubble {
    margin-top: 5px;
    background: #DCF8C6;
    border-radius: 6px 6px 0 6px;
    padding: 5px 7px 3px;
  }

  .if-chat-text {
    font-size: 6px;
    color: #1F2937;
    line-height: 1.4;
    display: block;
  }

  .if-chat-meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 2px;
    margin-top: 2px;
  }

  .if-chat-time {
    font-size: 4.5px;
    color: #6B7280;
  }

  /* === Connector dots + plus buttons === */
  .if-connector-right {
    position: absolute;
    right: -14px;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .if-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .if-dot-green {
    background: #22C55E;
    border: 1px solid #fff;
    box-shadow: 0 0 0 0.5px rgba(34,197,94,0.3);
  }

  .if-plus-btn {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #22C55E;
    color: #fff;
    font-size: 7px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    box-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }

  /* === Node: Switch === */
  .if-node-switch {
    width: 128px;
    padding: 7px 8px 6px;
    border-top: 2.5px solid #7C3AED;
  }

  .if-switch-items {
    margin-top: 5px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .if-switch-item {
    display: flex;
    align-items: center;
  }

  .if-switch-default {
    font-size: 5.5px;
    color: #9CA3AF;
    font-weight: 500;
  }

  /* === Connection line SVG === */
  .if-connection-svg {
    z-index: 0;
  }

  .if-node {
    z-index: 1;
  }

  /* === Floating Action Menu === */
  .if-action-menu {
    position: absolute;
    right: 10px;
    bottom: 10px;
    width: 118px;
    background: #ffffff;
    border: 1.5px solid #20B2AA;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1), 0 1px 3px rgba(0,0,0,0.05);
    overflow: hidden;
    z-index: 5;
  }

  .if-action-search {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 5px 7px;
    border-bottom: 1px solid #F3F4F6;
  }

  .if-action-search-text {
    font-size: 5.5px;
    color: #9CA3AF;
    font-weight: 400;
  }

  .if-action-list {
    padding: 3px 0;
  }

  .if-action-item {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 3px 7px;
  }

  .if-action-item:hover {
    background: #F9FAFB;
  }

  .if-action-icon {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .if-action-label {
    font-size: 6px;
    font-weight: 500;
    color: #374151;
  }

  .if-action-section {
    padding: 4px 7px 2px;
  }

  .if-action-section-text {
    font-size: 4.5px;
    font-weight: 700;
    color: #9CA3AF;
    letter-spacing: 0.06em;
  }
</style>
