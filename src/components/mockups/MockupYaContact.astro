---
/** MockupYaContact — Lead Intelligence Panel with Score & Behavioral Scoring (conversations page) */
---
<div class="yact-frame">
  <!-- Contact Header -->
  <div class="yact-header">
    <div class="yact-avatar">RP</div>
    <div style="flex: 1;">
      <div style="font-size: 15px; font-weight: 700; color: white;">Rodrigo Pimentel</div>
      <div style="display: flex; align-items: center; gap: 10px; margin-top: 2px;">
        <span style="display: flex; align-items: center; gap: 3px; font-size: 10px; color: rgba(255,255,255,0.7);">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
          rodrigo@logtech.com.br
        </span>
        <span style="display: flex; align-items: center; gap: 3px; font-size: 10px; color: rgba(255,255,255,0.7);">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          +55 11 98765-4321
        </span>
      </div>
    </div>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2" style="cursor: pointer;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </div>

  <!-- Tags row -->
  <div class="yact-tags">
    <span class="yact-tag-score">Score: 72</span>
    <span class="yact-tag-dark">Warm Lead</span>
    <span class="yact-tag-blue">LEAD</span>
  </div>

  <!-- Quick actions -->
  <div class="yact-actions">
    <div class="yact-action">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/></svg>
      <span>Nota</span>
    </div>
    <div class="yact-action">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
      <span>Email</span>
    </div>
    <div class="yact-action">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3"/></svg>
      <span>Chamada</span>
    </div>
    <div class="yact-action">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
      <span>Tarefa</span>
    </div>
    <div class="yact-action">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/></svg>
      <span>Reuniao</span>
    </div>
    <div class="yact-action">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="#6B7280"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
    </div>
  </div>

  <!-- Company -->
  <div class="yact-company">LogTech Solutions</div>

  <!-- Lead Intelligence section -->
  <div class="yact-intel">
    <div class="yact-intel-header">
      <div style="display: flex; align-items: center; gap: 6px;">
        <div style="width: 24px; height: 24px; border-radius: 6px; background: #F59E0B; display: flex; align-items: center; justify-content: center;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><path d="M3 3v18h18"/><path d="M18 17V9M13 17V5M8 17v-3"/></svg>
        </div>
        <span style="font-size: 12px; font-weight: 600; color: #1F2937;">Lead Intelligence</span>
      </div>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
    </div>

    <!-- Score -->
    <div class="yact-score-row">
      <div>
        <div style="display: flex; align-items: center; gap: 6px;">
          <div style="width: 20px; height: 20px; border-radius: 4px; background: #F59E0B; display: flex; align-items: center; justify-content: center;">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="white"><path d="M3 3v18h18"/><path d="M18 17V9M13 17V5M8 17v-3"/></svg>
          </div>
          <div>
            <div style="font-size: 11px; font-weight: 600; color: #1F2937;">Lead Score</div>
            <div style="font-size: 9px; color: #F59E0B; font-weight: 500;">Warm Lead</div>
          </div>
        </div>
      </div>
      <div class="yact-score-big">
        <span class="yact-score-num">72</span><span class="yact-score-total">/100</span>
      </div>
    </div>

    <div class="yact-score-meta">
      <div style="display: flex; align-items: center; gap: 4px;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        <span>Modo Hibrido — IA + Comportamental</span>
      </div>
    </div>

    <div class="yact-score-meta">
      <div style="display: flex; align-items: center; gap: 4px;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="#20B2AA"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        <span>Qualificado por <strong>Mentor de vendas yapt.</strong></span>
      </div>
    </div>

    <!-- Score bar -->
    <div class="yact-score-bar">
      <div class="yact-score-fill" style="width: 72%;"></div>
    </div>

    <!-- ICP Match -->
    <div class="yact-icp-row">
      <div style="display: flex; align-items: center; gap: 4px;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z"/></svg>
        <span style="font-size: 10px; color: #374151;">ICP Match</span>
      </div>
      <span style="font-size: 10px; font-weight: 600; color: #374151;">84%</span>
    </div>

    <!-- Behavioral Scoring -->
    <div class="yact-scoring-header">
      <div style="display: flex; align-items: center; gap: 4px;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        <span style="font-size: 10px; font-weight: 600; color: #374151;">Scoring Comportamental</span>
      </div>
      <span style="font-size: 8px; color: #9CA3AF;">Calculado ha 11min</span>
    </div>

    <div class="yact-metrics">
      <div class="yact-metric">
        <div class="yact-metric-header">
          <span>Engajamento</span><span class="yact-metric-val yact-val-green">20/20</span>
        </div>
        <div class="yact-bar-track"><div class="yact-bar-fill-green" style="width: 100%;"></div></div>
      </div>
      <div class="yact-metric">
        <div class="yact-metric-header">
          <span>Recencia</span><span class="yact-metric-val yact-val-green">20/20</span>
        </div>
        <div class="yact-bar-track"><div class="yact-bar-fill-green" style="width: 100%;"></div></div>
      </div>
      <div class="yact-metric">
        <div class="yact-metric-header">
          <span>Perfil Completo</span><span class="yact-metric-val">7/15</span>
        </div>
        <div class="yact-bar-track"><div class="yact-bar-fill-blue" style="width: 47%;"></div></div>
      </div>
      <div class="yact-metric">
        <div class="yact-metric-header">
          <span>Sentimento</span><span class="yact-metric-val yact-val-orange">8/15</span>
        </div>
        <div class="yact-bar-track"><div class="yact-bar-fill-orange" style="width: 53%;"></div></div>
      </div>
      <div class="yact-metric">
        <div class="yact-metric-header">
          <span>Canal de Origem</span><span class="yact-metric-val yact-val-green">10/10</span>
        </div>
        <div class="yact-bar-track"><div class="yact-bar-fill-green" style="width: 100%;"></div></div>
      </div>
      <div class="yact-metric">
        <div class="yact-metric-header">
          <span>Atividade de Deals</span><span class="yact-metric-val">4/10</span>
        </div>
        <div class="yact-bar-track"><div class="yact-bar-fill-blue" style="width: 40%;"></div></div>
      </div>
      <div class="yact-metric">
        <div class="yact-metric-header">
          <span>Estagio no Funil</span><span class="yact-metric-val">2/5</span>
        </div>
        <div class="yact-bar-track"><div class="yact-bar-fill-blue" style="width: 40%;"></div></div>
      </div>
    </div>
  </div>

  <!-- Lifecycle Pipeline -->
  <div class="yact-pipeline">
    <div class="yact-pipe-step">
      <div class="yact-pipe-circle yact-pipe-done">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
      </div>
      <span>Subscriber</span>
    </div>
    <div class="yact-pipe-line yact-pipe-line-done"></div>
    <div class="yact-pipe-step">
      <div class="yact-pipe-circle yact-pipe-active">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
      </div>
      <span style="font-weight: 600;">Lead</span>
    </div>
    <div class="yact-pipe-line"></div>
    <div class="yact-pipe-step">
      <div class="yact-pipe-circle"></div>
      <span>MQL</span>
    </div>
    <div class="yact-pipe-line"></div>
    <div class="yact-pipe-step">
      <div class="yact-pipe-circle"></div>
      <span>SAL</span>
    </div>
    <div class="yact-pipe-line"></div>
    <div class="yact-pipe-step">
      <div class="yact-pipe-circle"></div>
      <span>SQL</span>
    </div>
    <div class="yact-pipe-line"></div>
    <div class="yact-pipe-step">
      <div class="yact-pipe-circle"></div>
      <span>Opportunity</span>
    </div>
    <div class="yact-pipe-line"></div>
    <div class="yact-pipe-step">
      <div class="yact-pipe-circle"></div>
      <span>Customer</span>
    </div>
  </div>
</div>

<style>
  .yact-frame {
    width: 100%; max-width: 540px; border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.03);
    background: #ffffff; border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
  }

  /* Header */
  .yact-header {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 14px; background: linear-gradient(135deg, #20B2AA, #14B8A6);
  }
  .yact-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: rgba(255,255,255,0.2); display: flex;
    align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; color: white; flex-shrink: 0;
  }

  /* Tags */
  .yact-tags {
    display: flex; gap: 6px; padding: 10px 14px; border-bottom: 1px solid #F3F4F6;
  }
  .yact-tag-score {
    font-size: 9px; font-weight: 700; color: white;
    padding: 3px 8px; border-radius: 4px; background: #F59E0B;
  }
  .yact-tag-dark {
    font-size: 9px; font-weight: 500; color: #374151;
    padding: 3px 8px; border-radius: 4px; background: #F3F4F6;
  }
  .yact-tag-blue {
    font-size: 9px; font-weight: 600; color: #3B82F6;
    padding: 3px 8px; border-radius: 4px;
    border: 1px solid #3B82F6;
  }

  /* Actions */
  .yact-actions {
    display: flex; gap: 4px; padding: 8px 14px; border-bottom: 1px solid #F3F4F6;
  }
  .yact-action {
    display: flex; align-items: center; gap: 4px;
    font-size: 9px; color: #6B7280; padding: 4px 8px;
    border: 1px solid #E5E7EB; border-radius: 6px;
  }

  /* Company */
  .yact-company {
    font-size: 10px; color: #6B7280; padding: 8px 14px;
    border-bottom: 1px solid #F3F4F6;
  }

  /* Intel */
  .yact-intel { padding: 12px 14px; }
  .yact-intel-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 12px;
  }

  .yact-score-row {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 8px;
  }
  .yact-score-big { text-align: right; }
  .yact-score-num { font-size: 28px; font-weight: 700; color: #F59E0B; }
  .yact-score-total { font-size: 12px; color: #9CA3AF; }

  .yact-score-meta {
    font-size: 9px; color: #6B7280; margin-bottom: 6px;
  }

  .yact-score-bar {
    height: 6px; background: #F3F4F6; border-radius: 3px;
    margin: 10px 0; overflow: hidden;
  }
  .yact-score-fill {
    height: 100%; border-radius: 3px;
    background: linear-gradient(90deg, #F59E0B, #22C55E);
  }

  .yact-icp-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 8px 0; border-bottom: 1px solid #F3F4F6; margin-bottom: 10px;
  }

  .yact-scoring-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 10px;
  }

  /* Metrics */
  .yact-metrics { display: flex; flex-direction: column; gap: 6px; }
  .yact-metric {}
  .yact-metric-header {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 10px; color: #374151; margin-bottom: 3px;
  }
  .yact-metric-val { font-weight: 600; }
  .yact-val-green { color: #059669; }
  .yact-val-orange { color: #F59E0B; }
  .yact-bar-track {
    height: 5px; background: #F3F4F6; border-radius: 3px; overflow: hidden;
  }
  .yact-bar-fill-green { height: 100%; border-radius: 3px; background: #22C55E; }
  .yact-bar-fill-blue { height: 100%; border-radius: 3px; background: #3B82F6; }
  .yact-bar-fill-orange { height: 100%; border-radius: 3px; background: #F59E0B; }

  /* Pipeline */
  .yact-pipeline {
    display: flex; align-items: center; justify-content: center;
    gap: 0; padding: 12px 10px; border-top: 1px solid #F3F4F6;
    background: #FAFBFC; overflow-x: auto;
  }
  .yact-pipe-step {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    flex-shrink: 0;
  }
  .yact-pipe-step span { font-size: 7px; color: #9CA3AF; }
  .yact-pipe-circle {
    width: 18px; height: 18px; border-radius: 50%;
    border: 2px solid #E5E7EB; display: flex;
    align-items: center; justify-content: center;
  }
  .yact-pipe-done {
    background: #E5E7EB; border-color: #E5E7EB;
  }
  .yact-pipe-active {
    background: #20B2AA; border-color: #20B2AA;
    box-shadow: 0 0 0 3px rgba(32,178,170,0.2);
  }
  .yact-pipe-line {
    width: 12px; height: 2px; background: #E5E7EB; flex-shrink: 0;
    margin-bottom: 14px;
  }
  .yact-pipe-line-done { background: #D1D5DB; }
</style>
