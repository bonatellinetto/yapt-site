---
/** MockupYaEnterprise — Enterprise Operations Dashboard (static HTML/CSS mockup) */
---
<div class="mockup-frame">
  <!-- Top bar -->
  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #EF4444;"></div>
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #F59E0B;"></div>
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #22C55E;"></div>
    <div style="flex:1;"></div>
    <div style="font-size: 10px; font-weight: 600; color: #0D9488; font-family: Poppins, sans-serif;">yaEnterprise</div>
  </div>

  <!-- Header -->
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px;">
    <div>
      <div style="font-size: 12px; font-weight: 600; color: #1F2937; font-family: Poppins, sans-serif;">Torre de Controle</div>
      <div style="font-size: 9px; color: #9CA3AF;">5 unidades &middot; 142 agentes &middot; 30M msg/mes</div>
    </div>
    <div style="display: flex; align-items: center; gap: 4px; padding: 3px 8px; border-radius: 8px; background: rgba(32,178,170,0.08);">
      <div style="width: 6px; height: 6px; border-radius: 50%; background: #22C55E; animation: mockup-pulse 2s ease-in-out infinite;"></div>
      <div style="font-size: 8px; font-weight: 600; color: #0D9488;">Live</div>
    </div>
  </div>

  <!-- Tenant cards -->
  <div style="display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px;">
    <div class="tenant-card">
      <div style="display: flex; align-items: center; gap: 8px;">
        <div style="width: 28px; height: 28px; border-radius: 8px; background: linear-gradient(135deg, #20B2AA, #14B8A6); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 10px; font-weight: 700; color: white;">SP</div>
        <div style="flex: 1;">
          <div style="font-size: 9px; font-weight: 600; color: #1F2937;">Sao Paulo</div>
          <div style="font-size: 7px; color: #9CA3AF;">48 agentes &middot; 12.4k msg/h</div>
        </div>
        <div style="text-align: right;">
          <div style="font-size: 10px; font-weight: 700; color: #0D9488;">98.2%</div>
          <div style="font-size: 7px; color: #22C55E;">SLA OK</div>
        </div>
      </div>
      <div style="margin-top: 6px; height: 3px; border-radius: 2px; background: rgba(32,178,170,0.1); overflow: hidden;">
        <div style="width: 72%; height: 100%; border-radius: 2px; background: #20B2AA;"></div>
      </div>
    </div>

    <div class="tenant-card">
      <div style="display: flex; align-items: center; gap: 8px;">
        <div style="width: 28px; height: 28px; border-radius: 8px; background: linear-gradient(135deg, #3B82F6, #2563EB); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 10px; font-weight: 700; color: white;">RJ</div>
        <div style="flex: 1;">
          <div style="font-size: 9px; font-weight: 600; color: #1F2937;">Rio de Janeiro</div>
          <div style="font-size: 7px; color: #9CA3AF;">32 agentes &middot; 8.1k msg/h</div>
        </div>
        <div style="text-align: right;">
          <div style="font-size: 10px; font-weight: 700; color: #0D9488;">96.8%</div>
          <div style="font-size: 7px; color: #22C55E;">SLA OK</div>
        </div>
      </div>
      <div style="margin-top: 6px; height: 3px; border-radius: 2px; background: rgba(59,130,246,0.1); overflow: hidden;">
        <div style="width: 58%; height: 100%; border-radius: 2px; background: #3B82F6;"></div>
      </div>
    </div>

    <div class="tenant-card">
      <div style="display: flex; align-items: center; gap: 8px;">
        <div style="width: 28px; height: 28px; border-radius: 8px; background: linear-gradient(135deg, #F59E0B, #D97706); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 10px; font-weight: 700; color: white;">BH</div>
        <div style="flex: 1;">
          <div style="font-size: 9px; font-weight: 600; color: #1F2937;">Belo Horizonte</div>
          <div style="font-size: 7px; color: #9CA3AF;">24 agentes &middot; 4.8k msg/h</div>
        </div>
        <div style="text-align: right;">
          <div style="font-size: 10px; font-weight: 700; color: #F59E0B;">91.4%</div>
          <div style="font-size: 7px; color: #F59E0B;">SLA Risk</div>
        </div>
      </div>
      <div style="margin-top: 6px; height: 3px; border-radius: 2px; background: rgba(245,158,11,0.1); overflow: hidden;">
        <div style="width: 85%; height: 100%; border-radius: 2px; background: #F59E0B;"></div>
      </div>
    </div>
  </div>

  <!-- Distribution engine -->
  <div style="background: rgba(32,178,170,0.04); border: 1px solid rgba(32,178,170,0.1); border-radius: 10px; padding: 10px;">
    <div style="font-size: 8px; font-weight: 600; color: #0D9488; margin-bottom: 8px;">Distribuicao inteligente</div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px;">
      <div style="display: flex; align-items: center; gap: 4px;">
        <div style="width: 4px; height: 4px; border-radius: 50%; background: #20B2AA;"></div>
        <div style="font-size: 7px; color: #6B7280;">Round-robin: 45%</div>
      </div>
      <div style="display: flex; align-items: center; gap: 4px;">
        <div style="width: 4px; height: 4px; border-radius: 50%; background: #3B82F6;"></div>
        <div style="font-size: 7px; color: #6B7280;">Skill-based: 30%</div>
      </div>
      <div style="display: flex; align-items: center; gap: 4px;">
        <div style="width: 4px; height: 4px; border-radius: 50%; background: #8B5CF6;"></div>
        <div style="font-size: 7px; color: #6B7280;">IA resolve: 20%</div>
      </div>
      <div style="display: flex; align-items: center; gap: 4px;">
        <div style="width: 4px; height: 4px; border-radius: 50%; background: #F59E0B;"></div>
        <div style="font-size: 7px; color: #6B7280;">Overflow: 5%</div>
      </div>
    </div>
  </div>
</div>

<style>
  .mockup-frame {
    width: 100%; max-width: 480px; border-radius: 20px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.08);
    background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
    border: 1px solid rgba(0,0,0,0.06);
    padding: 18px; overflow: hidden;
  }
  .tenant-card {
    background: #F9FAFB; border: 1px solid rgba(0,0,0,0.04); border-radius: 10px; padding: 10px;
  }
  @keyframes mockup-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>
