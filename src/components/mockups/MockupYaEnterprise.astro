---
/** MockupYaEnterprise — yaOps Torre de Controle > Circuito (replicates real product UI) */
---
<div class="yaent-frame">
  <!-- Header -->
  <div class="yaent-header">
    <div style="width: 28px; height: 28px; border-radius: 50%; background: rgba(32,178,170,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="#20B2AA"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
    </div>
    <div>
      <span style="font-size: 11px; font-weight: 700; color: #1F2937; font-family: Poppins, sans-serif;">yaOps</span>
      <span style="font-size: 10px; color: #9CA3AF; margin-left: 6px;">Torre de Controle</span>
    </div>
  </div>

  <!-- Tabs -->
  <div class="yaent-tabs">
    <div class="yaent-tab">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      Live
      <div style="width: 5px; height: 5px; border-radius: 50%; background: #22C55E;"></div>
    </div>
    <div class="yaent-tab">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      Saude
    </div>
    <div class="yaent-tab">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      Equipe
    </div>
    <div class="yaent-tab yaent-tab-active">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="M11 18H8a2 2 0 0 1-2-2V9"/></svg>
      Circuito
      <div style="font-size: 7px; color: #6B7280; font-weight: 400;">Fluxo de distribuicao</div>
    </div>
    <div class="yaent-tab">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      Historico
    </div>
    <div class="yaent-tab">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      Regras
    </div>
  </div>

  <!-- Fluxo de Roteamento -->
  <div class="yaent-section">
    <div style="font-size: 11px; font-weight: 600; color: #1F2937; margin-bottom: 12px;">Fluxo de Roteamento</div>

    <!-- Row 1: Entrada → Avaliação → Fila -->
    <div class="yaent-flow-row">
      <div class="yaent-flow-card yaent-flow-green">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="1.8"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8l4-3v14l-4-3"/></svg>
        <div class="yaent-flow-label">ENTRADA</div>
        <div class="yaent-flow-value">248</div>
        <div class="yaent-flow-sub">msg/min</div>
      </div>
      <div class="yaent-flow-card yaent-flow-green">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <div class="yaent-flow-label">AVALIACAO</div>
        <div class="yaent-flow-value">94%</div>
        <div class="yaent-flow-sub">taxa de match</div>
      </div>
      <div class="yaent-flow-card yaent-flow-green">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="1.8"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        <div class="yaent-flow-label">FILA</div>
        <div class="yaent-flow-value">12</div>
        <div class="yaent-flow-sub">media 8s</div>
      </div>
    </div>

    <!-- Arrow down -->
    <div style="display: flex; justify-content: center; padding: 4px 0; color: #D1D5DB;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>

    <!-- Row 2: Reservado → Atribuído → Ativo -->
    <div class="yaent-flow-row">
      <div class="yaent-flow-card">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <div class="yaent-flow-label">RESERVADO</div>
        <div class="yaent-flow-value">34</div>
        <div class="yaent-flow-sub">timeout 30s</div>
      </div>
      <div class="yaent-flow-card">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <div class="yaent-flow-label">ATRIBUIDO</div>
        <div class="yaent-flow-value">87</div>
        <div class="yaent-flow-sub">aguardando operador</div>
      </div>
      <div class="yaent-flow-card yaent-flow-green">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="1.8"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
        <div class="yaent-flow-label">ATIVO</div>
        <div class="yaent-flow-value">142</div>
        <div class="yaent-flow-sub">em atendimento</div>
      </div>
    </div>
  </div>

  <!-- Mecanismos de Proteção -->
  <div class="yaent-section" style="padding-top: 0;">
    <div style="font-size: 11px; font-weight: 600; color: #1F2937; margin-bottom: 10px;">Mecanismos de Protecao</div>
    <div class="yaent-prot-row">
      <!-- Proteção de Setor -->
      <div class="yaent-prot-card">
        <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 4px;">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span style="font-size: 9px; font-weight: 600; color: #1F2937;">Protecao de Setor</span>
          <span class="yaent-badge-ok">OK</span>
        </div>
        <div style="font-size: 8px; color: #6B7280;">Comercial</div>
        <div style="margin-top: 3px;">
          <span class="yaent-badge-active">Ativo</span>
        </div>
      </div>

      <!-- Auto-Redistribuição -->
      <div class="yaent-prot-card">
        <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 4px;">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
          <span style="font-size: 9px; font-weight: 600; color: #1F2937;">Auto-Redistribuicao</span>
          <span class="yaent-badge-active">Ativo</span>
        </div>
        <div style="font-size: 7px; color: #6B7280; line-height: 1.5;">Gatilho: operador saiu<br/>Espera: 10s<br/>Impulso de prioridade: +10</div>
      </div>

      <!-- Fila de Revisão -->
      <div class="yaent-prot-card">
        <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 4px;">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          <span style="font-size: 9px; font-weight: 600; color: #1F2937;">Fila de Revisao</span>
          <span class="yaent-badge-count">16</span>
        </div>
        <div style="font-size: 7px; color: #6B7280; line-height: 1.5;">Re-tentativa: a cada 2min<br/>Tentativas maximas: 3</div>
        <div style="font-size: 7px; color: #EF4444; font-weight: 600; margin-top: 2px;">16 conversas precisam de atencao</div>
      </div>
    </div>
  </div>
</div>

<style>
  .yaent-frame {
    width: 100%; max-width: 520px; border-radius: 16px;
    box-shadow: 0 12px 48px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.04);
    background: #ffffff; border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
  }
  .yaent-header {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 16px;
  }

  /* Tabs */
  .yaent-tabs {
    display: flex; gap: 0; padding: 0 12px; border-bottom: 1px solid #F3F4F6;
    overflow-x: auto;
  }
  .yaent-tab {
    display: flex; align-items: center; gap: 4px; padding: 8px 10px;
    font-size: 9px; font-weight: 500; color: #6B7280; white-space: nowrap;
    border-bottom: 2px solid transparent; flex-shrink: 0;
  }
  .yaent-tab-active {
    color: #1F2937; font-weight: 600;
    border-bottom: 2px solid #1F2937;
    flex-direction: column; align-items: flex-start; gap: 0;
    padding: 6px 10px;
    background: white; border: 1px solid #E5E7EB; border-bottom: 2px solid #1F2937;
    border-radius: 8px 8px 0 0; margin-bottom: -1px;
  }

  /* Section */
  .yaent-section {
    padding: 14px;
  }

  /* Flow cards */
  .yaent-flow-row {
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px;
  }
  .yaent-flow-card {
    border: 1px solid #E5E7EB; border-radius: 12px; padding: 10px;
    text-align: center; background: white;
  }
  .yaent-flow-green {
    border-color: rgba(32,178,170,0.25); background: rgba(32,178,170,0.02);
  }
  .yaent-flow-label {
    font-size: 7px; font-weight: 600; color: #6B7280; letter-spacing: 0.04em;
    margin-top: 6px;
  }
  .yaent-flow-value {
    font-size: 20px; font-weight: 700; color: #1F2937; line-height: 1.2;
    font-family: Poppins, sans-serif;
  }
  .yaent-flow-sub {
    font-size: 7px; color: #9CA3AF;
  }

  /* Protection cards */
  .yaent-prot-row {
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px;
  }
  .yaent-prot-card {
    border: 1px solid #E5E7EB; border-radius: 10px; padding: 10px;
    background: white;
  }
  .yaent-badge-ok {
    font-size: 7px; font-weight: 600; color: #22C55E;
    padding: 1px 6px; border-radius: 4px; border: 1px solid rgba(34,197,94,0.3);
  }
  .yaent-badge-active {
    font-size: 7px; font-weight: 600; color: #22C55E;
    padding: 1px 6px; border-radius: 4px; background: rgba(34,197,94,0.08);
    border: 1px solid rgba(34,197,94,0.2);
  }
  .yaent-badge-count {
    font-size: 7px; font-weight: 700; color: white;
    padding: 1px 6px; border-radius: 10px; background: #EF4444;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .yaent-flow-row, .yaent-prot-row { grid-template-columns: 1fr; }
    .yaent-tabs { display: none; }
  }
</style>
