---
/** MockupProductivity — yaConnect Native Integrations screen (CSS-only mockup) */
---
<div class="pt-frame">
  <!-- Left sidebar + main content -->
  <div class="pt-layout">
    <!-- Sidebar (icons only) -->
    <div class="pt-sidebar">
      <div class="pt-sidebar-icon pt-sidebar-icon-active">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      </div>
      <div class="pt-sidebar-icon">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      </div>
      <div class="pt-sidebar-icon">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
      </div>
      <div class="pt-sidebar-icon">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      </div>
      <div class="pt-sidebar-icon">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      </div>
      <div class="pt-sidebar-icon">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      <div class="pt-sidebar-icon">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      </div>
      <div class="pt-sidebar-icon">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      </div>
      <div class="pt-sidebar-icon">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
      </div>
      <div class="pt-sidebar-icon">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      </div>
      <div class="pt-sidebar-icon">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <div class="pt-sidebar-icon">
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
      </div>
    </div>

    <!-- Main content -->
    <div class="pt-main">
      <!-- Top header bar -->
      <div class="pt-header">
        <div class="pt-header-left">
          <div class="pt-header-logo">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <span class="pt-header-title">yaConnect</span>
        </div>
        <div class="pt-header-stats">
          <span class="pt-header-stat">2 Apps Ativos</span>
          <span class="pt-header-stat-sep"></span>
          <span class="pt-header-stat">0 Eventos (24h)</span>
          <span class="pt-header-stat-sep"></span>
          <span class="pt-header-stat">100% Taxa de Sucesso</span>
        </div>
        <div class="pt-header-search">
          <svg width="7" height="7" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <span class="pt-header-search-text">Buscar apps...</span>
        </div>
      </div>

      <!-- Tab bar -->
      <div class="pt-tabs">
        <span class="pt-tab">Dashboard</span>
        <span class="pt-tab pt-tab-active">Nativos</span>
        <span class="pt-tab">Apps</span>
        <span class="pt-tab">Templates</span>
        <span class="pt-tab">Eventos</span>
      </div>

      <!-- Title section -->
      <div class="pt-title-section">
        <span class="pt-title">Integracoes Nativas</span>
        <span class="pt-subtitle">Conecte em 2 minutos. Sem codigo, sem complicacao.</span>
      </div>

      <!-- Cards grid -->
      <div class="pt-grid">
        <!-- Hotmart -->
        <div class="pt-card">
          <div class="pt-card-top">
            <div class="pt-card-icon" style="background: #F04438;">
              <span>+</span>
            </div>
            <span class="pt-card-status">Nao conectado</span>
          </div>
          <span class="pt-card-name">Hotmart</span>
          <span class="pt-card-tag pt-tag-info">
            <svg width="5" height="5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
            Infoprodutos
          </span>
          <span class="pt-card-desc">Receba compras, reembolsos e chargebacks da Hotmart automaticamente.</span>
          <button class="pt-card-btn">Conectar</button>
        </div>

        <!-- Kiwify -->
        <div class="pt-card">
          <div class="pt-card-top">
            <div class="pt-card-icon" style="background: #20B2AA;">
              <span>&gt;</span>
            </div>
            <span class="pt-card-status">Nao conectado</span>
          </div>
          <span class="pt-card-name">Kiwify</span>
          <span class="pt-card-tag pt-tag-info">
            <svg width="5" height="5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
            Infoprodutos
          </span>
          <span class="pt-card-desc">Receba compras, reembolsos e assinaturas da Kiwify automaticamente.</span>
          <button class="pt-card-btn">Conectar</button>
        </div>

        <!-- Shopify -->
        <div class="pt-card">
          <div class="pt-card-top">
            <div class="pt-card-icon" style="background: #96BF48;">
              <span>S</span>
            </div>
            <span class="pt-card-status">Nao conectado</span>
          </div>
          <span class="pt-card-name">Shopify</span>
          <span class="pt-card-tag pt-tag-ecom">
            <svg width="5" height="5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
            E-commerce
          </span>
          <span class="pt-card-desc">Receba pedidos, pagamentos e reembolsos da sua loja Shopify.</span>
          <button class="pt-card-btn">Conectar</button>
        </div>

        <!-- Bling -->
        <div class="pt-card">
          <div class="pt-card-top">
            <div class="pt-card-icon" style="background: #1F2937;">
              <span>B</span>
            </div>
            <span class="pt-card-status">Nao conectado</span>
          </div>
          <span class="pt-card-name">Bling</span>
          <span class="pt-card-tag pt-tag-erp">
            <svg width="5" height="5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            ERP
          </span>
          <span class="pt-card-desc">Receba pedidos e notas fiscais do Bling automaticamente.</span>
          <button class="pt-card-btn">Conectar</button>
        </div>

        <!-- Google Sheets -->
        <div class="pt-card">
          <div class="pt-card-top">
            <div class="pt-card-icon" style="background: #34A853;">
              <span>G</span>
            </div>
            <span class="pt-card-status">Nao conectado</span>
          </div>
          <span class="pt-card-name">Google Sheets</span>
          <span class="pt-card-tag pt-tag-prod">
            <svg width="5" height="5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
            Produtividade
          </span>
          <span class="pt-card-desc">Exporte leads e dados para planilhas automaticamente.</span>
          <button class="pt-card-btn">Conectar</button>
        </div>

        <!-- OpenAI -->
        <div class="pt-card">
          <div class="pt-card-top">
            <div class="pt-card-icon" style="background: #0F0F0F;">
              <span>AI</span>
            </div>
            <span class="pt-card-status">Nao conectado</span>
          </div>
          <span class="pt-card-name">OpenAI</span>
          <span class="pt-card-tag pt-tag-ai">
            <svg width="5" height="5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 014 4v1h2a2 2 0 012 2v10a2 2 0 01-2 2H6a2 2 0 01-2-2V9a2 2 0 012-2h2V6a4 4 0 014-4z"/><circle cx="9" cy="13" r="1"/><circle cx="15" cy="13" r="1"/></svg>
            IA
          </span>
          <span class="pt-card-desc">Conecte modelos de IA para enriquecimento automatico.</span>
          <button class="pt-card-btn">Conectar</button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .pt-frame {
    width: 100%;
    max-width: 420px;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06), 0 1px 4px rgba(0, 0, 0, 0.03);
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.05);
    overflow: hidden;
    font-family: 'Inter', sans-serif;
  }

  /* Layout: sidebar + main */
  .pt-layout {
    display: flex;
    min-height: 0;
  }

  /* Sidebar */
  .pt-sidebar {
    width: 24px;
    min-width: 24px;
    background: #F9FAFB;
    border-right: 1px solid #F3F4F6;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 0 6px;
    gap: 4px;
  }
  .pt-sidebar-icon {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9CA3AF;
    cursor: default;
  }
  .pt-sidebar-icon-active {
    background: rgba(32, 178, 170, 0.1);
    color: #20B2AA;
  }

  /* Main content area */
  .pt-main {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  /* Header bar */
  .pt-header {
    padding: 6px 8px;
    display: flex;
    align-items: center;
    gap: 6px;
    background: #ffffff;
    border-bottom: 1px solid #F3F4F6;
  }
  .pt-header-left {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }
  .pt-header-logo {
    width: 16px;
    height: 16px;
    border-radius: 5px;
    background: linear-gradient(135deg, #20B2AA, #2DD4BF);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .pt-header-title {
    font-size: 7.5px;
    font-weight: 700;
    color: #1F2937;
    white-space: nowrap;
  }
  .pt-header-stats {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    justify-content: center;
    min-width: 0;
  }
  .pt-header-stat {
    font-size: 5.5px;
    color: #6B7280;
    white-space: nowrap;
  }
  .pt-header-stat-sep {
    width: 1px;
    height: 8px;
    background: #E5E7EB;
    flex-shrink: 0;
  }
  .pt-header-search {
    display: flex;
    align-items: center;
    gap: 3px;
    padding: 2.5px 6px;
    border-radius: 4px;
    background: #F9FAFB;
    border: 1px solid #E5E7EB;
    flex-shrink: 0;
  }
  .pt-header-search-text {
    font-size: 5.5px;
    color: #9CA3AF;
    white-space: nowrap;
  }

  /* Tabs */
  .pt-tabs {
    display: flex;
    gap: 0;
    padding: 0 8px;
    border-bottom: 1px solid #F3F4F6;
    background: #ffffff;
  }
  .pt-tab {
    font-size: 6px;
    font-weight: 500;
    color: #9CA3AF;
    padding: 5px 6px 4px;
    border-bottom: 1.5px solid transparent;
    cursor: default;
    white-space: nowrap;
  }
  .pt-tab-active {
    color: #20B2AA;
    font-weight: 600;
    border-bottom-color: #20B2AA;
  }

  /* Title section */
  .pt-title-section {
    padding: 7px 8px 4px;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .pt-title {
    font-size: 9px;
    font-weight: 700;
    color: #1F2937;
    line-height: 1.2;
  }
  .pt-subtitle {
    font-size: 5.5px;
    color: #9CA3AF;
    line-height: 1.3;
  }

  /* Cards grid */
  .pt-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5px;
    padding: 5px 8px 8px;
  }
  .pt-card {
    background: #ffffff;
    border: 1px solid #F3F4F6;
    border-radius: 8px;
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .pt-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }
  .pt-card-icon {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .pt-card-icon span {
    font-size: 7px;
    font-weight: 800;
    color: #ffffff;
    line-height: 1;
  }
  .pt-card-status {
    font-size: 5px;
    font-weight: 500;
    color: #9CA3AF;
    background: #F3F4F6;
    padding: 1.5px 4px;
    border-radius: 3px;
    white-space: nowrap;
  }
  .pt-card-name {
    font-size: 7px;
    font-weight: 700;
    color: #1F2937;
    line-height: 1.2;
  }
  .pt-card-tag {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    font-size: 5px;
    font-weight: 600;
    padding: 1.5px 4px;
    border-radius: 3px;
    width: fit-content;
    line-height: 1;
  }
  .pt-tag-info {
    background: rgba(249, 115, 22, 0.08);
    color: #EA580C;
  }
  .pt-tag-ecom {
    background: rgba(34, 197, 94, 0.08);
    color: #16A34A;
  }
  .pt-tag-erp {
    background: rgba(99, 102, 241, 0.08);
    color: #4F46E5;
  }
  .pt-tag-crm {
    background: rgba(168, 85, 247, 0.08);
    color: #9333EA;
  }
  .pt-tag-prod {
    background: rgba(34, 197, 94, 0.08);
    color: #16A34A;
  }
  .pt-tag-comm {
    background: rgba(168, 85, 247, 0.08);
    color: #9333EA;
  }
  .pt-tag-ai {
    background: rgba(15, 15, 15, 0.08);
    color: #374151;
  }
  .pt-card-desc {
    font-size: 5.5px;
    color: #6B7280;
    line-height: 1.35;
  }
  .pt-card-btn {
    margin-top: 2px;
    width: 100%;
    padding: 3px 0;
    background: #20B2AA;
    color: #ffffff;
    font-size: 5.5px;
    font-weight: 600;
    border: none;
    border-radius: 4px;
    cursor: default;
    text-align: center;
    font-family: 'Inter', sans-serif;
    line-height: 1;
  }
</style>
