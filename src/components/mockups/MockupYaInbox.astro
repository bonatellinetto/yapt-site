---
/** MockupYaInbox — Inbox Central de Conversas with conversation cards (conversations page) */
---
<div class="yinb-frame">
  <!-- Top bar -->
  <div class="yinb-topbar">
    <div style="display: flex; align-items: center; gap: 8px;">
      <div style="width: 24px; height: 24px; border-radius: 8px; background: linear-gradient(135deg, #20B2AA, #14B8A6); display: flex; align-items: center; justify-content: center;">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6" fill="none" stroke="white" stroke-width="1.5"/></svg>
      </div>
      <div>
        <span style="font-size: 12px; font-weight: 700; color: #1F2937;">yaInbox</span>
        <span style="font-size: 10px; color: #9CA3AF; margin-left: 4px;">Central de Conversas</span>
      </div>
    </div>
    <div style="display: flex; align-items: center; gap: 10px; font-size: 9px; color: #6B7280;">
      <span style="display: flex; align-items: center; gap: 3px;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        6 ativos
      </span>
      <span style="display: flex; align-items: center; gap: 3px;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        TMA: 03:12
      </span>
    </div>
  </div>

  <div class="yinb-body">
    <!-- Sidebar -->
    <div class="yinb-sidebar">
      <div class="yinb-search">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <span>Buscar conversas...</span>
      </div>

      <div class="yinb-section-label">Minhas filas</div>
      <div class="yinb-nav-item yinb-nav-active">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#20B2AA" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Minha Caixa
      </div>
      <div class="yinb-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        Nao Atribuidas
      </div>
      <div class="yinb-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        Aguardando Atendime...
      </div>
      <div class="yinb-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
        Outbound Pendentes
      </div>
      <div class="yinb-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        Aguardando Cliente
      </div>
      <div class="yinb-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6"/></svg>
        Soneca
      </div>

      <div class="yinb-section-label" style="margin-top: 8px;">Prioridade</div>
      <div class="yinb-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        Fila Inteligente
      </div>
      <div class="yinb-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        SLA em Risco
      </div>
      <div class="yinb-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="#20B2AA"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        IA Ativa
        <span class="yinb-badge-green">4</span>
      </div>

      <div class="yinb-section-label" style="margin-top: 8px;">Historico</div>
      <div class="yinb-nav-item">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><path d="M9 11l3 3L22 4"/></svg>
        Finalizadas
        <span class="yinb-badge-gray">285</span>
      </div>
    </div>

    <!-- Main content -->
    <div class="yinb-main">
      <!-- Action bar -->
      <div class="yinb-actions">
        <div style="display: flex; gap: 4px;">
          <span class="yinb-filter-btn yinb-filter-active">Todos</span>
          <span class="yinb-filter-btn">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="#25D366"><circle cx="12" cy="12" r="10"/></svg>
            WhatsApp
          </span>
          <span class="yinb-filter-btn">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/></svg>
            Email
          </span>
          <span class="yinb-filter-btn">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="#E1306C"><circle cx="12" cy="12" r="10"/></svg>
            Instagram
          </span>
          <span class="yinb-filter-btn">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="#0084FF"><circle cx="12" cy="12" r="10"/></svg>
            Messenger
          </span>
        </div>
        <div style="display: flex; align-items: center; gap: 6px;">
          <div class="yinb-btn-filter">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
            Filtros
          </div>
        </div>
      </div>

      <!-- Cards grid -->
      <div class="yinb-cards">
        <!-- Card 1 — WhatsApp, closed -->
        <div class="yinb-card">
          <div class="yinb-card-header">
            <div style="display: flex; align-items: center; gap: 5px;">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="#25D366"><circle cx="12" cy="12" r="10"/></svg>
              <span class="yinb-card-name">Rodrigo Pimentel</span>
            </div>
            <div class="yinb-card-badge-closed">Fechada</div>
            <span class="yinb-card-count" style="background: #F59E0B;">7</span>
          </div>
          <div class="yinb-card-phone">+55 (11) 98765-4321</div>
          <div class="yinb-card-preview">Perfeito, Marina! Vou alinhar com o CFO e volto na segunda...</div>
          <div class="yinb-card-footer">
            <span class="yinb-card-tag">MQL</span>
            <span class="yinb-card-meta">
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              1 dia
            </span>
          </div>
        </div>

        <!-- Card 2 — Email -->
        <div class="yinb-card">
          <div class="yinb-card-header">
            <div style="display: flex; align-items: center; gap: 5px;">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="#8B5CF6"><rect x="2" y="4" width="20" height="16" rx="3"/></svg>
              <span class="yinb-card-name">Ana Carolina Silva</span>
            </div>
            <span class="yinb-card-count" style="background: #20B2AA;">3</span>
          </div>
          <div class="yinb-card-phone">ana@techretail.com.br</div>
          <div class="yinb-card-preview">Tudo certo! Voce tinha mencionado antes que o plano Enterprise...</div>
          <div class="yinb-card-footer">
            <span class="yinb-card-tag">Lead</span>
            <span class="yinb-card-meta">
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              24 horas
            </span>
          </div>
        </div>

        <!-- Card 3 — Instagram -->
        <div class="yinb-card">
          <div class="yinb-card-header">
            <div style="display: flex; align-items: center; gap: 5px;">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="#E1306C"><circle cx="12" cy="12" r="10"/></svg>
              <span class="yinb-card-name">Lucas Ferreira</span>
            </div>
            <span class="yinb-card-count" style="background: #20B2AA;">2</span>
          </div>
          <div class="yinb-card-phone">@lucas.ferreira.dev</div>
          <div class="yinb-card-preview">Sim, voce e o contato certo? Ja temos se...</div>
          <div class="yinb-card-footer">
            <span class="yinb-card-tag">Lead</span>
            <span class="yinb-card-meta">
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              2 horas
            </span>
          </div>
        </div>

        <!-- Card 4 — WhatsApp -->
        <div class="yinb-card">
          <div class="yinb-card-header">
            <div style="display: flex; align-items: center; gap: 5px;">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="#25D366"><circle cx="12" cy="12" r="10"/></svg>
              <span class="yinb-card-name">Patricia Mendes</span>
            </div>
            <span class="yinb-card-count" style="background: #F59E0B;">4</span>
          </div>
          <div class="yinb-card-phone">+55 (21) 99876-5432</div>
          <div class="yinb-card-preview">Cara, que cenario incrivel! *4-5 milhoes p...</div>
          <div class="yinb-card-footer">
            <span class="yinb-card-tag">Lead</span>
            <span class="yinb-card-meta">
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              1 hora
            </span>
          </div>
        </div>

        <!-- Card 5 — Messenger -->
        <div class="yinb-card">
          <div class="yinb-card-header">
            <div style="display: flex; align-items: center; gap: 5px;">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="#0084FF"><circle cx="12" cy="12" r="10"/></svg>
              <span class="yinb-card-name">Marcos Oliveira</span>
            </div>
            <span class="yinb-card-count" style="background: #20B2AA;">1</span>
          </div>
          <div class="yinb-card-phone">Messenger · LogPrime</div>
          <div class="yinb-card-preview">Boa tarde! Vi o anuncio sobre automacao de atendimento...</div>
          <div class="yinb-card-footer">
            <span class="yinb-card-tag">SQL</span>
            <span class="yinb-card-meta">
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              30 min
            </span>
          </div>
        </div>

        <!-- Card 6 — WhatsApp, IA tag -->
        <div class="yinb-card">
          <div class="yinb-card-header">
            <div style="display: flex; align-items: center; gap: 5px;">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="#25D366"><circle cx="12" cy="12" r="10"/></svg>
              <span class="yinb-card-name">Camila Duarte</span>
            </div>
            <span class="yinb-card-count" style="background: #8B5CF6;">
              <svg width="6" height="6" viewBox="0 0 24 24" fill="white"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            </span>
          </div>
          <div class="yinb-card-phone">+55 (31) 98234-1122</div>
          <div class="yinb-card-preview">Oi Camila! Entendi que voce busca otimizar o atendimento...</div>
          <div class="yinb-card-footer">
            <span class="yinb-card-tag-ia">IA Ativa</span>
            <span class="yinb-card-meta">
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              5 min
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .yinb-frame {
    width: 100%; max-width: 580px; border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.03);
    background: #ffffff; border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
  }

  .yinb-topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px; border-bottom: 1px solid #F3F4F6;
  }

  .yinb-body {
    display: grid; grid-template-columns: 140px 1fr;
  }

  /* Sidebar */
  .yinb-sidebar {
    padding: 8px 6px; border-right: 1px solid #F3F4F6;
    background: #FAFBFC;
  }
  .yinb-search {
    display: flex; align-items: center; gap: 4px;
    padding: 5px 6px; border: 1px solid #E5E7EB; border-radius: 6px;
    font-size: 8px; color: #9CA3AF; margin-bottom: 8px;
  }
  .yinb-section-label {
    font-size: 7px; font-weight: 600; color: #9CA3AF;
    padding: 4px 6px 2px; letter-spacing: 0.03em;
  }
  .yinb-nav-item {
    display: flex; align-items: center; gap: 5px;
    padding: 4px 6px; border-radius: 5px;
    font-size: 8px; color: #374151; cursor: default;
  }
  .yinb-nav-active {
    background: rgba(32,178,170,0.08); color: #20B2AA; font-weight: 600;
  }
  .yinb-badge-green {
    margin-left: auto; font-size: 7px; font-weight: 700; color: white;
    background: #20B2AA; border-radius: 8px; padding: 1px 5px;
  }
  .yinb-badge-gray {
    margin-left: auto; font-size: 7px; font-weight: 600; color: white;
    background: #EF4444; border-radius: 8px; padding: 1px 5px;
  }

  /* Main */
  .yinb-main { padding: 8px; }
  .yinb-actions {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 8px;
  }
  .yinb-filter-btn {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 8px; color: #6B7280; padding: 3px 8px;
    border: 1px solid #E5E7EB; border-radius: 12px;
  }
  .yinb-filter-active {
    background: #20B2AA; color: white; border-color: #20B2AA; font-weight: 600;
  }
  .yinb-btn-filter {
    display: flex; align-items: center; gap: 3px;
    font-size: 8px; color: #6B7280; padding: 3px 8px;
    border: 1px solid #E5E7EB; border-radius: 6px;
  }

  /* Cards */
  .yinb-cards {
    display: grid; grid-template-columns: 1fr 1fr; gap: 6px;
  }
  .yinb-card {
    border: 1.5px solid #F59E0B; border-radius: 10px;
    padding: 8px 10px; background: white;
  }
  .yinb-card:nth-child(2) { border-color: #20B2AA; }
  .yinb-card:nth-child(3) { border-color: #20B2AA; }
  .yinb-card:nth-child(5) { border-color: #20B2AA; }
  .yinb-card:nth-child(6) { border-color: #8B5CF6; }

  .yinb-card-header {
    display: flex; align-items: center; gap: 4px; margin-bottom: 2px;
  }
  .yinb-card-name { font-size: 9px; font-weight: 600; color: #1F2937; }
  .yinb-card-badge-closed {
    font-size: 6px; font-weight: 600; color: #EF4444;
    padding: 1px 5px; border-radius: 4px;
    border: 1px solid rgba(239,68,68,0.3); background: rgba(239,68,68,0.06);
  }
  .yinb-card-count {
    margin-left: auto; width: 16px; height: 16px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 7px; font-weight: 700; color: white; flex-shrink: 0;
  }
  .yinb-card-phone { font-size: 8px; color: #9CA3AF; margin-bottom: 4px; }
  .yinb-card-preview {
    font-size: 8px; color: #6B7280; line-height: 1.4;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    margin-bottom: 6px;
  }
  .yinb-card-footer {
    display: flex; align-items: center; justify-content: space-between;
  }
  .yinb-card-tag {
    font-size: 7px; font-weight: 500; color: #6B7280;
    padding: 1px 6px; border-radius: 3px; background: #F3F4F6;
  }
  .yinb-card-tag-ia {
    font-size: 7px; font-weight: 600; color: #8B5CF6;
    padding: 1px 6px; border-radius: 3px;
    background: rgba(139,92,246,0.08); border: 1px solid rgba(139,92,246,0.2);
  }
  .yinb-card-meta {
    display: flex; align-items: center; gap: 2px;
    font-size: 7px; color: #9CA3AF;
  }

  @media (max-width: 640px) {
    .yinb-body { grid-template-columns: 1fr; }
    .yinb-sidebar { display: none; }
    .yinb-cards { grid-template-columns: 1fr; }
  }
</style>
