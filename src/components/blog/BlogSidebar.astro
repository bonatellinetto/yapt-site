---
import type { BlogPost, BlogCategory } from '../../lib/blog';

interface Props {
  categories: BlogCategory[];
  relatedPosts: BlogPost[];
  currentCategory?: string | null;
  tags?: string[];
}

const { categories, relatedPosts, currentCategory, tags = [] } = Astro.props;
---

<aside class="space-y-8">
  <!-- Search -->
  <div>
    <h3 class="font-poppins text-sm font-semibold text-[#1a1a2e] mb-3">Buscar</h3>
    <div class="relative">
      <input
        type="text"
        id="blog-search-input"
        placeholder="Buscar artigos..."
        class="w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:border-teal-400 transition-colors"
      />
      <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" viewBox="0 0 20 20">
        <circle cx="8.5" cy="8.5" r="6" stroke="currentColor" stroke-width="1.5"/>
        <path d="M13 13l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
    <div id="blog-search-results" class="hidden mt-2 bg-white rounded-xl border border-gray-100 shadow-lg max-h-60 overflow-y-auto"></div>
  </div>

  <!-- Categories -->
  {categories.length > 0 && (
    <div>
      <h3 class="font-poppins text-sm font-semibold text-[#1a1a2e] mb-3">Categorias</h3>
      <div class="space-y-1">
        {categories.map((cat) => (
          <a
            href={`/blog?category=${cat.slug}`}
            class={`block px-3 py-2 rounded-lg text-sm transition-colors ${
              currentCategory === cat.slug
                ? 'bg-teal-50 text-teal-700 font-medium'
                : 'text-[#656D78] hover:bg-gray-50'
            }`}
          >
            <span class="inline-block w-2 h-2 rounded-full mr-2" style={`background: ${cat.color};`}></span>
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <div>
      <h3 class="font-poppins text-sm font-semibold text-[#1a1a2e] mb-3">Posts Relacionados</h3>
      <div class="space-y-3">
        {relatedPosts.map((post) => (
          <a href={`/blog/${post.slug}`} class="block group">
            <h4 class="text-sm text-[#434A54] font-medium group-hover:text-teal-600 transition-colors line-clamp-2">
              {post.title}
            </h4>
            <span class="text-xs text-[#AAB2BD]">
              {post.reading_time_minutes} min de leitura
            </span>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Tags -->
  {tags.length > 0 && (
    <div>
      <h3 class="font-poppins text-sm font-semibold text-[#1a1a2e] mb-3">Tags</h3>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="bg-gray-100 text-[#656D78] rounded-full px-3 py-1 text-xs">{tag}</span>
        ))}
      </div>
    </div>
  )}
</aside>
