---
import type { BlogPost } from '../../lib/blog';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const imageUrl = post.cover_image_url || post.card_image_url;
const date = post.published_at ? new Date(post.published_at).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) : '';
---

<a href={`/blog/${post.slug}`} class="group block">
  <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-200">
    <div class="grid grid-cols-1 lg:grid-cols-2">
      <!-- Image -->
      <div class="aspect-[16/9] lg:aspect-auto overflow-hidden">
        {imageUrl ? (
          <img
            src={imageUrl}
            alt={post.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
        ) : (
          <div class="w-full h-full min-h-[240px] flex items-center justify-center" style="background: linear-gradient(135deg, #064E3B, #0D9488);">
            <span class="font-poppins text-white/60 text-lg">yapt.</span>
          </div>
        )}
      </div>
      <!-- Content -->
      <div class="p-6 lg:p-8 flex flex-col justify-center">
        {post.category && (
          <span
            class="inline-block text-xs font-medium rounded-full px-3 py-1 mb-4 w-fit"
            style={`background: ${post.category.color}15; color: ${post.category.color};`}
          >
            {post.category.name}
          </span>
        )}
        <h2 class="font-poppins text-xl lg:text-2xl font-bold text-[#1a1a2e] mb-3 group-hover:text-teal-600 transition-colors">
          {post.title}
        </h2>
        {post.subtitle && (
          <p class="text-base text-[#656D78] mb-4">{post.subtitle}</p>
        )}
        {post.excerpt && (
          <p class="text-sm text-[#656D78] line-clamp-3 mb-4">{post.excerpt}</p>
        )}
        <div class="flex items-center gap-4 text-sm text-[#AAB2BD]">
          <span>{post.author_name}</span>
          <span>&middot;</span>
          <span>{date}</span>
          {post.reading_time_minutes > 0 && (
            <>
              <span>&middot;</span>
              <span>{post.reading_time_minutes} min de leitura</span>
            </>
          )}
        </div>
      </div>
    </div>
  </div>
</a>
